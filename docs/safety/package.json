{
  "name": "slint-safety-manual",
  "type": "module",
  "version": "1.18.0",
  "scripts": {
    "sync-language-spec": "node scripts/sync-language-spec.mjs",
    "dev": "node scripts/sync-language-spec.mjs && astro dev",
    "start": "node scripts/sync-language-spec.mjs && astro dev",
    "build": "node scripts/sync-language-spec.mjs && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix",
    "type-check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "catalog:",
    "@astrojs/starlight": "catalog:",
    "@slint/common-files": "workspace:*",
    "@types/node": "catalog:",
    "astro": "catalog:",
    "astro-mermaid": "2.1.0",
    "mermaid": "11.16.0",
    "sharp": "catalog:",
    "typescript": "catalog:"
  }
}
