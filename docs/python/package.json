{
    "name": "slint-python-docs",
    "type": "module",
    "version": "1.18.0",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "gen": "uv run python gen_mdx.py",
        "thirdparty": "node --experimental-strip-types ./scripts/generate-thirdparty.ts",
        "predev": "pnpm gen",
        "dev": "astro dev",
        "start": "astro dev",
        "prebuild": "pnpm gen && pnpm thirdparty",
        "build": "astro check && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "format": "biome format",
        "format:fix": "biome format --write",
        "lint": "biome lint",
        "lint:fix": "biome lint --fix",
        "type-check": "astro check"
    },
    "dependencies": {
        "@astrojs/check": "catalog:",
        "@astrojs/sitemap": "catalog:",
        "@astrojs/starlight": "catalog:",
        "@slint/common-files": "workspace:*",
        "@types/node": "catalog:",
        "astro": "catalog:",
        "sharp": "catalog:",
        "typescript": "catalog:"
    }
}
