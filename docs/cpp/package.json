{
    "name": "slint-cpp-docs",
    "type": "module",
    "version": "1.18.0",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "thirdparty": "node --experimental-strip-types ./scripts/generate-thirdparty.ts",
        "gen:api": "node --experimental-strip-types ./scripts/generate-api.ts",
        "predev": "pnpm gen:api",
        "dev": "astro dev",
        "start": "astro dev",
        "build": "node --experimental-strip-types ./scripts/generate-thirdparty.ts && node --experimental-strip-types ./scripts/generate-api.ts && astro check && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "test": "node --experimental-strip-types --test tests/convert.test.ts",
        "format": "biome format",
        "format:fix": "biome format --write",
        "lint": "biome lint",
        "lint:fix": "biome lint --fix",
        "type-check": "astro check"
    },
    "dependencies": {
        "@astrojs/check": "catalog:",
        "@astrojs/sitemap": "catalog:",
        "@astrojs/starlight": "catalog:",
        "@pagefind/default-ui": "catalog:",
        "@slint/common-files": "workspace:*",
        "@types/node": "catalog:",
        "astro": "catalog:",
        "sharp": "catalog:",
        "shiki": "4.3.1",
        "typescript": "catalog:"
    }
}
