import { MainWindowAdapter } from "../main_window_adapter.slint";
import {
    ElevatedCard,
    FilledCard,
    OutlinedCard,
    MaterialText,
    MaterialPalette,
    MaterialTypography,
    ElevatedButton,
    FilledButton,
    TonalButton,
    OutlineButton,
    TextButton,
    FloatingActionButton,
    FABStyle,
    IconButton,
    Vertical,
    Horizontal,
    Grid,
    FilledIconButton,
    TonalIconButton,
    OutlineIconButton,
    SegmentedButton,
    ScrollView,
    NavigationBar,
    CircularProgressIndicator,
    LinearProgressIndicator,
    SnackBar,
    ModalBottomSheet,
    MaterialText,
    MaterialStyleMetrics,
    HorizontalDivider,
    Dialog,
    FullscreenDialog
} from "../../../../src/material.slint";

import { ActionsView } from "./actions_view.slint";
import { NavigationView } from "./navigation_view.slint";
import { MainWindowAdapter } from "../main_window_adapter.slint";

export component ComponentsView {
    if !MainWindowAdapter.break_layout : HorizontalLayout {
        ScrollView {
            content_height: navigation_view.height;

            navigation_view := NavigationView {
                width: 100%;
            }

            changed content_y => {
                MainWindowAdapter.show_background = self.content_y != 0;
            }
        }

        ScrollView {
            content_height: action_view.height;

            action_view := ActionsView {
                width: 100%;
            }

            changed content_y => {
                MainWindowAdapter.show_background = self.content_y != 0;
            }
        }
    }

    if MainWindowAdapter.break_layout : ScrollView {
        VerticalLayout {
            alignment: start;
            spacing: MaterialStyleMetrics.spacing_8;

            NavigationView {}
            ActionsView {}
        }

        changed content_y => {
            MainWindowAdapter.show_background = self.content_y != 0;
        }
    }
}
