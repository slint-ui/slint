{
    "name": "@slint-ui/common",
    "version": "1.18.0",
    "description": "Platform-independent TypeScript support code shared by the Slint JavaScript APIs. Not intended for direct use; install slint-ui instead.",
    "homepage": "https://github.com/slint-ui/slint",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/slint-ui/slint"
    },
    "main": "dist/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "LICENSE.md"
    ],
    "scripts": {
        "compile": "tsc --build && tsc --project tsconfig.esm.json"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
