    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "esnext",
        "noEmit": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "types": ["node"],
        "paths": {
