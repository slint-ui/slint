export component ImageTest inherits Window {
    width: 4px;
    height: 4px;
    background: #000000;

    Image {
        x: 1px;
        y: 1px;
        width: 2px;
        height: 2px;
        // 2x2 SVG: red / green / blue / white quadrants.
        source: @image-url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='2' height='2' shape-rendering='crispEdges'><rect x='0' y='0' width='1' height='1' fill='red'/><rect x='1' y='0' width='1' height='1' fill='lime'/><rect x='0' y='1' width='1' height='1' fill='blue'/><rect x='1' y='1' width='1' height='1' fill='white'/></svg>");
    }
}

/*
```rust
const W: usize = 4;
const H: usize = 4;
let mut data = vec![Rgba8Pixel::default(); W * H];
let mut buffer = SliceBuffer::new(&mut data, W, H);

let window = ImageTest::new();
window.render(&mut buffer);

// Background (#000000): outside the image rect.
assert_eq!(buffer.line_slice(0)[0], Rgba8Pixel { r: 0, g: 0, b: 0, a: 255 });
// Image drawn at (1, 1), 2x2: red, green, blue, white.
assert_eq!(buffer.line_slice(1)[1], Rgba8Pixel { r: 255, g: 0, b: 0, a: 255 });
assert_eq!(buffer.line_slice(1)[2], Rgba8Pixel { r: 0, g: 255, b: 0, a: 255 });
assert_eq!(buffer.line_slice(2)[1], Rgba8Pixel { r: 0, g: 0, b: 255, a: 255 });
assert_eq!(buffer.line_slice(2)[2], Rgba8Pixel { r: 255, g: 255, b: 255, a: 255 });
```
*/
