export component SimpleRect inherits Window {
    width: 20px;
    height: 20px;
    background: #ffffff;

    Rectangle {
        x: 5px;
        y: 5px;
        width: 10px;
        height: 10px;
        background: #ff0000;
    }
}

/*
```rust
const W: usize = 20;
const H: usize = 20;
let mut data = vec![Rgba8Pixel::default(); W * H];
let mut buffer = SliceBuffer::new(&mut data, W, H);

let window = SimpleRect::new();
window.render(&mut buffer);

assert_eq!(buffer.line_slice(0)[0], Rgba8Pixel { r: 255, g: 255, b: 255, a: 255 });
assert_eq!(buffer.line_slice(10)[10], Rgba8Pixel { r: 255, g: 0, b: 0, a: 255 });
assert_eq!(buffer.line_slice(10)[16], Rgba8Pixel { r: 255, g: 255, b: 255, a: 255 });
```
*/
