export component TestCase inherits Window {
    background: #123456;
    //#sls.paint.clip
    Rectangle {
        // Wider than the window and centered: starts at a negative x and is
        // clipped on both sides
        width: 80px;
        height: 20px;
        background: #ff8800;
    }
}

