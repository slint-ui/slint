// Skia font rendering is not consistent across platforms
//ignore:skia


export component TestCase inherits Window {
    width: 64px;
    height: 64px;
    forward-focus: i-text-input;
    VerticalLayout {
        i-text-input := TextInput {
            text: "Hello Everyone";
            wrap: word-wrap;
            color: green;
            font-size: 10px;
            init => {
                i-text-input.set-selection-offsets(7, 7);
            }
        }
        TextInput {
            text: "Hello";
            color: #abcd;
            opacity: 0.9;
            font-size: 10px;
            horizontal-alignment: center;
            init => {
                self.set-selection-offsets(2, 4);
            }
        }
        TextInput {
            text: "Everyone";
            font-size: 10px;
            width: 100%;
            horizontal-alignment: right;
            init => {
                self.set-selection-offsets(5, 7);
            }
        }
    }
}
