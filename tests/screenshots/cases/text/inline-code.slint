// Skia font rendering is not consistent across platforms
//ignore:skia
// SIZE=320x160

// `font-family` is set to a name that does not match the embedded bitmap font;
// this routes the StyledText through the parley/vector-font path in the software
// renderer, which is where the inline `code` capsule is drawn. With the bitmap
// fast-path the capsule overlay is never reached.
export component TestCase inherits Window {
    width: 320px;
    height: 160px;
    background: white;
    default-font-family: "Inline Code Test";
    VerticalLayout {
        padding: 8px;
        spacing: 8px;
        StyledText {
            default-font-size: 32px;
            default-color: #111;
            text: @markdown("hi `code`");
            horizontal-alignment: center;
        }
        Rectangle {
            background: #1e1e1e;
            StyledText {
                default-font-size: 32px;
                default-color: #ededed;
                text: @markdown("hi `code`");
                horizontal-alignment: center;
            }
        }
    }
}
