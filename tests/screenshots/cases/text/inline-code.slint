// Skia font rendering is not consistent across platforms
//ignore:skia
// The embedded bitmap-font fast path in the software renderer doesn't draw the
// inline code capsule, so the embed variant wouldn't exercise this feature.
//ignore: software-embed-assets
// SIZE=320x160

export component TestCase inherits Window {
    width: 320px;
    height: 160px;
    background: white;
    VerticalLayout {
        padding: 8px;
        spacing: 8px;
        StyledText {
            default-font-size: 32px;
            default-color: #111;
            text: @markdown("hi `code`");
            horizontal-alignment: center;
        }
        Rectangle {
            background: #1e1e1e;
            StyledText {
                default-font-size: 32px;
                default-color: #ededed;
                text: @markdown("hi `code`");
                horizontal-alignment: center;
            }
        }
    }
}
