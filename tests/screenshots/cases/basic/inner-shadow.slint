// SIZE=160x160
// BASE_THRESHOLD=3
//ignore: software

export component TestCase inherits Window {
    width: 160px;
    height: 160px;
    background: white;

    GridLayout {
        spacing: 8px;
        padding: 12px;
        Row {
            // Simple inner shadow with blur. The red child overlaps the shadow edge on
            // one side, proving the inner shadow is rendered below children.
            Rectangle {
                height: 64px;
                background: lightyellow;
                inner-shadow-color: #000000c0;
                inner-shadow-blur: 8px;

                Rectangle {
                    width: 16px;
                    height: 16px;
                    x: 4px;
                    y: 4px;
                    background: red;
                }
            }
            // Inner shadow with offset (shadow appears stronger on the bottom-right interior)
            Rectangle {
                height: 64px;
                background: lightyellow;
                inner-shadow-color: #000000c0;
                inner-shadow-blur: 6px;
                inner-shadow-offset-x: 4px;
                inner-shadow-offset-y: 4px;
            }
        }
        Row {
            // Inner shadow with rounded corners
            Rectangle {
                height: 64px;
                background: lightyellow;
                border-radius: 12px;
                inner-shadow-color: #000000c0;
                inner-shadow-blur: 8px;
            }
            // Inner shadow with positive spread (makes the shadow band thicker)
            Rectangle {
                height: 64px;
                background: lightyellow;
                border-radius: 8px;
                inner-shadow-color: #000000c0;
                inner-shadow-blur: 6px;
                inner-shadow-spread: 5px;
            }
        }
    }
}
