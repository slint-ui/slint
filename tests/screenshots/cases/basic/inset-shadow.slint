// SIZE=160x160
// BASE_THRESHOLD=3
//ignore: software

export component TestCase inherits Window {
    width: 160px;
    height: 160px;
    background: white;

    GridLayout {
        spacing: 8px;
        padding: 12px;
        Row {
            // Simple inset shadow with blur. The shadow must stay below child content.
            Rectangle {
                background: lightyellow;
                inset-shadow-color: #000000c0;
                inset-shadow-blur: 8px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "TEXT";
                    color: black;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            // Inset shadow with offset (shadow appears stronger on the bottom-right interior)
            Rectangle {
                background: lightyellow;
                inset-shadow-color: #000000c0;
                inset-shadow-blur: 6px;
                inset-shadow-offset-x: 4px;
                inset-shadow-offset-y: 4px;
            }
        }
        Row {
            // Inset shadow with rounded corners
            Rectangle {
                background: lightyellow;
                border-radius: 12px;
                inset-shadow-color: #000000c0;
                inset-shadow-blur: 8px;
            }
            // Inset shadow with positive spread (makes the shadow band thicker)
            Rectangle {
                background: lightyellow;
                border-radius: 8px;
                inset-shadow-color: #000000c0;
                inset-shadow-blur: 6px;
                inset-shadow-spread: 5px;
            }
        }
    }
}
