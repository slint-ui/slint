component ComboBox inherits Rectangle {
    min-width: 60px;
}

component SubComp1 inherits Rectangle {
    HorizontalLayout {
        ComboBox {
            width: 200px;
        }
    }
}

component SubComp2 inherits HorizontalLayout {
    ComboBox {
        width: 200px;
    }
}

component SubComp3 inherits HorizontalLayout {
    max-width: 500px;
    Rectangle { }
}

component SubComp4 inherits SubComp1 {}


export component TestCase inherits Rectangle {
    width: 300phx;
    height: 300phx;

    sc1 := SubComp1 {}
    sc2 := SubComp2 {}
    // FIXME: the HorizontalLayout is required here because the sc3.max-width takes the existing binding instead of being re-materialized
    sc3 := HorizontalLayout { SubComp3 { width: 200px; } }
    sc4 := SubComp4 {}
    out property<bool> test: sc1.min-width == 200px && sc2.min-width == 200px && sc3.max-width == 200px && sc4.min-width == 200px;
}

/*

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_test());
```


```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```
*/
