// Test FlexBoxLayout flex-grow, flex-shrink, and flex-basis per-item properties

// Test 1: flex-grow — items grow proportionally to fill extra space
component TestFlexGrowRow inherits Rectangle {
    width: 300px;
    height: 50px;
    FlexBoxLayout {
        flex-wrap: no-wrap;
        r1 := Rectangle {
            flex-basis: 50px;
            flex-grow: 1;
            height: 50px;
            background: red;
        }
        r2 := Rectangle {
            flex-basis: 50px;
            flex-grow: 2;
            height: 50px;
            background: green;
        }
        r3 := Rectangle {
            flex-basis: 50px;
            flex-grow: 0;
            height: 50px;
            background: blue;
        }
    }

    // Total basis = 150px, extra = 150px
    // r1 gets 150 * 1/3 = 50, r2 gets 150 * 2/3 = 100, r3 gets 0
    // r1 = 100px, r2 = 150px, r3 = 50px
    out property <bool> test_r1: r1.width == 100px;
    out property <bool> test_r2: r2.width == 150px;
    out property <bool> test_r3: r3.width == 50px;
    out property <bool> test: test_r1 && test_r2 && test_r3;
}

// Test 2: flex-grow column direction
component TestFlexGrowColumn inherits Rectangle {
    width: 50px;
    height: 300px;
    FlexBoxLayout {
        flex-direction: column;
        flex-wrap: no-wrap;
        r1 := Rectangle {
            flex-basis: 50px;
            flex-grow: 1;
            width: 50px;
            background: red;
        }
        r2 := Rectangle {
            flex-basis: 50px;
            flex-grow: 3;
            width: 50px;
            background: green;
        }
    }

    // Total basis = 100px, extra = 200px
    // r1 gets 200 * 1/4 = 50, r2 gets 200 * 3/4 = 150
    // r1 = 100px, r2 = 200px
    out property <bool> test_r1: r1.height == 100px;
    out property <bool> test_r2: r2.height == 200px;
    out property <bool> test: test_r1 && test_r2;
}

// Test 3: flex-shrink — items shrink when container is too small
component TestFlexShrinkRow inherits Rectangle {
    width: 200px;
    height: 50px;
    FlexBoxLayout {
        flex-wrap: no-wrap;
        r1 := Rectangle {
            flex-basis: 150px;
            flex-shrink: 1;
            height: 50px;
            background: red;
        }
        r2 := Rectangle {
            flex-basis: 150px;
            flex-shrink: 1;
            height: 50px;
            background: green;
        }
    }

    // Total basis = 300px, overflow = 100px
    // Both shrink equally: each loses 50px
    // r1 = 100px, r2 = 100px
    out property <bool> test_r1: r1.width == 100px;
    out property <bool> test_r2: r2.width == 100px;
    out property <bool> test: test_r1 && test_r2;
}

// Test 4: flex-basis without flex-grow (items keep their basis size)
component TestFlexBasis inherits Rectangle {
    width: 300px;
    height: 50px;
    FlexBoxLayout {
        flex-wrap: no-wrap;
        r1 := Rectangle {
            flex-basis: 80px;
            height: 50px;
            background: red;
        }
        r2 := Rectangle {
            flex-basis: 120px;
            height: 50px;
            background: green;
        }
    }

    // No flex-grow, so items stay at their basis
    out property <bool> test_r1: r1.width == 80px;
    out property <bool> test_r2: r2.width == 120px;
    out property <bool> test: test_r1 && test_r2;
}

// Test 5: default behavior (no flex properties) — items use preferred size
component TestFlexDefaults inherits Rectangle {
    width: 300px;
    height: 50px;
    FlexBoxLayout {
        flex-wrap: no-wrap;
        r1 := Rectangle {
            preferred-width: 80px;
            height: 50px;
            background: red;
        }
        r2 := Rectangle {
            preferred-width: 120px;
            height: 50px;
            background: green;
        }
    }

    // No flex properties at all — same behavior as before
    out property <bool> test_r1: r1.width == 80px;
    out property <bool> test_r2: r2.width == 120px;
    out property <bool> test: test_r1 && test_r2;
}

export component TestCase inherits Window {
    width: 400px;
    height: 400px;

    VerticalLayout {
        t1 := TestFlexGrowRow { }
        t2 := TestFlexGrowColumn { }
        t3 := TestFlexShrinkRow { }
        t4 := TestFlexBasis { }
        t5 := TestFlexDefaults { }
    }

    out property <bool> test: t1.test && t2.test && t3.test && t4.test && t5.test;
}

/*
```cpp
auto handle = TestCase::create();
assert(handle->get_test());
```

```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```

```js
var instance = new slint.TestCase();
assert(instance.test);
```
*/
