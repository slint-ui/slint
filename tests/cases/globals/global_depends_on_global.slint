global Numbers  {
    in-out property <int> three: 3;
    in-out property <int> ten: root.three * Numbers.three + 1;
}

export global A  {
    in-out property <int> a_alias <=> root.a;
    in-out property <int> a: 3;
    in-out property <int> b: root.a + root.three;
    in-out property <int> three: Numbers.three;
}

export global B  {
   // property <int> a_alias <=> A.a_alias;
    in-out property <int> c: {
        debug(A.b, Numbers.ten);
        A.b + Numbers.ten;
    }
}

export component TestCase inherits Rectangle {
    callback set_a(int);
    set_a(a) => {
        A.a_alias = a;
    }
    in-out property <int> value1: B.c;
    in-out property <bool> test: root.value1 == 3 + 13;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_value1(), 3 + 13);
instance.invoke_set_a(4);
assert_eq!(instance.get_value1(), 4 + 13);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_value1(), 3 + 13);
instance.invoke_set_a(4);
assert_eq(instance.get_value1(), 4 + 13);
```

```js
let instance = new slint.TestCase({});
assert.equal(instance.value1, 3 + 13);
instance.set_a(4);
assert.equal(instance.value1, 4 + 13);
```

