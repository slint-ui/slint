const TestCase &instance = *handle;
slint_testing::mock_elapsed_time(100);
assert_eq(instance.get_log(), "if1,for1.1,for1.2,for2.1,if2.1,for2.2,if2.2,outer.1,mid.1,inner.1.1,inner.1.2,");
```

