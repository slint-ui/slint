assert(std::abs(instance.get_t1() - 42.3) < 0.0001);
assert(std::abs(instance.get_t2() - 42.3) < 0.0001);
assert_eq(instance.get_t3(), 42);
assert_eq(instance.get_t4(), 42);
assert(instance.get_test());
```

