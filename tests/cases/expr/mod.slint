assert_eq(instance.get_t4(),432);
assert_eq(instance.get_t5(), 1.8);
assert_eq(instance.get_t6(), 2.);
assert_eq(instance.get_t7(), 3.5);
assert_eq(instance.get_t8(), 0);
```


