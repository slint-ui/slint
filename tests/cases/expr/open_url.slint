TestCase := Rectangle {
    callback open-url-callback(url: string);
    open-url-callback(url) => {
        open-url(url);
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
instance.invoke_open_url_callback("https://example.com".into());
let url = slint_testing::access_testing_window(instance.window(), |window| window.open_url());
assert_eq!(url, Some("https://example.com".into()));
```

```cpp
auto handle = TestCase::create();
TestCase &instance = *handle;
instance.invoke_open_url_callback("https://example.com");
auto url = slint_testing::access_testing_window(instance.window(), [](auto *window){ return window->open_url(); });
assert_eq(url, std::make_optional("https://example.com"));
```

*/
