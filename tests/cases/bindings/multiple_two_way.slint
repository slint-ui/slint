component O inherits Text {
    in-out property <int> val;
    text: val;
    in-out property <int> a: val + 1;
}

export component TestCase inherits Window {
    in-out property <int> val: condition ? 2 : 4;
    in-out property <bool> condition : false;
    HorizontalLayout {
        o1 := O { val <=> val; }
        o2 := O { val <=> val; }
        o3 := O { val <=> val; }
        o4 := O { val <=> val; }
        o5 := O { val <=> val; }
    }
    in-out property <int> checksum: 10000 * o1.a + 1000 * o2.a + 100 * o3.a + 10 * o4.a + 1 * o5.a;
    in-out property <bool> test: checksum == 55555;
}


/*

```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_checksum(), 55555);
instance.set_condition(true);
assert_eq!(instance.get_checksum(), 33333);
```



```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_checksum(), 55555);
instance.set_condition(true);
assert_eq(instance.get_checksum(), 33333);
```


```js
let instance = new slint.TestCase({});
assert.equal(instance.checksum, 55555);
instance.condition = true;
assert.equal(instance.checksum, 33333);
```

*/
