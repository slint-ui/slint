// Long two-way-binding chains combined with two nested `for` loops over
// separate models. At the Base use-site the chain reaches both:
//  - the parent-model row (`odata.label`, parent_level == 1 from inside
//    the inner `for`), via an in-out property alias on `Base`,
//  - the inner-model row (`idata.bar`, parent_level == 0), through a
//    nested component (`Compo` exposes a string property aliased down to
//    `Text.text`).
// TouchAreas inside both `Compo` and `Base` write into the chain so we
// verify UI -> model propagation; native `set_row_data` on either model
// verifies model -> UI propagation.

struct Inner {
    bar: string,
    baz: int,
}

struct OuterItem {
    label: string,
    n: int,
}

component Compo {
    in-out property <string> other;
    callback compo_tap;
    HorizontalLayout {
        Text {
            text <=> other;
        }

        Rectangle {
            width: 30px;
            background: blue;
            TouchArea {
                clicked => {
                    other = "Z";
                    compo_tap();
                }
            }
        }
    }
}

component Base {
    in-out property <string> link_to_alias;
    in-out property <string> link_to_text <=> c.other;
    callback tap <=> c.compo_tap;
    HorizontalLayout {
        c := Compo { }

        Rectangle {
            width: 30px;
            background: red;
            TouchArea {
                clicked => {
                    link_to_alias = "A";
                    tap();
                }
            }
        }
    }
}

export component TestCase inherits Window {
    width: 600px;
    height: 600px;

    in-out property <[OuterItem]> outer_m: [
        { label: "O0", n: 0 },
        { label: "O1", n: 1 },
    ];
    in-out property <[Inner]> inner_m: [
        { bar: "I0", baz: 0 },
        { bar: "I1", baz: 1 },
    ];
    in-out property <string> result;

    VerticalLayout {
        for odata[oidx] in outer_m: VerticalLayout {
            for idata[iidx] in inner_m: HorizontalLayout {
                Base {
                    // Parent-level model field: reached with parent_level == 1
                    // from inside the inner `for`.
                    link_to_alias <=> odata.label;
                    // Inner-level model field: parent_level == 0 here, and
                    // chained down to Text.text through Base and Compo.
                    link_to_text <=> idata.bar;
                    tap => {
                        result += oidx + "," + iidx + ":" + odata.label + ":" + idata.bar + "\n";
                    }
                }
            }
        }
    }

    out property <bool> test: true;
}

/*
```rust
use slint::{Model, VecModel};
use std::rc::Rc;

let instance = TestCase::new().unwrap();
let outer = Rc::new(VecModel::from(vec![
    OuterItem { label: "O0".into(), n: 0 },
    OuterItem { label: "O1".into(), n: 1 },
]));
let inner = Rc::new(VecModel::from(vec![
    Inner { bar: "I0".into(), baz: 0 },
    Inner { bar: "I1".into(), baz: 1 },
]));
instance.set_outer_m(outer.clone().into());
instance.set_inner_m(inner.clone().into());
slint_testing::mock_elapsed_time(0);

// UI -> model via the blue TouchArea inside Compo of Base(0,0). Writes
// "Z" to Compo.other, aliased to Base.link_to_text, re-aliased to
// idata.bar = inner_m[0].bar.
slint_testing::send_mouse_click(&instance, 555., 75.);
assert_eq!(inner.row_data(0).unwrap().bar, "Z");
assert_eq!(instance.get_result(), "0,0:O0:Z\n");

// UI -> model via the red TouchArea inside Base(1,0). Writes "A" to
// Base.link_to_alias, re-aliased to odata.label = outer_m[1].label.
instance.set_result("".into());
slint_testing::send_mouse_click(&instance, 585., 375.);
assert_eq!(outer.row_data(1).unwrap().label, "A");
assert_eq!(instance.get_result(), "1,0:A:Z\n");

// Model -> UI: set_row_data on the outer model; Base(1,1) then reads the
// new odata.label through its parent-level alias chain.
instance.set_result("".into());
outer.set_row_data(1, OuterItem { label: "NEW".into(), n: 99 });
slint_testing::mock_elapsed_time(0);
slint_testing::send_mouse_click(&instance, 585., 525.);
assert_eq!(outer.row_data(1).unwrap().label, "A");
assert_eq!(instance.get_result(), "1,1:A:I1\n");

// Model -> UI on the inner model. Base(1,1) reads idata=inner_m[1] so
// the tap there must observe the new bar value.
instance.set_result("".into());
inner.set_row_data(1, Inner { bar: "XYZ".into(), baz: 7 });
slint_testing::mock_elapsed_time(0);
slint_testing::send_mouse_click(&instance, 555., 525.);
assert_eq!(inner.row_data(1).unwrap().bar, "Z");
assert_eq!(instance.get_result(), "1,1:A:Z\n");
```


```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
auto outer = std::make_shared<slint::VectorModel<OuterItem>>(std::vector<OuterItem>{
    OuterItem { .label = "O0", .n = 0 },
    OuterItem { .label = "O1", .n = 1 },
});
auto inner = std::make_shared<slint::VectorModel<Inner>>(std::vector<Inner>{
    Inner { .bar = "I0", .baz = 0 },
    Inner { .bar = "I1", .baz = 1 },
});
instance.set_outer_m(outer);
instance.set_inner_m(inner);
slint_testing::mock_elapsed_time(0);

// UI -> model via the blue TouchArea inside Compo of Base(0,0).
slint_testing::send_mouse_click(&instance, 555., 75.);
assert_eq(inner->row_data(0).value().bar, "Z");
assert_eq(instance.get_result(), "0,0:O0:Z\n");

// UI -> model via the red TouchArea inside Base(1,0).
instance.set_result("");
slint_testing::send_mouse_click(&instance, 585., 375.);
assert_eq(outer->row_data(1).value().label, "A");
assert_eq(instance.get_result(), "1,0:A:Z\n");

// Model -> UI on outer model; Base(1,1) reads odata=outer_m[1] through
// its parent-level alias chain.
instance.set_result("");
outer->set_row_data(1, OuterItem { .label = "NEW", .n = 99 });
slint_testing::mock_elapsed_time(0);
slint_testing::send_mouse_click(&instance, 585., 525.);
assert_eq(outer->row_data(1).value().label, "A");
assert_eq(instance.get_result(), "1,1:A:I1\n");

// Model -> UI on inner model.
instance.set_result("");
inner->set_row_data(1, Inner { .bar = "XYZ", .baz = 7 });
slint_testing::mock_elapsed_time(0);
slint_testing::send_mouse_click(&instance, 555., 525.);
assert_eq(inner->row_data(1).value().bar, "Z");
assert_eq(instance.get_result(), "1,1:A:Z\n");
```


