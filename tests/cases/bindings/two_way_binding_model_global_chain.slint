]);
instance.mmm = m;

slintlib.private_api.send_mouse_click(instance, 355., 50.);
assert.equal(m.rowData(0).inner.bar, "Z");
assert.equal(instance.result, "0:Z\n");

instance.result = "";
slintlib.private_api.send_mouse_click(instance, 385., 150.);
assert.equal(m.rowData(1).inner.bar, "A");
assert.equal(instance.result, "1:A\n");

instance.result = "";
m.setRowData(0, { foo: "F0", inner: { bar: "NEW", baz: 9 } });
slintlib.private_api.send_mouse_click(instance, 355., 50.);
assert.equal(m.rowData(0).inner.bar, "Z");
assert.equal(instance.result, "0:Z\n");
