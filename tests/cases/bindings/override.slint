component Compo inherits Text {
    in-out property <int> prop_a: 10;
    in-out property <int> prop_b;
    prop_b: 20;
    text: "hello";
}

export component TestCase inherits Rectangle {
    in-out property <string> text: "ignore_me";
    c := Compo {
        x:0;y:0;
        prop_a: 1;
        prop_b: 2;
        text: "world";
    }

    in-out property<int> prop_a: c.prop_a;
    in-out property<int> prop_b: c.prop_b;
    in-out property<string> prop_text: c.text;

    in-out property<bool> test: prop_a == 1 && prop_b == 2 && prop_text == "world";
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_prop_a(), 1);
assert_eq!(instance.get_prop_b(), 2);
assert_eq!(instance.get_prop_text(), slint::SharedString::from("world"));
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_prop_a(), 1);
assert_eq(instance.get_prop_b(), 2);
assert_eq(instance.get_prop_text(), slint::SharedString("world"));
```

```js
let instance = new slint.TestCase({});
assert.equal(instance.prop_a, 1);
assert.equal(instance.prop_b, 2);
assert.equal(instance.prop_text, "world");
```

*/
