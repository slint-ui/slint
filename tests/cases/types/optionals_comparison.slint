// Test optional comparison with none

TestCase := Rectangle {
    property <string?> optional_text: none;
    property <string?> text_with_value: "hello";

    // Test comparison with none
    property <bool> is_none: optional_text == none;
    property <bool> is_not_none: text_with_value != none;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_is_none(), true);
assert_eq!(instance.get_is_not_none(), true);
```
*/
