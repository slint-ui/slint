// Comprehensive test of optional types features

struct OptionalData {
    title: string?,
    count: int?,
    flag: bool?,
}

TestCase := Rectangle {
    // Phase 1: Basic declarations and none literal
    property <string?> opt_text: none;
    property <int?> opt_number: none;
    property <bool?> opt_flag: none;

    // Implicit wrapping T -> T?
    property <string?> text_wrapped: "hello";
    property <int?> number_wrapped: 42;

    // Phase 2: Null-coalescing operator
    property <string> text_with_fallback: opt_text ?? "default";
    property <string> text_with_value: text_wrapped ?? "unused";
    property <int> number_with_fallback: opt_number ?? 99;

    // Comparison with none
    property <bool> text_is_none: opt_text == none;
    property <bool> text_has_value: text_wrapped != none;

    // Optional in structs
    property <OptionalData> data: {
        title: "Test",
        count: 5,
    };

    // Chained value-or
    property <string> chained: opt_text.value-or(text_wrapped.value-or("final_fallback"));

    // Optional with enum types (testing AccessibleRole? migration)
    property <AccessibleRole?> role: none;
    property <AccessibleRole?> button_role: AccessibleRole.button;
}

