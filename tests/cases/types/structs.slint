assertion.NoError(err)
name, err = playerStruct.GetField("name")
assertion.NoError(err)
assertion.True(name.Equal(slint.StringValue("Player1")))
score, err = playerStruct.GetField("score")
assertion.NoError(err)
assertion.True(score.Equal(slint.NumberValue(12)))
energyLevel, err = playerStruct.GetField("energy_level")
assertion.NoError(err)
assertion.True(energyLevel.Equal(slint.NumberValue(0.8)))

playerStruct, err = playersArr[1].Struct()
assertion.NoError(err)
name, err = playerStruct.GetField("name")
assertion.NoError(err)
assertion.True(name.Equal(slint.StringValue("Player2")))
score, err = playerStruct.GetField("score")
assertion.NoError(err)
assertion.True(score.Equal(slint.NumberValue(24)))
energyLevel, err = playerStruct.GetField("energy_level")
assertion.NoError(err)
assertion.True(energyLevel.Equal(slint.NumberValue(0.4)))

playerList, err := instance.GetPlayerList()
assertion.NoError(err)
playerListArr, err := playerList.Array()
assertion.NoError(err)
assertion.Len(playerListArr, 3)
playerStruct, err = playerListArr[0].Struct()
assertion.NoError(err)
name, err = playerStruct.GetField("name")
assertion.NoError(err)
assertion.True(name.Equal(slint.StringValue("Simon")))
score, err = playerStruct.GetField("score")
assertion.NoError(err)
assertion.True(score.Equal(slint.NumberValue(1)))
energyLevel, err = playerStruct.GetField("energy_level")
assertion.NoError(err)
assertion.True(energyLevel.Equal(slint.NumberValue(0.5)))

playerStruct, err = playerListArr[1].Struct()
assertion.NoError(err)
name, err = playerStruct.GetField("name")
assertion.NoError(err)
assertion.True(name.Equal(slint.StringValue("Olivier")))
score, err = playerStruct.GetField("score")
assertion.NoError(err)
assertion.True(score.Equal(slint.NumberValue(10)))
energyLevel, err = playerStruct.GetField("energy_level")
assertion.NoError(err)
assertion.True(energyLevel.Equal(slint.NumberValue(1)))

playerStruct, err = playerListArr[2].Struct()
assertion.NoError(err)
name, err = playerStruct.GetField("name")
assertion.NoError(err)
assertion.True(name.Equal(slint.StringValue("NoScore")))
score, err = playerStruct.GetField("score")
assertion.NoError(err)
assertion.True(score.Equal(slint.NumberValue(0)))
energyLevel, err = playerStruct.GetField("energy_level")
assertion.NoError(err)
assertion.True(energyLevel.Equal(slint.NumberValue(1)))

test, err := instance.GetTest()
assertion.NoError(err)
assertion.True(test)

assertion.NoError(instance.SetPlayer2(slint.StructValue(map[string]slint.Value{
	"name": slint.StringValue("Super Player"),
	"score": slint.NumberValue(99),
	"energy_level": slint.NumberValue(0.4),
})))

player2, err = instance.GetPlayer2()
