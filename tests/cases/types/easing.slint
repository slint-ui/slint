struct AnimProp {
    easing: easing
}

global G {
    in-out property <easing> a: Easing.ease-out-quad;
    in-out property <AnimProp> p: { easing: Easing.ease-out-quad };
}


export component TestCase inherits Window {
    in-out property <easing> easing: ease-in-circ;
    in-out property <easing> bounce: Easing.ease-out-bounce;
    in-out property <easing> bounce-in-out: Easing.ease-in-out-bounce;
    in-out property <int> unused: 0;
    animate unused {
        duration: 1200ms;
        easing: G.p.easing;
    }

    // The bounce curves must map to different easing tags than the elastic curves; a code
    // generation mistake mapped them to the elastic tags.
    out property <bool> test-bounce: bounce != Easing.ease-out-elastic
        && bounce-in-out != Easing.ease-in-out-elastic;

    out property <bool> test: easing == Easing.ease-in-circ && easing != Easing.ease-out-elastic && G.p.easing == Easing.ease-out-quad && test-bounce;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_test());
```
*/

