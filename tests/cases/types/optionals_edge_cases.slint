// Test edge cases for optional types

struct NestedOptionals {
    outer: {
        inner: string?,
        count: int?,
    },
}

TestCase := Rectangle {
    // Optionals with different types
    property <duration?> opt_duration: none;
    property <length?> opt_length: none;
    property <color?> opt_color: none;
    property <brush?> opt_brush: none;
    property <image?> opt_image: none;

    // Optionals with values
    property <duration?> duration_val: 500ms;
    property <length?> length_val: 100px;
    property <color?> color_val: #FF0000;

    // Null-coalesce with different types
    property <duration> duration_or_default: opt_duration ?? 1s;
    property <length> length_or_default: opt_length ?? 50px;
    property <color> color_or_default: opt_color ?? #000000;

    // Chained null-coalesce
    property <string?> first: none;
    property <string?> second: none;
    property <string?> third: "fallback";
    property <string> chained_coalesce: first ?? second ?? third ?? "final";

    // Nested struct optionals
    property <NestedOptionals> nested: {
        outer: {
            inner: "nested_text",
            count: none,
        }
    };

    // Optional arrays
    property <[string]?> opt_array: none;
    property <[int]?> array_with_value: [1, 2, 3];
    property <int> array_length: opt_array == none ? 0 : 3;

    // Optional in conditional expressions
    property <string> conditional_opt: opt_text != none ? "has value" : "is none";

    // Comparison combinations
    property <bool> both_none: opt_text == none && opt_number == none;
    property <bool> any_has_value: text_wrapped != none || number_wrapped != none;
}

/*
```rust
let instance = TestCase::new().unwrap();

// Test type-specific optionals
assert_eq!(instance.get_opt_duration(), None);
assert_eq!(instance.get_duration_val(), Some(500));
assert_eq!(instance.get_duration_or_default(), 1000);

assert_eq!(instance.get_opt_length(), None);
assert_eq!(instance.get_length_val(), Some(100.0));

// Test chained coalesce
assert_eq!(instance.get_chained_coalesce(), "fallback".into());

// Test comparisons
assert_eq!(instance.get_text_is_none(), true);
assert_eq!(instance.get_text_has_value(), true);
assert_eq!(instance.get_both_none(), true);
assert_eq!(instance.get_any_has_value(), true);
```
*/
