export component TestCase inherits Window {
    in-out property <int> var1: 20;
    in-out property <int> var2: 50;
    in-out property <int> var3: 70;
    in-out property <int> cond: 2;

    out property <bool> test: cond == 2 && var1 == 20 && var2 == 50 && var3 == 70;

    match cond {
        2: TouchArea {
            Text {
                text: var1;
            }

            x: 0px;
            y: 100px;
            width: 100px;
            height: 100px;
            property <int> xx: var1;
            clicked => {
                var1 += self.xx;
            }
        }
        1: TouchArea {
            Text {
                text: var2;
            }

            x: 150px;
            y: 100px;
            width: 100px;
            height: 100px;
            property <int> xx: var2;
            clicked => {
                var2 += self.xx;
            }
        }
        3: TouchArea {
            Text {
                text: var3;
            }

            x: 300px;
            y: 100px;
            width: 100px;
            height: 100px;
            property <int> xx: var3;
            clicked => {
                var3 += self.xx;
            }
        }
        *: TouchArea {
            x: 0px;
            y: 250px;
            width: 100px;
            height: 100px;
            clicked => {
                var1 = 999;
            }
        }
    }
}

/*

```rust
let instance = TestCase::new().unwrap();

assert_eq!(instance.get_var1(), 20);
assert_eq!(instance.get_var2(), 50);
assert_eq!(instance.get_var3(), 70);
assert!(instance.get_test());

slint_testing::send_mouse_click(&instance, 50., 150.);
assert_eq!(instance.get_var1(), 40);
assert_eq!(instance.get_var2(), 50);
assert_eq!(instance.get_var3(), 70);

slint_testing::send_mouse_click(&instance, 50., 300.);
assert_eq!(instance.get_var1(), 40);
slint_testing::send_mouse_click(&instance, 200., 150.);
assert_eq!(instance.get_var2(), 50);
slint_testing::send_mouse_click(&instance, 350., 150.);
assert_eq!(instance.get_var3(), 70);

instance.set_cond(1);
slint_testing::send_mouse_click(&instance, 200., 150.);
assert_eq!(instance.get_var1(), 40);
assert_eq!(instance.get_var2(), 100);
assert_eq!(instance.get_var3(), 70);

slint_testing::send_mouse_click(&instance, 50., 150.);
assert_eq!(instance.get_var1(), 40);

instance.set_cond(3);
slint_testing::send_mouse_click(&instance, 350., 150.);
assert_eq!(instance.get_var1(), 40);
assert_eq!(instance.get_var2(), 100);
assert_eq!(instance.get_var3(), 140);

instance.set_cond(10);
slint_testing::send_mouse_click(&instance, 50., 300.);
assert_eq!(instance.get_var1(), 999);

instance.set_var1(20);
instance.set_cond(2);
slint_testing::send_mouse_click(&instance, 50., 300.);
assert_eq!(instance.get_var1(), 20);

slint_testing::send_mouse_click(&instance, 50., 150.);
assert_eq!(instance.get_var1(), 40);
slint_testing::send_mouse_click(&instance, 50., 150.);
assert_eq!(instance.get_var1(), 80);
```

