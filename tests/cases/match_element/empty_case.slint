export component TestCase inherits Window {
    in-out property <int> var1: 20;
    in-out property <int> var2: 50;
    in-out property <int> var3: 70;

    in-out property <int> cond: 0;

    match cond {
        0: TouchArea {
            Text {
                text: var1;
            }

            x: 0px;
            y: 100px;
            width: 100px;
            height: 100px;
            property <int> xx: var1;
            clicked => {
                var1 += self.xx;
            }
        }
        1: { }
        *: TouchArea {
            Text {
                text: var3;
            }

            x: 300px;
            y: 100px;
            width: 100px;
            height: 100px;
            property <int> xx: var3;
            clicked => {
                var3 += self.xx;
            }
        }
    }
    in-out property <bool> test: var1 == 20 && var2 == 50 && var3 == 70 && cond == 0;
}

