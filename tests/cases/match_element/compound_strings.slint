assert_eq(instance.get_var3(), 70);

slint_testing::send_mouse_click(&instance, 0., 100.);
slint_testing::send_mouse_click(&instance, 150., 100.);
slint_testing::send_mouse_click(&instance, 300., 100.);

assert_eq(instance.get_var1(), 40);
assert_eq(instance.get_var2(), 50);
assert_eq(instance.get_var3(), 70);

slint_testing::send_mouse_click(&instance, 450., 100.);
assert_eq(instance.get_var1(), 40);
assert_eq(instance.get_var2(), 50);
assert_eq(instance.get_var3(), 70);
assert_eq(instance.get_output(), "d");
```

