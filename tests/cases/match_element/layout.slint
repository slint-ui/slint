export component TestCase inherits Window {
    width: 200px;
    height: 100px;
    in-out property <int> mode: 0;
    in-out property <string> tab: "home";

    HorizontalLayout {
        alignment: start;
        Rectangle {
            background: red;
            width: 5px;
        }

        match mode {
            0: TouchArea {
                width: 5px;
                clicked => {
                    tab = "menu";
                }
            }
            1: TouchArea {
                width: 5px;
                clicked => {
                    tab = "profile";
                }
            }
            2: TouchArea {
                width: 5px;
                clicked => {
                    tab = "store";
                }
            }
            *: TouchArea {
                width: 5px;
                clicked => {
                    tab = "settings";
                }
            }
        }
        Rectangle {
            background: green;
            width: 5px;
            TouchArea {
                width: 5px;
                clicked => {
                    mode += 1;
                }
            }
        }
    }

    in-out property <bool> test: mode == 0 && tab == "home";
}

