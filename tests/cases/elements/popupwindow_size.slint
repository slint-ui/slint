// Check that the layout sizes are correct
// For the TextInput the textsize must be determining using the scale factor so it is handled differently
// than a normal rectangle

import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export global Properties {
    in-out property <bool> popup-initialized: false;
    in-out property <length> popup-width: -1px;
    in-out property <length> popup-height: -1px;

    in-out property <bool> button-in-popup-pressed: false;
    in-out property <bool> button-top-visible: false;

    in-out property <length> button-width: -1px;
    in-out property <length> button-height: -1px;
    in-out property <length> text-width: -1px;
    in-out property <length> text-height: -1px;
   
}
export component TestCase {
    in-out property <bool> show-buttons;

    callback show_popup();
    show_popup => {
        popup.show();
    }

    width: 600px;
    height: 400px;

    VerticalBox {
        Button {
            text: "Show popup";

            clicked => {
                debug("Show popup");
                popup.show();
            }
        }

        Button {
            text: "Show second popup";

            clicked => {
                debug("Show second popup");
            }
        }

        Button {
            text: "Show dialog";

            clicked => {
                debug("Show Dialog");
            }
        }
    }

    popup := PopupWindow {
        // x: parent.width - 100px;
        // y: parent.height;

        changed width => {
            Properties.popup-width = self.width;
        }

        changed height => {
            Properties.popup-height = self.height;
        }
      
        // close-on-click: false;
        close-policy: PopupClosePolicy.no-auto-close;
        // close-policy: PopupClosePolicy.close-on-click-outside;

        init => {
            Properties.popup-initialized = true;
            Properties.popup-width = self.width;
            Properties.popup-height = self.height;
            debug("Popup initialized");
            debug("Text input size: ", ti.width, ", ", ti.height);
        }
        

        VerticalBox {
            padding: 9px;
            spacing: 6px;
            ti:= TextInput {
                width: 100px;
                text: "Hello";

                init => {
                    Properties.text-height = self.preferred-height;
                    Properties.text-width = self.width;
                }
            }
            if root.show-buttons : HorizontalBox {
                Button {
                    text: "Button top"; 
                    init => {
                        Properties.button_top_visible = true;
                        debug("Button. Preferred width: ", self.preferred-width);
                        debug("Button. Preferred height: ", self.preferred-height);
                        debug("Button. width: ", self.width);
                        // debug("Button. height: ", self.height);
                        // debug("Button. Min width: ", self.min-width);
                        // debug("Button. Min height: ", self.min-height);
                        // debug("Button. Max width: ", self.max-width);
                        // debug("Button. Max height: ", self.max-height);
                    }
                }

                Button {
                    text: "Button top"; 
                }

                Button {
                    text: "Button bottom";
                }
            }

            Button {
                text: root.show-buttons ? "Hide Buttons" : "Show buttons";

                init => {
                    Properties.button-height = max(self.preferred-height, self.min-height);
                    Properties.button-width = self.width;
                }

                clicked => {
                    debug(self.text);
                    Properties.button-in-popup-pressed = true;
                    root.show-buttons = true;
                }
            }
        }
    }
}

/*

```rust
use slint::*;

let instance = TestCase::new().unwrap();
assert_eq!(instance.global::<Properties<'_>>().get_popup_height(), -1.);
assert_eq!(instance.global::<Properties<'_>>().get_popup_initialized(), false);
assert_eq!(instance.global::<Properties<'_>>().get_button_top_visible(), false);

instance.invoke_show_popup();

assert_eq!(instance.global::<Properties<'_>>().get_popup_initialized(), true);
assert_eq!(instance.global::<Properties<'_>>().get_button_top_visible(), false);

let padding = 9.;
let spacing = 6.;
let button_height = 32.;
let text_height = 17.;
assert_eq!(instance.global::<Properties<'_>>().get_text_height(), text_height);
assert_eq!(instance.global::<Properties<'_>>().get_button_height(), button_height);
assert_eq!(instance.global::<Properties<'_>>().get_popup_height(), padding + text_height + spacing + button_height + padding);

let width = instance.global::<Properties<'_>>().get_button_width();
assert_eq!(instance.global::<Properties<'_>>().get_popup_width(), padding + width + padding);

let window = instance.window();
let pressed_position = LogicalPosition::new(50., 40.);
window.dispatch_event(platform::WindowEvent::PointerPressed { position: pressed_position, button: platform::PointerEventButton::Left });
window.dispatch_event(platform::WindowEvent::PointerReleased { position: pressed_position, button: platform::PointerEventButton::Left });

assert_eq!(instance.global::<Properties<'_>>().get_popup_initialized(), true);
assert_eq!(instance.global::<Properties<'_>>().get_button_in_popup_pressed(), true);
assert_eq!(instance.global::<Properties<'_>>().get_button_top_visible(), true);

window.dispatch_event(platform::WindowEvent::PointerPressed { position: pressed_position, button: platform::PointerEventButton::Left }); // To trigger recalculation
