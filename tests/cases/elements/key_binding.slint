export component TestCase inherits Window {
    in-out property <int> matches: 0;
    in-out property <bool> condition: false;
    in-out property <[keys]> key_bindings: [
        @keys(Control + C),
        @keys(Control + D),
    ];
    out property has-focus <=> scope.has-focus;
    in-out property <bool> enable-ctrl-a: true;

    forward-focus: scope;

    out property <int> pressed-count: 0;
    out property <int> released-count: 0;

    Rectangle {
        background: scope.has-focus ? blue : red;

        scope := FocusScope {
            KeyBinding {
                enabled: root.enable-ctrl-a;
                keys: @keys(Control + A);
                activated => {
                    matches += 1;
                }
            }

            if condition: KeyBinding {
                keys: @keys(Control + B);
                activated => {
                    matches += 1;
                }
            }

            for keys in key_bindings: KeyBinding {
                keys: keys;
                activated => {
                    matches += 1;
                }
            }
            key-pressed(event) => {
                pressed-count += 1;
                EventResult.reject
            }
            key-released(event) => {
                released-count += 1;
                EventResult.reject
            }
        }
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_has_focus());

let assert_matches = |matches| {
    assert_eq!(instance.get_matches(), matches);
    // ensure that pressed/released events appear symmetric (one release for each pressed event),
    // even if KeyBindings consume part of the events
    assert_eq!(instance.get_pressed_count(), instance.get_released_count());
};
assert_matches(0);

use slint::private_unstable_api::re_exports::Key;
use slint_testing::send_key_combo;

send_key_combo(&instance, [Key::Control, Key::A]);
assert_matches(1);

instance.set_enable_ctrl_a(false);
send_key_combo(&instance, [Key::Control, Key::A]);
assert_matches(1);

assert!(!instance.get_condition());
send_key_combo(&instance, [Key::Control, Key::B]);
assert_matches(1);

instance.set_condition(true);
send_key_combo(&instance, [Key::Control, Key::B]);
assert_matches(2);

send_key_combo(&instance, [Key::Control, Key::C]);
send_key_combo(&instance, [Key::Control, Key::D]);
assert_matches(4);

instance.set_key_bindings([].into());

send_key_combo(&instance, [Key::Control, Key::C]);
send_key_combo(&instance, [Key::Control, Key::D]);
assert_matches(4);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_has_focus());

auto assert_matches = [&instance](int matches) {
    assert_eq(instance.get_matches(), matches);
    // ensure that pressed/released events appear symmetric (one release for each pressed event),
    // even if KeyBindings consume part of the events
    assert_eq(instance.get_pressed_count(), instance.get_released_count());
};
assert_matches(0);

using namespace slint::platform;
using slint::private_api::testing::send_key_combo;

slint::SharedString control(key_codes::Control);

send_key_combo(&instance, {control, "A"});
assert_matches(1);

assert(!instance.get_condition());
send_key_combo(&instance, {control, "B"});
assert_matches(1);

instance.set_condition(true);
send_key_combo(&instance, {control, "B"});
assert_matches(2);

send_key_combo(&instance, {control, "C"});
send_key_combo(&instance, {control, "D"});
assert_matches(4);

// TODO: Make Keys public API in C++
instance.set_key_bindings(std::make_shared<slint::VectorModel<slint::cbindgen_private::types::Keys>>());

send_key_combo(&instance, {control, "C"});
send_key_combo(&instance, {control, "D"});
assert_matches(4);
```
*/
