const TestCase &instance = *handle;

instance.invoke_show_popup();
assert_eq(instance.global<Properties>().get_popup_width(), 100.);

instance.global<Properties>().set_do_resize(true);
slint_testing::mock_elapsed_time(100);

// The fixed width is dissociated from the window geometry, so reading the width still returns 100.
assert_eq(instance.global<Properties>().get_popup_width(), 100.);
```

```js
var instance = new slint.TestCase({});
instance.show_popup();
assert.equal(instance.Properties.popup_width, 100);

instance.Properties.do_resize = true;
slintlib.private_api.mock_elapsed_time(100);

// The fixed width is dissociated from the window geometry, so reading the width still returns 100.
assert.equal(instance.Properties.popup_width, 100);
```
