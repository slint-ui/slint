export component TestCase inherits Window {
    VerticalLayout {
        st := StyledText {
            text: @markdown("Hello **World**: {} *{}*", "_abc_", @markdown("<u>xyz</u>"));
            default-color: red;
        }

        st_link := StyledText {
            text: @markdown("Click [this link](https://slint.dev)");
            link-clicked(url) => {
                clicked_link_url = url;
            }
        }
    }

    out property <bool> test: true;
    out property <string> clicked_link_url: "";
}

/*
```rust
use slint::{platform::WindowEvent, LogicalPosition};
use slint::private_unstable_api::re_exports::MouseCursor;

let instance = TestCase::new().unwrap();
assert!(instance.get_test());

// Not over a link: default cursor
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(5.0, 5.0) });
assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursor::Default);

// Over the link: pointer cursor
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(75.0, 325.0) });
assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursor::Pointer);

// Move away from the link: back to default
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(5.0, 5.0) });
assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursor::Default);

assert_eq!(instance.get_clicked_link_url(), "");

// Click on the link
slint_testing::send_mouse_click(&instance, 75.0, 325.0);
assert_eq!(instance.get_clicked_link_url(), "https://slint.dev");
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_test());

assert_eq(instance.get_clicked_link_url(), "");
slint_testing::send_mouse_click(&instance, 75., 325.);
assert_eq(instance.get_clicked_link_url(), "https://slint.dev");
```
*/
