// Test KeyPressRepeated and KeyReleased with and without focus
export component TestCase inherits Window {
    width: 400px;
    height: 400px;
    input := TextInput {
        width: parent.width;
        height: parent.height;
    }
}

/*
```rust
use slint::*;
use i_slint_core::context::WindowEventDispatchResult::*;
let instance = TestCase::new().unwrap();
let window = instance.window();

// No focus, key events ignored
let res = window.dispatch_event_with_result(platform::WindowEvent::KeyPressRepeated { text: 'a'.into() });
assert_eq!(res.unwrap(), Ignored);
let res = window.dispatch_event_with_result(platform::WindowEvent::KeyReleased { text: 'a'.into() });
assert_eq!(res.unwrap(), Ignored);

// Click to focus
let position = LogicalPosition::new(200., 200.);
let res = window.dispatch_event_with_result(platform::WindowEvent::PointerPressed { position, button: platform::PointerEventButton::Left });
let _ = window.dispatch_event_with_result(platform::WindowEvent::PointerReleased { position, button: platform::PointerEventButton::Left });
assert_eq!(res.unwrap(), Accepted);

// Now key events accepted
let res = window.dispatch_event_with_result(platform::WindowEvent::KeyPressRepeated { text: 'a'.into() });
assert_eq!(res.unwrap(), Accepted);
let res = window.dispatch_event_with_result(platform::WindowEvent::KeyReleased { text: 'a'.into() });
assert_eq!(res.unwrap(), Ignored);
```
*/