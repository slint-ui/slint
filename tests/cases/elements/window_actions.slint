// Compile/pass test: all window control actions used in activated callbacks.

export component TestCase inherits Window {
    MenuBar {
        Menu {
            title: "Window";
            MenuItem {
                title: "Minimize";
                shortcut: @keys(Control + M);
                activated => { root.minimized = true; }
            }
            MenuItem {
                title: "Zoom";
                activated => { root.maximized = !root.maximized; }
            }
            MenuItem {
                title: "Close";
                shortcut: @keys(Control + W);
                activated => { root.close(); }
            }
            MenuItem {
                title: "Enter Full Screen";
                shortcut: @keys(Control + Meta + F);
                activated => { root.full-screen = !root.full-screen; }
            }
        }
    }

    out property <bool> test: true;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_test(), true);
```

```js
var instance = new slint.TestCase();
assert.equal(instance.test, true);
```

