// C++ live preview: always exposes window(), forbidden for SystemTrayIcon roots
//ignore: cpp-live-preview

// cSpell: ignore SFINAE
// Exercises lowering + code generation for a SystemTrayIcon with a Menu child,
// including a separator and a nested sub-menu. At runtime the tray has no
// icon, so the platform layer stays inert; this is primarily a compile test
// for all generator backends.

export component TestCase inherits SystemTrayIcon {
    tooltip: "Test tray";

    in-out property <string> result;

    Menu {
        MenuItem {
            title: "First";
            activated => { result += "First"; }
        }
        MenuSeparator {}
        Menu {
            title: "Sub";
            MenuItem {
                title: "Nested";
                activated => { result += "Nested"; }
            }
        }
        MenuItem {
            title: "Last";
            activated => { result += "Last"; }
        }
    }

    // `show()`/`hide()` set the item's `visible` behind the compiler's back;
    // this binding checks that readers of `visible` stay reactive to that.
    out property <bool> shown: self.visible;

    out property <bool> test: true;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
assert!(instance.get_shown());
instance.hide().unwrap();
assert!(!instance.get_shown());
instance.show().unwrap();
assert!(instance.get_shown());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_test());
assert(instance.get_shown());
handle->hide();
assert(!instance.get_shown());
handle->show();
assert(instance.get_shown());

// Compile-time check: a SystemTrayIcon-rooted component must not expose a
// `window()` member. If a future change adds one, this fires. Wrapping
// in a template lets the requires-expression SFINAE cleanly instead of
// erroring on the missing member.
auto _has_window = []<typename T>(T*) {
    return requires(T t) { t.window(); };
};
static_assert(!_has_window(static_cast<TestCase *>(nullptr)),
              "SystemTrayIcon-rooted components must not expose window()");
```
*/
