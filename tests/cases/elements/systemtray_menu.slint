// Exercises lowering + code generation for a SystemTray with a Menu child,
// including a separator and a nested sub-menu. At runtime the tray has no
// icon, so the platform layer stays inert; this is primarily a compile test
// for all generator backends.

export component TestCase inherits SystemTray {
    title: "Test tray";

    in-out property <string> result;

    Menu {
        MenuItem {
            title: "First";
            activated => { result += "First"; }
        }
        MenuSeparator {}
        Menu {
            title: "Sub";
            MenuItem {
                title: "Nested";
                activated => { result += "Nested"; }
            }
        }
        MenuItem {
            title: "Last";
            activated => { result += "Last"; }
        }
    }

    out property <bool> test: true;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_test());
```
*/
