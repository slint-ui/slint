// Verify that `PopupWindow::is-open` reflects the visibility of the popup, becoming `true` when it is
// shown and `false` again on every close path (auto-close on click, and programmatic `close()`).
//
// The popups live inside reusable components that read their *own* `popup.is-open` internally (like a
// ComboBox styling its arrow). `AutoDropdown` is instantiated twice, exercising the sub-component /
// `parent_level` code path that a single root-level popup would not.

component AutoDropdown inherits Rectangle {
    width: 40px;
    height: 20px;
    out property <bool> open: popup.is-open;

    TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: 20px;
        width: 40px;
        height: 40px;
        Rectangle { background: blue; }
    }
}

component ManualDropdown inherits Rectangle {
    width: 40px;
    height: 20px;
    out property <bool> open: popup.is-open;

    TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        close-policy: no-auto-close;
        x: 0;
        y: 20px;
        width: 40px;
        height: 40px;
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                popup.close();
            }
        }
    }
}

export component TestCase {
    width: 300px;
    height: 300px;

    out property <bool> a-open: a.open;
    out property <bool> a2-open: a2.open;
    out property <bool> b-open: b.open;

    a := AutoDropdown {
        x: 0;
        y: 0;
    }

    a2 := AutoDropdown {
        x: 50px;
        y: 0;
    }

    b := ManualDropdown {
        x: 150px;
        y: 0;
    }
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_a_open(), false);
assert_eq!(instance.get_a2_open(), false);
assert_eq!(instance.get_b_open(), false);

// --------- `a`: close-on-click — opens on click, closes again on the next click
slint_testing::send_mouse_click(&instance, 5., 5.);
assert_eq!(instance.get_a_open(), true);
assert_eq!(instance.get_a2_open(), false);

// Any click dismisses a close-on-click popup, which must reset is-open to false.
slint_testing::send_mouse_click(&instance, 5., 5.);
assert_eq!(instance.get_a_open(), false);

// --------- `a2`: a second instance of the same component opens/closes independently
slint_testing::send_mouse_click(&instance, 55., 5.);
assert_eq!(instance.get_a2_open(), true);
assert_eq!(instance.get_a_open(), false);
slint_testing::send_mouse_click(&instance, 55., 5.);
assert_eq!(instance.get_a2_open(), false);

// --------- `b`: no-auto-close, closed via close()
slint_testing::send_mouse_click(&instance, 155., 5.);
assert_eq!(instance.get_b_open(), true);

// Clicking inside `b`'s popup calls close(), which must reset is-open to false.
slint_testing::send_mouse_click(&instance, 155., 35.);
assert_eq!(instance.get_b_open(), false);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_a_open(), false);
assert_eq(instance.get_a2_open(), false);
assert_eq(instance.get_b_open(), false);

// --------- `a`: close-on-click — opens on click, closes again on the next click
slint_testing::send_mouse_click(&instance, 5., 5.);
assert_eq(instance.get_a_open(), true);
assert_eq(instance.get_a2_open(), false);

// Any click dismisses a close-on-click popup, which must reset is-open to false.
slint_testing::send_mouse_click(&instance, 5., 5.);
assert_eq(instance.get_a_open(), false);

// --------- `a2`: a second instance of the same component opens/closes independently
slint_testing::send_mouse_click(&instance, 55., 5.);
assert_eq(instance.get_a2_open(), true);
assert_eq(instance.get_a_open(), false);
slint_testing::send_mouse_click(&instance, 55., 5.);
assert_eq(instance.get_a2_open(), false);

// --------- `b`: no-auto-close, closed via close()
slint_testing::send_mouse_click(&instance, 155., 5.);
assert_eq(instance.get_b_open(), true);

// Clicking inside `b`'s popup calls close(), which must reset is-open to false.
slint_testing::send_mouse_click(&instance, 155., 35.);
assert_eq(instance.get_b_open(), false);
```
*/
