auto handle = TestCase::create();
const TestCase &instance = *handle;
slint::SharedString ctrl(slint::platform::key_codes::Control);
auto assert_shortcut = [&](const char *key, const char *expected) {
    slint_testing::send_key_combo(&instance, { ctrl, key });
    assert_eq(instance.get_result(), expected);
    instance.set_result("");
};

assert_shortcut("N", "New");

// "Open" is hidden — shortcut must not fire, then show and retry
assert_shortcut("O", "");
instance.set_show_open(true);
assert_shortcut("O", "Open");

// "Save" is disabled — shortcut must not fire, then enable and retry
assert_shortcut("S", "");
instance.set_save_enabled(true);
assert_shortcut("S", "Save");

// for-loop items fire, then clear the model and verify they no longer fire
assert_shortcut("A", "shortcut-0");
assert_shortcut("B", "shortcut-1");
instance.set_dynamic_shortcuts(nullptr);
assert_shortcut("A", "");
assert_shortcut("B", "");
