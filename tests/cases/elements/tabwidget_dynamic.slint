import { TabWidget } from "std-widgets.slint";

TestCase := Window {
    preferred_height: 500px;
    preferred_width: 500px;

    property <[{name: string}]> tab_model: [
        { name: "First" },
        { name: "Second" },
        { name: "Third" },
    ];

    property <int> current_tab: tw.current-index;

    VerticalLayout {
        padding: 20px;
        tw := TabWidget {
            current-index: 0;
            for item[idx] in tab_model: Tab {
                title: item.name;
                Rectangle {
                    background: idx == 0 ? red : idx == 1 ? green : blue;
                }
            }
        }
    }

    out property <bool> test: tw.current-index == 0;
}
