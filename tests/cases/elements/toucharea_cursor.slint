// cSpell: ignore mousecursor
export component TestCase  {
    TouchArea {
        property <MouseCursor> current-cursor: MouseCursor.default;

        x: 100phx;
        y: 100phx;
        width: 10phx;
        height: 10phx;
        clicked => { self.current-cursor = MouseCursor.move; }
        mouse-cursor: current-cursor;
    }

    TouchArea {
        x: 200phx;
        y: 200phx;
        width: 10phx;
        height: 10phx;

        mouse-cursor: MouseCursor.custom(@image-url("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAIAAACQd1PeAAAADElEQVR4nGP4z8AAAAMBAQDJ/pLvAAAAAElFTkSuQmCC"), -1, -1);
    }
}

/*
```rust
use slint::{platform::WindowEvent, LogicalPosition};
use slint::private_unstable_api::re_exports::{BuiltInMouseCursor, MouseCursorInner};

let instance = TestCase::new().unwrap();


assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursorInner::BuiltIn(BuiltInMouseCursor::Default),
     "Unexpected mousecursor at start");

slint_testing::send_mouse_click(&instance, 5., 5.);
slint_testing::mock_elapsed_time(1000);
assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursorInner::BuiltIn(BuiltInMouseCursor::Default),
    "Click 1 did not change mouse pointer");

slint_testing::send_mouse_click(&instance, 105., 105.);
slint_testing::mock_elapsed_time(1000);
assert_eq!(slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor()), MouseCursorInner::BuiltIn(BuiltInMouseCursor::Move),
    "Click 2 did not change mouse pointer");

// Hovering the second TouchArea delivers the custom cursor to the backend.
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(205., 205.) });
slint_testing::mock_elapsed_time(1000);
let cursor = slint_testing::access_testing_window(instance.window(), |window| window.mouse_cursor());
assert!(matches!(cursor, MouseCursorInner::CustomMouseCursor { hotspot_x: -1, hotspot_y: -1, .. }),
    "Custom cursor was not delivered to the backend: {cursor:?}");
```

*/
