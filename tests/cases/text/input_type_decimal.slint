export component TestCase inherits Window {
    width: 100phx;
    height: 100phx;
    ti := TextInput {
        input-type: decimal;
    }
    ti-loc := TextInput {
        y: 50phx;
        input-type: decimal-localized;
    }

    out property <bool> input_focused: ti.has_focus;
    in-out property <string> text <=> ti.text;
    out property <bool> input_focused_loc: ti-loc.has_focus;
    in-out property <string> text_loc <=> ti-loc.text;
}

/*
```rust
use slint::platform::Key;
use slint::SharedString;

let instance = TestCase::new().unwrap();
slint_testing::send_mouse_click(&instance, 5., 5.);
assert!(instance.get_input_focused());
assert!(instance.get_text().is_empty());

let send_and_check = |seq: &str, expected: &str| {
    slint_testing::send_keyboard_string_sequence(&instance, seq);
    assert_eq!(instance.get_text(), expected);
};

// accept characters as valid decimal only
send_and_check("a", "");
slint_testing::send_keyboard_char(&instance, Key::Shift.into(), true);
slint_testing::send_keyboard_char(&instance, Key::Shift.into(), false);
assert!(instance.get_text().is_empty());
for (seq, expected) in [("-", "-"), ("1", "-1"), (".", "-1."), ("0", "-1.0")] {
    send_and_check(seq, expected);
}

instance.set_text("".into());
for (seq, expected) in [("a", ""), ("4", "4"), ("b", "4"), ("5", "45")] {
    send_and_check(seq, expected);
}
slint_testing::send_keyboard_string_sequence(&instance, &SharedString::from(Key::LeftArrow));
assert_eq!(instance.get_text(), "45");
for (seq, expected) in [("c", "45"), ("6", "465"), ("-", "465")] {
    send_and_check(seq, expected);
}
slint_testing::send_keyboard_string_sequence(&instance, &SharedString::from(Key::LeftArrow));
slint_testing::send_keyboard_string_sequence(&instance, &SharedString::from(Key::LeftArrow));
send_and_check("-", "-465");

slint_testing::send_keyboard_char(&instance, Key::Shift.into(), true);
slint_testing::send_keyboard_string_sequence(&instance, &SharedString::from(Key::RightArrow));
slint_testing::send_keyboard_char(&instance, Key::Shift.into(), false);
for (seq, expected) in [("d", "-465"), ("7", "-765")] {
    send_and_check(seq, expected);
}

```

```rust
// Test that plain decimal rejects commas even with a comma-separator locale
let instance = TestCase::new().unwrap();
slint_testing::set_locale(&instance, "de-DE");
slint_testing::send_mouse_click(&instance, 5., 5.);
assert!(instance.get_input_focused());

let send_and_check = |seq: &str, expected: &str| {
    slint_testing::send_keyboard_string_sequence(&instance, seq);
    assert_eq!(instance.get_text(), expected);
};

// comma should be rejected — plain decimal always uses dot
send_and_check(",", "");

// dot should still be accepted
instance.set_text("".into());
for (seq, expected) in [("1", "1"), (".", "1."), ("5", "1.5")] {
    send_and_check(seq, expected);
}
```

```rust
// Test decimal-localized with German locale
let instance = TestCase::new().unwrap();
slint_testing::set_locale(&instance, "de-DE");
slint_testing::send_mouse_click(&instance, 5., 55.);
assert!(instance.get_input_focused_loc());

let send_and_check = |seq: &str, expected: &str| {
    slint_testing::send_keyboard_string_sequence(&instance, seq);
    assert_eq!(instance.get_text_loc(), expected);
};

// comma should be accepted as decimal separator
send_and_check(",", ",");

// dot should be rejected in a comma locale
instance.set_text_loc("".into());
send_and_check(".", "");

// build a full decimal number with comma separator
instance.set_text_loc("".into());
for (seq, expected) in [("-", "-"), ("1", "-1"), (",", "-1,"), ("5", "-1,5")] {
    send_and_check(seq, expected);
}

// only one comma allowed
send_and_check(",", "-1,5");
```
*/
