// This fixture is derived from Roboto-Regular.ttf and carries an explicit line gap,
// so the first-line trim changes the preferred height by a measurable pixel.
import "fixtures/Roboto-Test-LineGap.ttf";

export component TestCase inherits Window {
    width: 200px;
    height: 80px;
    default-font-family: "Roboto Test LineGap";
    default-font-size: 20px;

    t := Text {
        text: "STOP";
    }

    out property <length> preferred-text-height: t.preferred-height;
    out property <length> metrics-text-height: t.font-metrics.ascent - t.font-metrics.descent;
    out property <bool> test: preferred-text-height == 22px && metrics-text-height == 20px;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_test());
```
*/
