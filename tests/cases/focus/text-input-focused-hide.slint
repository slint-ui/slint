import { LineEdit } from "std-widgets.slint";

// If the lineedit gets hidden, the text-input-focused must be false
// to hide also virtual keyboards and so on

export component TestCase inherits Window {

    property <bool> le_visible;

    callback focus_the_line_edit;
    focus_the_line_edit => {
        timer.running = true;
        le.focus();
    }
    callback set_line_edit_visible_and_focused;
    set_line_edit_visible_and_focused => {
        le.visible = true;
        le.focus();
    }

    timer:= Timer {
        running: false;
        interval: 10s;
        triggered => {
            debug("Hide LineEdit");
            le.visible = false;
            self.running = false;
        }
    }

    le := LineEdit {}

    out property<bool> focused: TextInputInterface.text-input-focused;

    changed focused => {
        debug("Focused changed");
        // timer.running = true; // When running in the livepreview this can be used
    }
}

/*
```rust
use slint::{platform::WindowEvent, LogicalPosition};

let instance = TestCase::new().unwrap();
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
assert!(!instance.get_focused());

instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
instance.invoke_focus_the_line_edit();
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
assert!(instance.get_focused());

instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
slint_testing::mock_elapsed_time(100000); // in ms
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
assert!(!instance.get_focused());

instance.invoke_set_line_edit_visible_and_focused();
instance.window().dispatch_event(WindowEvent::PointerMoved { position: LogicalPosition::new(0., 0.) }); // Required to trigger traversing through the item tree
assert!(instance.get_focused());
```
*/
