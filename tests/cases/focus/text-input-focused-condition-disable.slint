import { LineEdit } from "std-widgets.slint";

// If the lineedit gets hidden indirectly because a condition gets disabled, the text-input-focused must be false
// to hide also virtual keyboards and so on

export component TestCase inherits Window {

    property <bool> set_visible: true;

    callback hide_rectangle();
    hide_rectangle => {
        set_visible = false;
    }

    if set_visible: Rectangle {
        Timer {
            running: true;
            interval: 200ms;
            triggered => {
                le.focus();
                self.running = false;
            }
        }

        le := LineEdit {}
    }

    out property<bool> focused: TextInputInterface.text-input-focused;

}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(!instance.get_focused());

slint_testing::mock_elapsed_time(300); // in ms
assert!(instance.get_focused());

instance.invoke_hide_rectangle();
assert!(!instance.get_focused());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(!instance.get_focused());

slint_testing::mock_elapsed_time(300); // in ms
assert(instance.get_focused());

instance.invoke_hide_rectangle();
assert(!instance.get_focused());

```

```js
var instance = new slint.TestCase();
assert(!instance.focused);

slintlib.private_api.mock_elapsed_time(3000);
assert(instance.focused);

instance.hide_rectangle();
assert(!instance.focused);
```
*/
