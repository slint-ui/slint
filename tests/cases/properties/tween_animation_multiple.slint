export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> value-a: 0px;
    in-out property <length> value-b: 0px;
    in-out property <length> value-c: 0px;

    anim-a := TweenAnimation {
        target: value-a;
        from: 0px;
        to: 100px;
        duration: 1000ms;
        easing: linear;
    }

    anim-b := TweenAnimation {
        target: value-b;
        from: 0px;
        to: 50px;
        duration: 500ms;
        easing: linear;
    }

    anim-c := TweenAnimation {
        target: value-c;
        from: 100px;
        to: 0px;
        duration: 2000ms;
        easing: linear;
    }

    public function start_all() {
        anim-a.start();
        anim-b.start();
        anim-c.start();
    }
}

/*

```rust
let instance = TestCase::new().unwrap();

// Start all animations
instance.invoke_start_all();
slint_testing::mock_elapsed_time(1);
assert_eq!(instance.get_value_a(), 0.);
assert_eq!(instance.get_value_b(), 0.);
assert_eq!(instance.get_value_c(), 100.);

// At 250ms
slint_testing::mock_elapsed_time(250);
let a_250 = instance.get_value_a();
let b_250 = instance.get_value_b();
let c_250 = instance.get_value_c();

assert_eq!(a_250, 25.);  // 250ms of 1000ms = 25%
assert_eq!(b_250, 25.);  // 250ms of 500ms = 50%
assert_eq!(c_250, 87.5); // 250ms of 2000ms = 12.5% from 100 to 0

// At 500ms - anim-b completes
slint_testing::mock_elapsed_time(250);
let a_500 = instance.get_value_a();
let b_500 = instance.get_value_b();
let c_500 = instance.get_value_c();

assert_eq!(a_500, 50.);  // 500ms of 1000ms = 50%
assert_eq!(b_500, 50.);  // completed
assert_eq!(c_500, 75.);  // 500ms of 2000ms = 25% from 100 to 0

// At 1000ms - anim-a completes
slint_testing::mock_elapsed_time(500);
let a_1000 = instance.get_value_a();
let c_1000 = instance.get_value_c();

assert_eq!(a_1000, 100.);  // completed
assert_eq!(c_1000, 50.);   // 1000ms of 2000ms = 50% from 100 to 0

// At 2000ms - anim-c completes
slint_testing::mock_elapsed_time(1000);
assert_eq!(instance.get_value_c(), 0.);
```

