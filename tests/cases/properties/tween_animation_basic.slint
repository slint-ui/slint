export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> value: 0px;

    anim := TweenAnimation {
        target: value;
        from: 0px;
        to: 100px;
        duration: 1000ms;
        easing: linear;
    }

    TouchArea {
        clicked => {
            anim.start();
        }
    }

    public function start_anim() {
        anim.start();
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_value(), 0.);

// Start animation
instance.invoke_start_anim();
slint_testing::mock_elapsed_time(1);

// Halfway through animation with linear easing
slint_testing::mock_elapsed_time(500);
assert_eq!(instance.get_value(), 50.);

// Finished animation
slint_testing::mock_elapsed_time(500);
assert_eq!(instance.get_value(), 100.);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_value(), 0.);

// Start animation
instance.invoke_start_anim();
slint_testing::mock_elapsed_time(1);

// Halfway through animation with linear easing
slint_testing::mock_elapsed_time(500);
assert_eq(instance.get_value(), 50.);

// Finished animation
slint_testing::mock_elapsed_time(500);
assert_eq(instance.get_value(), 100.);
```

*/
