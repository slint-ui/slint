export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> start-value: 0px;
    in-out property <length> end-value: 100px;
    in-out property <int> duration-ms: 1000;

    in-out property <length> current-value: 0px;

    anim := SpringAnimation {
        target: current-value;
        from: start-value;
        to: end-value;
        duration: duration-ms * 1ms;
        bounce: 0;
    }

    public function start_anim() {
        anim.start();
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
fn assert_almost_eq(value: f32, expected: f32) {
    assert!((value - expected).abs() < 0.5, "Expected {value} to be close to {expected} (+-0.5)");
}
assert_eq!(instance.get_current_value(), 0.);

// Change start and end values
instance.set_start_value(10.);
instance.set_end_value(110.);
instance.set_duration_ms(1000);

// Start animation
instance.invoke_start_anim();

// Halfway through the animation - critically damped, closed-form value at t=500ms.
slint_testing::mock_elapsed_time(500);
assert_almost_eq(instance.get_current_value(), 92.1);

// Settled animation
slint_testing::mock_elapsed_time(3000);
assert_eq!(instance.get_current_value(), 110.);
```

