assert_eq(instance.get_float_value(), 1.0);
assert_eq(instance.get_int_value(), 10);

// Color should have changed (from white to black)
auto color = instance.get_color_value();
assert(color.red() < 128 && color.green() < 128 && color.blue() < 128);
