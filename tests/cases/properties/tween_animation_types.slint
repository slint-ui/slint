assert_eq(instance.get_float_value(), 0.0);

// At 250ms (halfway)
slint_testing::mock_elapsed_time(250);
assert_eq(instance.get_length_value(), 50.);
auto float_halfway = instance.get_float_value();
assert(float_halfway > 0.49 && float_halfway < 0.51);

// At 500ms (complete)
