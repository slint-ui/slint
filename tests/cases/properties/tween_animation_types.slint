export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> length-value: 0px;
    in-out property <float> float-value: 0.0;
    in-out property <color> color-value: #ffffff;
    in-out property <int> int-value: 0;

    length-anim := TweenAnimation {
        target: length-value;
        from: 0px;
        to: 100px;
        duration: 500ms;
        easing: linear;
    }

    float-anim := TweenAnimation {
        target: float-value;
        from: 0.0;
        to: 1.0;
        duration: 500ms;
        easing: linear;
    }

    color-anim := TweenAnimation {
        target: color-value;
        from: #ffffff;
        to: #000000;
        duration: 500ms;
        easing: linear;
    }

    int-anim := TweenAnimation {
        target: int-value;
        from: 0;
        to: 10;
        duration: 500ms;
        easing: linear;
    }

    public function start_all() {
        length-anim.start();
        float-anim.start();
        color-anim.start();
        int-anim.start();
    }
}

/*

```rust
let instance = TestCase::new().unwrap();

// Start all animations
instance.invoke_start_all();
assert_eq!(instance.get_length_value(), 0.);
assert_eq!(instance.get_float_value(), 0.0);
assert_eq!(instance.get_int_value(), 0);

// At 250ms (halfway)
slint_testing::mock_elapsed_time(250);
assert_eq!(instance.get_length_value(), 50.);
let float_halfway = instance.get_float_value();
assert!(float_halfway > 0.49 && float_halfway < 0.51, "Float halfway should be ~0.5, got {}", float_halfway);
assert_eq!(instance.get_int_value(), 5);

// At 500ms (complete)
slint_testing::mock_elapsed_time(250);
assert_eq!(instance.get_length_value(), 100.);
assert_eq!(instance.get_float_value(), 1.0);
assert_eq!(instance.get_int_value(), 10);

// Color should have changed (from white to black)
let color = instance.get_color_value();
assert!(color.red() < 128 && color.green() < 128 && color.blue() < 128, "Color should be darker than white");
```

