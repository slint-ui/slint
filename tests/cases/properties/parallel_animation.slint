export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> short-value: 0px;
    in-out property <length> long-value: 0px;
    out property <bool> anim-running: anim.running;

    anim := ParallelAnimation {
        TweenAnimation {
            target: short-value;
            from: 0px;
            to: 100px;
            duration: 100ms;
            easing: linear;
        }
        TweenAnimation {
            target: long-value;
            from: 0px;
            to: 100px;
            duration: 200ms;
            easing: linear;
        }
    }

    public function start_anim() {
        anim.start()
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_short_value(), 0.);
assert_eq!(instance.get_long_value(), 0.);

instance.invoke_start_anim();
assert!(instance.get_anim_running());

// Halfway through the shorter tween.
slint_testing::mock_elapsed_time(50);
assert_eq!(instance.get_short_value(), 50.);
assert_eq!(instance.get_long_value(), 25.);
assert!(instance.get_anim_running());

// The shorter tween finishes; the group keeps running for the longer one.
slint_testing::mock_elapsed_time(50);
assert_eq!(instance.get_short_value(), 100.);
assert_eq!(instance.get_long_value(), 50.);
assert!(instance.get_anim_running());

// Both finish: the group is done.
slint_testing::mock_elapsed_time(100);
assert_eq!(instance.get_short_value(), 100.);
assert_eq!(instance.get_long_value(), 100.);
assert!(!instance.get_anim_running());
```

