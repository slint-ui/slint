export component TestCase inherits Rectangle {
    width: 200px;
    height: 200px;
    background: white;

    in-out property <length> value: 0px;
    out property <bool> anim-running: anim.running;

    anim := TweenAnimation {
        target: value;
        from: 0px;
        to: 100px;
        duration: 1000ms;
        easing: linear;
    }

    public function start_anim() {
        anim.start()
    }

    public function stop_anim() {
        anim.stop()
    }

    public function restart_anim() {
        anim.restart()
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_value(), 0.);

// Start animation
instance.invoke_start_anim();
assert!(instance.get_anim_running());
assert_eq!(instance.get_value(), 0.);

// Progress partway
slint_testing::mock_elapsed_time(250);
assert_eq!(instance.get_value(), 25.);
// While animating, `running` reads back as true.
assert!(instance.get_anim_running());

// Stop animation
instance.invoke_stop_anim();
assert_eq!(instance.get_value(), 25.);
assert!(!instance.get_anim_running());

// Restart animation from beginning
instance.invoke_restart_anim();
assert_eq!(instance.get_value(), 0.);
assert!(instance.get_anim_running());

// Let it complete
slint_testing::mock_elapsed_time(1000);
assert_eq!(instance.get_value(), 100.);
// When the animation finishes on its own, `running` must return to false.
assert!(!instance.get_anim_running());
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert_eq(instance.get_value(), 0.);

// Start animation
instance.invoke_start_anim();
assert(instance.get_anim_running());
assert_eq(instance.get_value(), 0.);

// Progress partway
slint_testing::mock_elapsed_time(250);
assert_eq(instance.get_value(), 25.);
// While animating, `running` reads back as true.
assert(instance.get_anim_running());

// Stop animation
instance.invoke_stop_anim();
assert_eq(instance.get_value(), 25.);
assert(!instance.get_anim_running());

// Restart animation from beginning
instance.invoke_restart_anim();
assert_eq(instance.get_value(), 0.);
assert(instance.get_anim_running());

// Let it complete
slint_testing::mock_elapsed_time(1000);
assert_eq(instance.get_value(), 100.);
// When the animation finishes on its own, `running` must return to false.
assert(!instance.get_anim_running());
```

