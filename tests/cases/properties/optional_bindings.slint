// Test optional properties with bindings

TestCase := Rectangle {
    in-out property <string?> source: "initial";
    in-out property <string?> dependent: source;

    // Test null-coalesce in binding
    property <string> with_fallback: source ?? "fallback";

    // Test comparison in binding
    property <bool> has_source: source != none;
}

/*
```rust
use slint::*;
let instance = TestCase::new().unwrap();

// Test initial values
assert_eq!(instance.get_source(), Some("initial".into()));
assert_eq!(instance.get_dependent(), Some("initial".into()));
assert_eq!(instance.get_with_fallback(), "initial".into());
assert_eq!(instance.get_has_source(), true);

// Test binding updates
instance.set_source(None);
assert_eq!(instance.get_dependent(), None);
assert_eq!(instance.get_with_fallback(), "fallback".into());
assert_eq!(instance.get_has_source(), false);

instance.set_source(Some("updated".into()));
assert_eq!(instance.get_dependent(), Some("updated".into()));
assert_eq!(instance.get_with_fallback(), "updated".into());
```
*/
