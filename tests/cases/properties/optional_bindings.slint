// Test optional properties with bindings

TestCase := Rectangle {
    in-out property <string?> source: "initial";
    in-out property <string?> dependent: source;

    // Test null-coalesce in binding
    property <string> with_fallback: source ?? "fallback";

    // Test comparison in binding
    property <bool> has_source: source != none;
}

/*
```rust
let instance = TestCase::new().unwrap();

// Test initial values
assert_eq!(instance.get_source(), Some(slint::SharedString::from("initial")));
assert_eq!(instance.get_dependent(), Some(slint::SharedString::from("initial")));
assert_eq!(instance.get_with_fallback(), slint::SharedString::from("initial"));
assert_eq!(instance.get_has_source(), true);

// Test binding updates
instance.set_source(None);
assert_eq!(instance.get_dependent(), None);
assert_eq!(instance.get_with_fallback(), slint::SharedString::from("fallback"));
assert_eq!(instance.get_has_source(), false);

instance.set_source(Some(slint::SharedString::from("updated")));
assert_eq!(instance.get_dependent(), Some(slint::SharedString::from("updated")));
assert_eq!(instance.get_with_fallback(), slint::SharedString::from("updated"));
```
*/
