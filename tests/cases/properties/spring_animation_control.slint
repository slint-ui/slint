auto handle = TestCase::create();
const TestCase &instance = *handle;
auto assert_almost_eq = [](float value, float expected) {
    assert(std::abs(value - expected) < 0.5);
};

assert_eq(instance.get_value(), 0.);

// Start animation
instance.invoke_start_anim();
assert(instance.get_anim_running());
assert_eq(instance.get_value(), 0.);

// Progress partway - critically damped spring (bounce: 0), so it approaches monotonically.
slint_testing::mock_elapsed_time(200);
assert_almost_eq(instance.get_value(), 35.77);
assert(instance.get_anim_running());

// Stop animation
instance.invoke_stop_anim();
auto stopped_value = instance.get_value();
slint_testing::mock_elapsed_time(200);
assert_eq(instance.get_value(), stopped_value);
assert(!instance.get_anim_running());

// Restart animation from the `from` value
instance.invoke_restart_anim();
assert_eq(instance.get_value(), 0.);
assert(instance.get_anim_running());

// Let it settle
slint_testing::mock_elapsed_time(3000);
assert_eq(instance.get_value(), 100.);
assert(!instance.get_anim_running());
```

