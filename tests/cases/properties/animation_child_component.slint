// An `animate` declaration at the use site of a child component's property
// must interpolate assignments. The binding on `val` keeps the child from
// being inlined, so the animation is registered in the enclosing component.

component Inner {
    in-out property <int> val;
}

export component TestCase {
    inner := Inner {
        val: 0;
        animate val { duration: 1000ms; }
    }

    public function go() {
        inner.val = 100;
    }

    out property <int> result: inner.val;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_result(), 0);
instance.invoke_go();
assert_eq!(instance.get_result(), 0);
slint_testing::mock_elapsed_time(500);
assert_eq!(instance.get_result(), 50);
slint_testing::mock_elapsed_time(500);
assert_eq!(instance.get_result(), 100);
```

