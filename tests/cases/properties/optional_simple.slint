export component TestCase {
    in-out property <string?> text: "hello";
    out property <bool> has_text: text != none;
}

/*
```rust
let instance = TestCase::new().unwrap();
assert_eq!(instance.get_text(), Some("hello".into()));
assert_eq!(instance.get_has_text(), true);
```
*/
