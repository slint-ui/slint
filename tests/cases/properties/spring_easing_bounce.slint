// Tests the `spring` easing curve driven by `bounce` (duration/bounce style,
// see `physics_simulation::SpringDurationBounceParameters`).
export component TestCase inherits Rectangle {
    // bounce: 0 -> critically damped, approaches the target without ever overshooting it.
    in-out property <float> critical: 0;
    animate critical {
        duration: 1000ms;
        easing: spring;
        bounce: 0;
    }

    // bounce: 1 -> undamped, oscillates forever without settling (over one period here).
    in-out property <float> undamped: 0;
    animate undamped {
        duration: 1000ms;
        easing: spring;
        bounce: 1;
    }

    // bounce: -1 -> overdamped, approaches the target even slower than critical damping.
    in-out property <float> overdamped: 0;
    animate overdamped {
        duration: 1000ms;
        easing: spring;
        bounce: -1;
    }
}

/*
```rust
let instance = TestCase::new().unwrap();
fn assert_approx(value: f32, expected: f32) {
    assert!((value - expected).abs() < 0.01, "Expected {value} to be close to {expected}");
}

instance.set_critical(1.0);
instance.set_undamped(1.0);
instance.set_overdamped(1.0);

slint_testing::mock_elapsed_time(250);
assert_approx(instance.get_critical(), 0.4656);
assert_approx(instance.get_undamped(), 1.0);
assert_approx(instance.get_overdamped(), 0.2930);

slint_testing::mock_elapsed_time(250);
// Critical damping never overshoots the target.
assert_approx(instance.get_critical(), 0.8210);
assert!(instance.get_critical() < 1.0);
// The undamped spring overshoots, reaching twice the target at the midpoint.
assert_approx(instance.get_undamped(), 2.0);
// Overdamped moves slower than critical damping and also never overshoots.
assert_approx(instance.get_overdamped(), 0.5357);
assert!(instance.get_overdamped() < instance.get_critical());

slint_testing::mock_elapsed_time(500);
// Once the full duration has elapsed, the animation is done and the
// value is close to the target
let critical = instance.get_critical();
assert!(1.0 - critical < 0.15, "Expected {critical} to be close to 1.0");
// 0.0 as it oscillates forever
assert_eq!(instance.get_undamped(), 0.0);
// overdamped is slower than duration
assert!(instance.get_overdamped() > 0.7);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;

instance.set_critical(1.0);
instance.set_undamped(1.0);
instance.set_overdamped(1.0);

slint_testing::mock_elapsed_time(250);
assert(std::abs(instance.get_critical() - 0.4656) < 0.01);
assert(std::abs(instance.get_undamped() - 1.0) < 0.01);
assert(std::abs(instance.get_overdamped() - 0.2930) < 0.01);

slint_testing::mock_elapsed_time(250);
assert(std::abs(instance.get_critical() - 0.8210) < 0.01);
assert(instance.get_critical() < 1.0);
assert(std::abs(instance.get_undamped() - 2.0) < 0.01);
assert(std::abs(instance.get_overdamped() - 0.5357) < 0.01);
assert(instance.get_overdamped() < instance.get_critical());

slint_testing::mock_elapsed_time(500);
auto critical = instance.get_critical();
assert(1.0 - critical < 0.15);
// 0.0 as it oscillates forever
assert_eq(instance.get_undamped(), 0.0);
// overdamped is slower than duration
assert(instance.get_overdamped() > 0.7);
```

