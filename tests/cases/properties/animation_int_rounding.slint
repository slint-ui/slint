// An animated int property interpolates in int space: every intermediate
// value is rounded to the nearest integer, not truncated and not left
// fractional. At 336ms of a linear 0->100 animation the raw value is 33.6,
// so a correct implementation reads 34 everywhere, including through the
// language APIs that see the raw value (e.g. JavaScript numbers).

export component TestCase inherits Window {
    in-out property <int> value: 0;
    animate value { duration: 1000ms; }

    out property <bool> test: value == 0;
}

