slint_testing::mock_elapsed_time(336);
assert_eq!(instance.get_value(), 34, "33.6 must round to 34");

slint_testing::mock_elapsed_time(164);
assert_eq!(instance.get_value(), 50);

slint_testing::mock_elapsed_time(500);
assert_eq!(instance.get_value(), 100);
```

