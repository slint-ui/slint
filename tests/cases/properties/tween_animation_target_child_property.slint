export component TestCase inherits Rectangle {
    width: 300px;
    height: 300px;
    background: white;

    rect := Rectangle {
        x: 20px;
        y: 20px;
        width: 60px;
        height: 60px;
        background: grey;
        border-radius: 4px;
    }

    TouchArea {
        x: 20px;
        y: 20px;
        width: 60px;
        height: 60px;
        clicked => {
            anim.running = true;
        }
    }

    anim := TweenAnimation {
        target: rect.x;
        to: 200px;
        duration: 1000ms;
        easing: ease-in-out;
    }

    out property <length> rect-x: rect.x;
    out property <bool> anim_running: anim.running;

    public function start_anim() {
        anim.start();
    }
    public function change_x() {
        rect.x = 20px;
    }
}

