export component TestCase inherits Rectangle {
    width: 300px;
    height: 300px;
    background: white;

    rect := Rectangle {
        x: 20px;
        y: 20px;
        width: 60px;
        height: 60px;
        background: grey;
        border-radius: 4px;
    }

    TouchArea {
        x: 20px;
        y: 20px;
        width: 60px;
        height: 60px;
        clicked => {
            anim.running = true;
        }
    }

    anim := SpringAnimation {
        target: rect.x;
        to: 200px;
        duration: 1000ms;
        bounce: 0;
    }

    out property <length> rect-x: rect.x;
    out property <bool> anim_running: anim.running;

    public function start_anim() {
        anim.start();
    }
    public function change_x() {
        rect.x = 20px;
    }
}

/*

```rust
let instance = TestCase::new().unwrap();
fn assert_almost_eq(value: f32, expected: f32) {
    assert!((value - expected).abs() < 0.5, "Expected {value} to be close to {expected} (+-0.5)");
}
assert_eq!(instance.get_rect_x(), 20.);

// Start animation
instance.invoke_start_anim();

// Progress through the animation - critically damped, closed-form value at t=500ms.
slint_testing::mock_elapsed_time(500);
assert_almost_eq(instance.get_rect_x(), 167.78);

// Settled animation
slint_testing::mock_elapsed_time(3000);
assert_eq!(instance.get_rect_x(), 200.);
assert!(!instance.get_anim_running());

// A subsequent write to the target restarts the spring, from the current value.
instance.invoke_change_x();
slint_testing::mock_elapsed_time(1);
assert_eq!(instance.get_rect_x(), 20.);
assert!(instance.get_anim_running());

slint_testing::mock_elapsed_time(500);
assert_almost_eq(instance.get_rect_x(), 167.78);

slint_testing::mock_elapsed_time(3000);
assert_eq!(instance.get_rect_x(), 200.);
assert!(!instance.get_anim_running());
```

