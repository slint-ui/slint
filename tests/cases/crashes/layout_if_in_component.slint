export Btn := Rectangle {
    property <bool> show: false;
    min-height: max(32px, l.min-height);
    l := HorizontalLayout {
        if (show): button_in_image := Image {
            width: 24px;
        }
        text := Text {  }
    }
}

export TestCase := Window {
    property <bool> show: false;
    x := HorizontalLayout {
        btn := Btn { show: root.show; }
    }
}
