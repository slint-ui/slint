// Test for issue #781

global Glop  {
    in-out property <int> r;
}

component SubSubCompo inherits Rectangle {
    in-out property <int> val;
    TouchArea {
        clicked => { Glop.r = val; }
    }
}
component SubCompo inherits SubSubCompo { }

export component TestCase inherits Window {
    width: 300px;
    height: 300px;
    HorizontalLayout {
        SubCompo { val: 88; }
        SubCompo { val: 99; }
    }

    in-out property <int> result: Glop.r;
}

/*
```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
slint_testing::send_mouse_click(&instance, 295., 295.);
assert_eq(instance.get_result(), 99);
```

```rust
let instance = TestCase::new().unwrap();
slint_testing::send_mouse_click(&instance, 295., 295.);
assert_eq!(instance.get_result(), 99);
```

*/
