// Regression test for "Recursion detected" panics when a Repeater or
// Conditional is first instantiated inside a layout binding and the new
// component's init code reads a geometry property.

component Inner inherits Rectangle {
    width: 50px;
    min-height: 30px;
    init => {
        // Reading geometry here used to trigger the recursion panic.
        debug(self.y);
    }
}

export component TestCase inherits Window {
    width: 300px;
    height: 300px;
    in-out property <bool> show: true;
    out property <length> measured-w: lay.preferred-width;

    lay := VerticalLayout {
        if show: Inner {}
    }
}

/*
```rust
let instance = TestCase::new().unwrap();
assert!(instance.get_measured_w() >= 50.);
```

```cpp
auto handle = TestCase::create();
const TestCase &instance = *handle;
assert(instance.get_measured_w() >= 50.);
```

```js
var instance = new slint.TestCase({});
assert(instance.measured_w >= 50);
```
*/
