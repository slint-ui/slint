instance.glob_prop = { field: "from1" };
slintlib.private_api.send_mouse_click(instance, 5., 5.);
assert.deepStrictEqual(m.rowData(2), { value: "from1" });

// And the reverse: writing to the model should propagate to glob-prop.
m.setRowData(2, { value: "from2" });
slintlib.private_api.send_mouse_click(instance, 5., 5.);
assert.deepStrictEqual(instance.glob_prop, { field: "from2" });
