export component TestCase inherits Window {
    in-out property <string> matched: "";
    forward-focus: scope;

    init => {
        scope.focus();
    }

    scope := FocusScope {
        KeyBinding {
            keys: @physical-keys(Control + A);
            activated => {
                matched = "physical-a";
            }
        }

        KeyBinding {
            keys: @keys(Control + A);
            activated => {
                matched = "logical-a";
            }
        }
    }
}

/*
```rust
let instance = TestCase::new().unwrap();
use i_slint_core::SharedString;
use i_slint_core::input::key_codes::Key;

slint_testing::send_key_combo_with_text_and_physical_keys(
    &instance,
    &[(Key::Control.into(), SharedString::default()), ("z".into(), "A".into())],
);
assert_eq!(instance.get_matched(), "physical-a");
instance.set_matched("".into());

slint_testing::send_key_combo_with_text_and_physical_keys(
    &instance,
    &[(Key::Control.into(), SharedString::default()), ("a".into(), "Q".into())],
);
assert_eq!(instance.get_matched(), "logical-a");
instance.set_matched("".into());

slint_testing::send_key_combo_with_text_and_physical_keys(
    &instance,
    &[(Key::Control.into(), SharedString::default()), ("a".into(), SharedString::default())],
);
assert_eq!(instance.get_matched(), "logical-a");
```
*/
