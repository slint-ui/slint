```js
var instance = new slint.TestCase();

// Section 1
slintlib.private_api.send_mouse_click(instance, 50., 50.);
assert.equal(instance.clicked_value, 1);

instance.front = true;
slintlib.private_api.send_mouse_click(instance, 50., 50.);
assert.equal(instance.clicked_value, 2);

// Section 2
instance.top_layer = 0;
slintlib.private_api.send_mouse_click(instance, 150., 50.);
assert.equal(instance.clicked_value, 10);

instance.top_layer = 2;
slintlib.private_api.send_mouse_click(instance, 150., 50.);
assert.equal(instance.clicked_value, 12);

instance.top_layer = 3;
slintlib.private_api.send_mouse_click(instance, 150., 50.);
assert.equal(instance.clicked_value, 13);

instance.top_layer = 1;
slintlib.private_api.send_mouse_click(instance, 150., 50.);
assert.equal(instance.clicked_value, 11);

// Section 3
instance.front = true;
slintlib.private_api.send_mouse_click(instance, 250., 50.);
assert.equal(instance.clicked_value, 21);

instance.front = false;
slintlib.private_api.send_mouse_click(instance, 250., 50.);
assert.equal(instance.clicked_value, 20);

// Section 4
slintlib.private_api.send_mouse_click(instance, 350., 50.);
assert.equal(instance.clicked_value, 31);
slintlib.private_api.send_mouse_click(instance, 450., 50.);
assert.equal(instance.clicked_value, 41);
instance.front = true;
slintlib.private_api.send_mouse_click(instance, 350., 50.);
assert.equal(instance.clicked_value, 32);
slintlib.private_api.send_mouse_click(instance, 450., 50.);
assert.equal(instance.clicked_value, 42);

// Section 5
instance.front = false;
slintlib.private_api.send_mouse_click(instance, 550., 50.);
assert.equal(instance.clicked_value, 50);
instance.front = true;
slintlib.private_api.send_mouse_click(instance, 550., 50.);
assert.equal(instance.clicked_value, 51);

// Section 6
slintlib.private_api.send_mouse_click(instance, 650., 50.);
assert.equal(instance.clicked_value, 60);
instance.ZOrderGlobal.overlay_z = 1;
slintlib.private_api.send_mouse_click(instance, 650., 50.);
assert.equal(instance.clicked_value, 61);

// Section 7
instance.top_layer = 0;
slintlib.private_api.send_mouse_click(instance, 750., 50.);
assert.equal(instance.clicked_value, 70);
instance.top_layer = 2;
slintlib.private_api.send_mouse_click(instance, 750., 50.);
assert.equal(instance.clicked_value, 72);
instance.top_layer = 1;
slintlib.private_api.send_mouse_click(instance, 750., 50.);
assert.equal(instance.clicked_value, 71);

// Section 8
instance.front = true;
instance.top_layer = 0;
slintlib.private_api.send_mouse_click(instance, 850., 25.);
assert.equal(instance.clicked_value, 88);
instance.top_layer = 8;
slintlib.private_api.send_mouse_click(instance, 850., 25.);
assert.equal(instance.clicked_value, 82);
instance.front = false;
slintlib.private_api.send_mouse_click(instance, 850., 25.);
assert.equal(instance.clicked_value, 83);
instance.top_layer = 0;
slintlib.private_api.send_mouse_click(instance, 850., 75.);
assert.equal(instance.clicked_value, 85);
instance.top_layer = 1;
slintlib.private_api.send_mouse_click(instance, 850., 75.);
assert.equal(instance.clicked_value, 86);
instance.front = true;
slintlib.private_api.send_mouse_click(instance, 850., 75.);
assert.equal(instance.clicked_value, 86);
instance.top_layer = 9;
slintlib.private_api.send_mouse_click(instance, 850., 75.);
assert.equal(instance.clicked_value, 87);
instance.front = false;
slintlib.private_api.send_mouse_click(instance, 850., 25.);
assert.equal(instance.clicked_value, 84);

// Section 9
slintlib.private_api.send_mouse_click(instance, 950., 50.);
assert.equal(instance.clicked_value, 92);
instance.front = true;
slintlib.private_api.send_mouse_click(instance, 950., 50.);
assert.equal(instance.clicked_value, 93);

// Section 10
slintlib.private_api.send_mouse_click(instance, 1050., 50.);
assert.equal(instance.clicked_value, 100);
instance.front = false;
slintlib.private_api.send_mouse_click(instance, 1050., 50.);
assert.equal(instance.clicked_value, 101);

// Section 11
instance.top_layer = 0;
slintlib.private_api.send_mouse_click(instance, 1150., 50.);
assert.equal(instance.clicked_value, 110);
instance.ZOrderGlobal.overlay_z = 10;
