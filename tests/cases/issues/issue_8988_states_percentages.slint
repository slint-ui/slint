export component TestCase inherits Window {
    width: 800px;
    height: 600px;

    out property <length> inner_width <=> inner.width;
    out property <length> inner_height <=> inner.height;

    inner := Rectangle {
        width: 10%;

        states [
            test when true: {
                width: 100%;
                height: 100%;
            }
        ]
    }
}


/*
```rust
let instance = TestCase::new().unwrap();
instance.show().unwrap();

assert_eq!(instance.get_inner_width(), 800.);
assert_eq!(instance.get_inner_height(), 600.);
```
*/
