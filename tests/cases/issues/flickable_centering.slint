export component TestCase inherits Window {
    width: 800px;
    height: 600px;

    out property <length> inner_x <=> inner.x;
    out property <length> inner_y <=> inner.y;

    Flickable {
        viewport-height: 1000px;
        viewport-width: 1000px;

        inner:= Rectangle {
            // In this case the 100% should not trigger the optimization of skipping the centering.
            width: 100%;
            height: 100%;
        }
    }
}


/*
```rust
let instance = TestCase::new().unwrap();
instance.show().unwrap();

assert_eq!(instance.get_inner_x(), 100.);
assert_eq!(instance.get_inner_y(), 200.);
```
*/
