assert_eq!(instance.get_length_m2(), 0);
assert_eq!(instance.get_length_m3(), 0);
assert_eq!(instance.get_length_m4(), 1);
assert_eq!(instance.get_length_m5(), 1);

instance.invoke_append();

assert_eq!(instance.get_length_m1(), 1);
assert_eq!(instance.get_length_m2(), 0);
assert_eq!(instance.get_length_m3(), 1);
assert_eq!(instance.get_length_m4(), 3);
assert_eq!(instance.get_length_m5(), 3);

```
