<?xml version="1.0" encoding="utf-8" ?>
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap2="http://schemas.microsoft.com/appx/manifest/uap/windows10/2"
    xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
    xmlns:desktop6="http://schemas.microsoft.com/appx/manifest/desktop/windows10/6"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap2 uap3 uap10 desktop desktop6 rescap uap5"
    xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
>
  <!-- Cargo version has 3 fields, MSIX version has 4 fields, so we just unconditionally add `.0` -->
  <Identity
        Name="slintvisualeditor"
        Publisher="CN=sixtyfps"
        Version="{{cargo.version}}.0"
    />
  <Properties>
    <DisplayName>Slint Visual Editor</DisplayName>
    <PublisherDisplayName>SixtyFPS GmbH</PublisherDisplayName>
    <Logo>packaging\windows-appx\SlintVisualEditor-Logo.png</Logo>
  </Properties>
  <Dependencies>
    <TargetDeviceFamily
            Name="Windows.Desktop"
            MinVersion="10.0.18362.0"
            MaxVersionTested="10.0.26200.0"
        />
  </Dependencies>
  <Resources>
    <Resource Language="en-us" />
  </Resources>
  <Applications>
    <Application
            Id="slintvisualeditor"
            Executable="$targetnametoken$.exe"
            uap10:TrustLevel="mediumIL"
            EntryPoint="Windows.FullTrustApplication"
        >
      <uap:VisualElements
                DisplayName="Slint Visual Editor"
                Description="The graphical editor for the Slint UI description language"
                BackgroundColor="transparent"
                Square150x150Logo="Assets\SlintVisualEditor-Logo-150x150.png"
                Square44x44Logo="Assets\SlintVisualEditor-Logo-44x44.png"
            >
        <uap:DefaultTile
          Square310x310Logo="Assets\SlintVisualEditor-Logo-310x310.png"
          Wide310x150Logo="Assets\SlintVisualEditor-Logo-310x150.png"
          Square71x71Logo="Assets\SlintVisualEditor-Logo-71x71.png"
          />
      </uap:VisualElements>
    </Application>
  </Applications>
  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
