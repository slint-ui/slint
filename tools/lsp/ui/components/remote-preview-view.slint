import { Button, LineEdit, ListView, Palette } from "std-widgets.slint";
import { Api, RemoteConnectionState } from "../api.slint";
import { EditorSpaceSettings } from "styling.slint";

component PhonePreview {
    property <bool> dark-color-scheme: Palette.color-scheme == ColorScheme.dark;
    in property <image> background-image;

    width: 190px;
    height: 380px;

    Rectangle {
        border-radius: 34px;
        background: root.dark-color-scheme ? @linear-gradient(180deg, #1C1C1C, black) : @linear-gradient(0deg, #D7D9DD, white);
        drop-shadow-blur: 10px;
        drop-shadow-color: black.with-alpha(0.5);
        clip: true;

        Image {
            y: parent.height - self.height;
            width: 100%;
            source: background-image;
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: 10px;
            width: 62px;
            height: 18px;
            border-radius: 9px;
            background: #111111;
        }

        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 92px;
            padding-bottom: 24px;
            alignment: space-between;

            VerticalLayout {
                spacing: 6px;
                Text {
                    text: @tr("Slint Viewer");
                    font-size: 16px;
                    font-weight: FontWeight.extra-bold;
                    color: root.dark-color-scheme ? #eeeeee : #333333;
                }
            }
        }

        Rectangle {
            border-radius: parent.border-radius;
            border-color: root.dark-color-scheme ? #232323 : #1f2025;
            border-width: 5px;
        }
    }
}

export component RemotePreviewView inherits Rectangle {
    background: Palette.background;
    min-width: 640px;
    min-height: 420px;
    preferred-width: 900px;
    preferred-height: 620px;

    property <int> selected-index: -1;
    property <string> manual-entry;

    property <bool> selection-is-compatible:
        selected-index >= 0
        && selected-index < Api.remote-discovered-viewers.length
        && Api.remote-discovered-viewers[selected-index].compatible;

    property <bool> connecting: Api.remote-connection-state == RemoteConnectionState.Connecting;
    property <bool> dark-color-scheme: Palette.color-scheme == ColorScheme.dark;
    property <image> background-image: root.dark-color-scheme ? @image-url("../../../viewer/remote/assets/bg-frame.svg") : @image-url("../../../viewer/remote/assets/bg-frame-light.svg");

    Rectangle {
        background: root.dark-color-scheme ? @linear-gradient(180deg, #1C1C1C, black) : @linear-gradient(0deg, #D7D9DD, white);
    }

    Image {
        y: parent.height - self.height;
        width: 100%;
        source: background-image;
    }

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 28px;
        spacing: 22px;

        HorizontalLayout {
            vertical-stretch: 0;
            alignment: space-between;

            VerticalLayout {
                spacing: 6px;
                Text {
                    text: Api.remote-connection-state == RemoteConnectionState.Connected
                        ? @tr("Previewing on {}.", Api.remote-connection-target)
                        : @tr("Searching for a device…");
                    font-size: 24px;
                    font-weight: FontWeight.bold;
                    color: Palette.foreground;
                }

                Text {
                    text: @tr("Open Slint Viewer on your phone and ensure it is on the same Wi-Fi.");
                    wrap: word-wrap;
                    color: Palette.foreground;
                    opacity: 0.72;
                }
            }

            Rectangle {
                width: 1px;
            }
        }

        HorizontalLayout {
            spacing: 28px;

            devices-frame := Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: Palette.background;
                border-color: root.dark-color-scheme ? #323131 : #d3d3d3;
                border-width: 1px;
                border-radius: 8px;

                inset-shadow-blur: 10px;
                inset-shadow-color: black.with-alpha(0.1);
                inset-shadow-offset-x: 3px;
                inset-shadow-offset-y: 3px;
                inset-shadow-spread: 1px;

                VerticalLayout {
                    padding: EditorSpaceSettings.default-padding * 2;
                    spacing: EditorSpaceSettings.default-spacing;

                    Text {
                        text: @tr("Devices");
                        font-weight: FontWeight.bold;
                        color: Palette.foreground;
                    }

                    Rectangle {
                        background: Palette.alternate-background;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Palette.border;
                        vertical-stretch: 1;
                        inset-shadow-blur: 5px;
                        inset-shadow-color: black.with-alpha(0.1);
                        inset-shadow-offset-x: 5px;
                        inset-shadow-offset-y: 5px;

                        if Api.remote-discovered-viewers.length == 0: VerticalLayout {
                            alignment: center;
                            spacing: EditorSpaceSettings.default-spacing;
                            Text {
                                text: @tr("Searching the local network…");
                                horizontal-alignment: center;
                                font-weight: FontWeight.bold;
                                color: Palette.foreground;
                                font-size: 12px;
                            }
                        }

                        if Api.remote-discovered-viewers.length > 0: ListView {
                            for device[i] in Api.remote-discovered-viewers: Rectangle {
                                height: device-layout.preferred-height;
                                background: i == root.selected-index
                                    ? Palette.accent-background
                                    : (touch.has-hover ? Palette.alternate-background : transparent);

                                touch := TouchArea {
                                    clicked => {
                                        root.selected-index = i;
                                        root.manual-entry = "";
                                    }
                                }

                                device-layout := HorizontalLayout {
                                    padding: EditorSpaceSettings.default-padding;
                                    spacing: EditorSpaceSettings.default-spacing;
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        Text {
                                            text: device.name;
                                            color: i == root.selected-index ? Palette.accent-foreground : Palette.foreground;
                                            font-weight: FontWeight.bold;
                                        }

                                        Text {
                                            text: (device.addresses.length > 0 ? device.addresses[0] : device.host) + ":" + device.port;
                                            color: i == root.selected-index ? Palette.accent-foreground : Palette.foreground;
                                            opacity: 0.7;
                                            font-size: 12px;
                                        }

                                        if !device.compatible: Text {
                                            text: device.incompatible-reason;
                                            color: #d33;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        border-radius: 4px;
                        inset-shadow-blur: 5px;
                        inset-shadow-color: black.with-alpha(0.15);
                        inset-shadow-offset-x: 5px;
                        inset-shadow-offset-y: 5px;
                        background: root.dark-color-scheme ? #1C1C1C : #D7D9DD;
                        LineEdit {
                            placeholder-text: @tr("Manual host:port, for example 192.168.1.42:9000");
                            text <=> root.manual-entry;
                            edited => {
                                root.selected-index = -1;
                            }
                        }
                    }

                    if root.connecting: Text {
                        text: @tr("Connecting to {}…", Api.remote-connection-target);
                        color: Palette.foreground;
                    }
                    if Api.remote-connection-state == RemoteConnectionState.Connected: Text {
                        text: @tr("Connected to {}. Switch to Local to disconnect.", Api.remote-connection-target);
                        color: #2a2;
                        font-weight: FontWeight.bold;
                    }
                    if Api.remote-connection-state == RemoteConnectionState.Failed: Text {
                        text: Api.remote-connection-error != ""
                            ? Api.remote-connection-error
                            : @tr("Connection failed");
                        color: #d33;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: EditorSpaceSettings.default-spacing;
                        alignment: end;

                        Button {
                            text: @tr("Connect");
                            primary: true;
                            enabled: !root.connecting && (root.selection-is-compatible || root.manual-entry != "");
                            clicked => {
                                if root.manual-entry != "" {
                                    Api.remote-connect-manual(root.manual-entry);
                                } else if root.selected-index >= 0
                                    && root.selected-index < Api.remote-discovered-viewers.length
                                    && Api.remote-discovered-viewers[root.selected-index].compatible
                                    && Api.remote-discovered-viewers[root.selected-index].addresses.length > 0 {
                                    Api.remote-connect(
                                        Api.remote-discovered-viewers[root.selected-index].addresses,
                                        Api.remote-discovered-viewers[root.selected-index].port);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 260px;
                vertical-stretch: 1;

                VerticalLayout {
                    alignment: center;
                    spacing: EditorSpaceSettings.default-spacing * 2;
                    cross-axis-alignment: center;

                    PhonePreview {
                        background-image: background-image;
                    }

                    Text {
                        text: @tr("Start Slint Viewer on your device using the same Wi-Fi.");
                        horizontal-alignment: left;
                        wrap: word-wrap;
                        color: Palette.foreground;
                        opacity: 0.80;
                        font-size: 14px;
                    }
                }
            }
        }
    }
}
