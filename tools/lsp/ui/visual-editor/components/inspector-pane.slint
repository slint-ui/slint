            overflow: elide;
        }
    }
}

component InspectorCopyButton inherits Rectangle {
    callback clicked;

    width: 54px;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: touch.has-hover ? InspectorTokens.field-bg-hover : InspectorTokens.field-bg;
    border-width: 1px;
    border-color: InspectorTokens.divider;

    Text {
        text: "Copy";
        color: InspectorTokens.text;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component InspectorSyntaxField inherits Rectangle {
    in property <string> value;

    horizontal-stretch: 1;
    height: 54px;
    border-radius: InspectorTokens.field-radius;
    background: InspectorTokens.field-bg;

    Text {
        x: 8px;
        width: parent.width - 16px;
        text: root.value;
        color: InspectorTokens.text;
        font-size: 11px;
        vertical-alignment: center;
        wrap: word-wrap;
    }
}

component InspectorSection inherits Rectangle {
    in property <string> title;
    in property <bool> show-appearance-icons: false;
    in property <bool> show-typography-icons: false;

    horizontal-stretch: 1;
    height: section-layout.preferred-height;

    section-layout := VerticalLayout {
        width: root.width;
        padding-top: 12px;
        padding-bottom: 16px;
        spacing: 11px;

        Rectangle {
            height: 19px;

            Text {
                x: InspectorTokens.side-padding;
                text: root.title;
                color: InspectorTokens.text;
                font-size: InspectorTokens.section-title-size;
                font-weight: 700;
                vertical-alignment: center;
            }

            if root.show-appearance-icons: HorizontalLayout {
                x: parent.width - InspectorTokens.side-padding - self.preferred-width;
                y: 0.5px;
                height: 18px;
                spacing: 8px;

                InspectorIconButton { kind: "eye"; }
                InspectorIconButton { kind: "drop"; }
            }

            if root.show-typography-icons: HorizontalLayout {
                x: parent.width - InspectorTokens.side-padding - self.preferred-width;
                y: 0.5px;
                height: 18px;
                spacing: 0px;

                InspectorIconButton { kind: "type-grid"; }
            }
        }

        @children
    }

    Rectangle {
        y: root.height - 1px;
        height: 1px;
        background: InspectorTokens.divider;
    }
}

export component InspectorPane inherits Rectangle {
    in property <CanvasSelectionKind> selection;
    in property <Point> placed-position;
    in property <Size> rectangle-size;
    in property <Size> text-size;
    in property <Size> image-size;
    in property <color> phone-background;
    in property <string> phone-background-label;
    in property <ElementInformation> element-information;

    callback local-geometry-edited(Point, Size) -> bool;
    callback element-selected();

    width: EditorMetrics.inspector-pane-width;
    background: InspectorTokens.panel-bg;
    property <length> content-x: 1px;
    property <length> split-height: 1px;
    property <length> inspector-height: (root.height - root.split-height) / 2;

    property <[SelectionRectangle]> selection-rects: Api.selection.highlight-index >= 0
        ? Api.highlight-positions(root.element-information.source-uri, root.element-information.offset)
        : [];
    property <bool> image-mode: Api.editor-surface-mode == EditorSurfaceMode.image;
    property <bool> tooltip-visible: false;
    property <string> tooltip-key: "";
    property <string> tooltip-label: "";
    property <Point> tooltip-position: { x: 0px, y: 0px };
    property <string> hovered-tooltip-key: "";
    property <string> hovered-tooltip-label: "";
    property <Point> hovered-tooltip-position: { x: 0px, y: 0px };

    function has-backend-rect() -> bool {
        return Api.selection.highlight-index >= 0 && root.selection-rects.length > Api.selection.highlight-index;
    }

    function is-rectangle-selection() -> bool {
        return root.selection == CanvasSelectionKind.rectangle
            || (root.has-backend-rect() && root.element-information.type-name == "Rectangle");
    }

    function is-text-selection() -> bool {
        return root.selection == CanvasSelectionKind.text
            || (root.has-backend-rect() && root.element-information.type-name == "Text");
    }

    function is-image-selection() -> bool {
        return root.selection == CanvasSelectionKind.image
            || (root.has-backend-rect() && root.element-information.type-name == "Image");
    }

    function has-backend-image-selection() -> bool {
        return root.has-backend-rect() && root.element-information.type-name == "Image";
    }

    function is-root-selection() -> bool {
        return !root.has-backend-rect() && root.selection == CanvasSelectionKind.artboard;
    }

    function selected-x() -> length {
        return root.has-backend-rect()
            ? root.selection-rects[Api.selection.highlight-index].x
            : root.placed-position.x;
    }

    function selected-y() -> length {
        return root.has-backend-rect()
            ? root.selection-rects[Api.selection.highlight-index].y
            : root.placed-position.y;
    }

    function selected-width() -> length {
        if root.has-backend-rect() {
            return root.selection-rects[Api.selection.highlight-index].width;
        }
        if root.is-image-selection() {
            return root.image-size.width;
        }
        return root.is-text-selection() ? root.text-size.width : root.rectangle-size.width;
    }

    function selected-height() -> length {
        if root.has-backend-rect() {
            return root.selection-rects[Api.selection.highlight-index].height;
        }
        if root.is-image-selection() {
            return root.image-size.height;
        }
        return root.is-text-selection() ? root.text-size.height : root.rectangle-size.height;
    }

    function selected-x-label() -> string {
        return (root.selected-x() / 1px).to-fixed(0);
    }

    function selected-y-label() -> string {
        return (root.selected-y() / 1px).to-fixed(0);
    }

    function selected-width-label() -> string {
        return (root.selected-width() / 1px).to-fixed(0);
    }

    function selected-height-label() -> string {
        return (root.selected-height() / 1px).to-fixed(0);
    }

    function commit-geometry(x-text: string, y-text: string, width-text: string, height-text: string) -> bool {
        if !x-text.is-float() || !y-text.is-float() || !width-text.is-float() || !height-text.is-float() {
            return false;
        }

        let new-position = {
            x: x-text.to-float() * 1px,
            y: y-text.to-float() * 1px,
        };
        let new-size = {
            width: width-text.to-float() * 1px,
            height: height-text.to-float() * 1px,
        };

        if new-size.width <= 0px || new-size.height <= 0px {
            return false;
        }

        if root.has-backend-rect() {
            Api.selected-element-resize(new-position.x, new-position.y, new-size.width, new-size.height);
            return true;
        }

        return root.local-geometry-edited(new-position, new-size);
    }

    function commit-code(property-name: string, value: string) -> bool {
        if value == "" || root.element-information.source-uri == "" {
            return false;
        }
        if !Api.test-code-binding(
            root.element-information.source-uri,
            root.element-information.source-version,
            root.element-information.offset,
            property-name,
            value,
        ) {
            return false;
        }
        Api.set-code-binding(
            root.element-information.source-uri,
            root.element-information.source-version,
            root.element-information.offset,
            property-name,
            value,
        );
        return true;
    }

    function commit-px-code(property-name: string, value: string) -> bool {
        if !value.is-float() {
            return false;
        }
        return root.commit-code(property-name, value + "px");
    }

    function quote(value: string) -> string {
        return "\"" + value + "\"";
    }

    function image-source-value() -> string {
        return Api.current-property-value("source", "");
    }

    function image-fit-value() -> string {
        let value = Api.current-property-value("image-fit", "fill");
        if value == "fill" || value == "preserve" || value == "contain" || value == "cover" {
            return value;
        }
        return "fill";
    }

    function image-fit-index() -> int {
        let value = root.image-fit-value();
        if value == "fill" {
            return 0;
        }
        if value == "preserve" {
            return 1;
        }
        if value == "contain" {
            return 2;
        }
        if value == "cover" {
            return 3;
        }
        return -1;
    }

    function image-horizontal-alignment-value() -> string {
        return Api.current-property-value("horizontal-alignment", "center");
    }

    function image-vertical-alignment-value() -> string {
        return Api.current-property-value("vertical-alignment", "center");
    }

    function image-width-label() -> string {
        return Api.selected-image-asset.image.width + "";
    }

    function image-height-label() -> string {
        return Api.selected-image-asset.image.height + "";
    }

    function image-nine-slice-expression() -> string {
        return Api.image-nine-slice-expression(
            Api.selected-image-asset.relative-path,
            Api.image-nine-slice-top,
            Api.image-nine-slice-right,
            Api.image-nine-slice-bottom,
            Api.image-nine-slice-left,
        );
    }

    function tooltip-position-for(field-position: Point) -> Point {
        return {
            x: field-position.x - root.absolute-position.x - root.content-x + (InspectorTokens.column-width - 71px) / 2,
            y: field-position.y - root.absolute-position.y + InspectorTokens.field-height + 1px,
        };
    }

    function show-current-tooltip() {
        root.tooltip-key = root.hovered-tooltip-key;
        root.tooltip-label = root.hovered-tooltip-label;
        root.tooltip-position = root.hovered-tooltip-position;
        root.tooltip-visible = true;
    }

    function show-tooltip(key: string, label: string, field-position: Point) {
        root.hovered-tooltip-key = key;
        root.hovered-tooltip-label = label;
        root.hovered-tooltip-position = root.tooltip-position-for(field-position);
        hide-tooltip-timer.running = false;

        if root.tooltip-visible {
            show-tooltip-timer.running = false;
            root.show-current-tooltip();
        } else {
            show-tooltip-timer.running = false;
            show-tooltip-timer.running = true;
        }
    }

    function hide-tooltip(key: string) {
        if key != root.hovered-tooltip-key {
            return;
        }

        root.hovered-tooltip-key = "";
        root.hovered-tooltip-label = "";
        show-tooltip-timer.running = false;

        if root.tooltip-visible {
            hide-tooltip-timer.running = false;
            hide-tooltip-timer.running = true;
        }
    }

    function reset-tooltip() {
        root.tooltip-visible = false;
        root.tooltip-key = "";
        root.tooltip-label = "";
    }

    show-tooltip-timer := Timer {
        interval: 1500ms;
        running: false;
        triggered => {
            self.running = false;

            if root.hovered-tooltip-key != "" {
                root.show-current-tooltip();
            }
        }
    }

    hide-tooltip-timer := Timer {
        interval: 1500ms;
        running: false;
        triggered => {
            self.running = false;

            if root.hovered-tooltip-key == "" {
                root.reset-tooltip();
            } else {
                root.show-current-tooltip();
            }
        }
    }

    EdgeDivider {
        x: 0px;
        background: InspectorTokens.divider;
    }

    Flickable {
        x: root.content-x;
        y: 0px;
        width: root.width - root.content-x;
        height: root.inspector-height;
        viewport-width: self.width;
        viewport-height: content.height;

        content := Rectangle {
            width: parent.width;
            height: content-layout.preferred-height;

            content-layout := VerticalLayout {
                width: parent.width;
                alignment: start;

                if root.image-mode: InspectorSection {
                    title: "Image";

                    VerticalLayout {
                        padding-left: InspectorTokens.side-padding;
                        spacing: 8px;

                        InspectorReadOnlyField {
                            prefix: "File";
                            value: Api.selected-image-asset.relative-path;
                            wide: true;
                        }

                        HorizontalLayout {
                            spacing: InspectorTokens.column-gap;

                            InspectorReadOnlyField {
                                prefix: "Fmt";
                                value: Api.selected-image-asset.format;
                            }

                            InspectorReadOnlyField {
                                prefix: "W";
                                value: root.image-width-label();
                            }
                        }

                        InspectorReadOnlyField {
                            prefix: "H";
                            value: root.image-height-label();
                        }
                    }
                }

                if root.image-mode: InspectorSection {
                    title: "Nine-Slice";

                    VerticalLayout {
                        padding-left: InspectorTokens.side-padding;
                        padding-right: InspectorTokens.side-padding;
                        spacing: 8px;

                        InspectorSyntaxField {
                            value: root.image-nine-slice-expression();
                        }

                        HorizontalLayout {
                            alignment: end;

                            InspectorCopyButton {
                                clicked => {
                                    Api.copy-nine-slice-expression(root.image-nine-slice-expression());
                                }
                            }
                        }
                    }
                }

                if !root.image-mode && (root.is-rectangle-selection() || root.is-text-selection() || root.is-image-selection()): InspectorSection {
                    title: "Position";

                    HorizontalLayout {
                        padding-left: InspectorTokens.side-padding;
                        spacing: InspectorTokens.column-gap;

                        InspectorValueField {
                            prefix: "X";
                            value: root.selected-x-label();
                            tooltip-label: "X-position";
                            tooltip-hovered(key, label, position) => { root.show-tooltip(key, label, position); }
                            tooltip-hidden(key) => { root.hide-tooltip(key); }
                            accepted(text) => {
                                return root.commit-geometry(text, root.selected-y-label(), root.selected-width-label(), root.selected-height-label());
                            }
                        }

                        InspectorValueField {
                            prefix: "Y";
                            value: root.selected-y-label();
                            tooltip-label: "Y-position";
                            tooltip-hovered(key, label, position) => { root.show-tooltip(key, label, position); }
                            tooltip-hidden(key) => { root.hide-tooltip(key); }
                            accepted(text) => {
                                return root.commit-geometry(root.selected-x-label(), text, root.selected-width-label(), root.selected-height-label());
                            }
                        }
                    }
                }

                if !root.image-mode && (root.is-rectangle-selection() || root.is-text-selection() || root.is-image-selection()): InspectorSection {
                    title: "Layout";

                    HorizontalLayout {
                        padding-left: InspectorTokens.side-padding;
                        spacing: InspectorTokens.column-gap;

                        InspectorValueField {
                            prefix: "W";
                            value: root.selected-width-label();
                            tooltip-label: "Width";
                            tooltip-hovered(key, label, position) => { root.show-tooltip(key, label, position); }
                            tooltip-hidden(key) => { root.hide-tooltip(key); }
                            accepted(text) => {
                                return root.commit-geometry(root.selected-x-label(), root.selected-y-label(), text, root.selected-height-label());
                            }
                        }

                        InspectorValueField {
                            prefix: "H";
                            value: root.selected-height-label();
                            tooltip-label: "Height";
                            tooltip-hovered(key, label, position) => { root.show-tooltip(key, label, position); }
                            tooltip-hidden(key) => { root.hide-tooltip(key); }
                            accepted(text) => {
                                return root.commit-geometry(root.selected-x-label(), root.selected-y-label(), root.selected-width-label(), text);
                            }
                        }
                    }
                }

                if !root.image-mode && (root.is-root-selection() || root.is-rectangle-selection() || root.is-text-selection()): InspectorSection {
                    title: "Appearance";
                    show-appearance-icons: false;

                    HorizontalLayout {
                        padding-left: InspectorTokens.side-padding;
                        spacing: InspectorTokens.column-gap;

                        if root.is-root-selection(): InspectorColorField {
                            value: root.phone-background-label;
                            swatch: root.phone-background;
                            wide: true;
                            accepted(text) => {
                                return root.commit-code("background", text);
                            }
                        }

                        if root.is-rectangle-selection(): InspectorColorField {
                            value: StudioTheme.dark ? "#383838" : "#ffffff";
                            swatch: StudioTheme.dark ? #383838 : #ffffff;
                            wide: true;
                            accepted(text) => {
                                return root.commit-code("background", text);
                            }
                        }

                        if root.is-text-selection(): InspectorColorField {
                            value: StudioTheme.dark ? "#f4f4f4" : "#1f2328";
                            swatch: StudioTheme.dark ? #f4f4f4 : #1f2328;
                            wide: true;
                            accepted(text) => {
                                return root.commit-code("color", text);
                            }
                        }
                    }
                }

                if !root.image-mode && root.has-backend-image-selection(): InspectorSection {
                    title: "Image";

                    VerticalLayout {
                        padding-left: InspectorTokens.side-padding;
                        padding-right: InspectorTokens.side-padding;
                        spacing: 8px;

                        InspectorCodeField {
                            prefix: "Source";
                            value: root.image-source-value();
                            accepted(text) => {
                                return root.commit-code("source", text);
                            }
                        }

                        VerticalLayout {
                            spacing: 5px;

                            HorizontalLayout {
                                spacing: 6px;
                                cross-axis-alignment: center;

                                Text {
                                    text: "Image fit";
                                    color: InspectorTokens.text;
                                    font-size: 11px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }

                                InspectorInfoIcon {
                                    activated => {
                                        Platform.open-url("https://docs.slint.dev/latest/docs/slint/reference/elements/image/#image-fit");
                                    }
                                }
                            }

                            InspectorComboBox {
                                value: root.image-fit-value();
                                selected-index: root.image-fit-index();
                                options: [
                                    { value: "fill", label: "fill", enabled: true },
                                    { value: "preserve", label: "preserve", enabled: true },
                                    { value: "contain", label: "contain", enabled: true },
                                    { value: "cover", label: "cover", enabled: true },
                                ];
                                wide: true;
                                accepted(text) => {
                                    return text != "" && root.commit-code("image-fit", text);
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: InspectorTokens.column-gap;

                            InspectorSelectField {
                                prefix: "H";
                                value: root.image-horizontal-alignment-value();
                                accepted(text) => {
                                    return text != "" && root.commit-code("horizontal-alignment", text);
                                }
                            }

                            InspectorSelectField {
                                prefix: "V";
                                value: root.image-vertical-alignment-value();
                                accepted(text) => {
                                    return text != "" && root.commit-code("vertical-alignment", text);
                                }
                            }
                        }
                    }
                }

                if !root.image-mode && root.is-text-selection(): InspectorSection {
                    title: "Typography";
                    show-typography-icons: false;

                    VerticalLayout {
                        padding-left: InspectorTokens.side-padding;
                        spacing: 8px;

                        InspectorSelectField {
                            value: "Roboto";
                            wide: true;
                            accepted(text) => {
                                return text != "" && root.commit-code("font-family", root.quote(text));
                            }
                        }

                        HorizontalLayout {
                            spacing: InspectorTokens.column-gap;

                            InspectorSelectField {
                                value: "Regular";
                                accepted(text) => {
                                    if text == "Regular" {
                                        return root.commit-code("font-weight", "400");
                                    }
                                    if text == "Bold" {
                                        return root.commit-code("font-weight", "700");
                                    }
                                    return text.is-float() && root.commit-code("font-weight", text);
                                }
                            }

                            InspectorSelectField {
                                value: "14";
                                accepted(text) => {
                                    return root.commit-px-code("font-size", text);
                                }
                            }
                        }

                        // HorizontalLayout {
                        //     spacing: InspectorTokens.column-gap;

                        //     InspectorValueField {
                        //         prefix: "A";
                        //         value: "20";
                        //         accepted(text) => {
                        //             return root.commit-px-code("line-height", text);
                        //         }
                        //     }

                        //     InspectorValueField {
                        //         prefix: "A";
                        //         value: "0";
                        //         accepted(text) => {
                        //             return root.commit-px-code("letter-spacing", text);
                        //         }
                        //     }
                        // }

                        // HorizontalLayout {
                        //     spacing: InspectorTokens.column-gap;

                        //     InspectorSegmentedIconControl {
                        //         kind: "horizontal";
                        //         selected-index: 0;
                        //         selected(index) => {
                        //             return root.commit-code(
                        //                 "horizontal-alignment",
                        //                 index == 0 ? "left" : index == 1 ? "center" : "right",
                        //             );
                        //         }
                        //     }

                        //     InspectorSegmentedIconControl {
                        //         kind: "vertical";
                        //         selected-index: 1;
                        //         selected(index) => {
                        //             return root.commit-code(
                        //                 "vertical-alignment",
                        //                 index == 0 ? "top" : index == 1 ? "center" : "bottom",
                        //             );
                        //         }
                        //     }
                        // }
                    }
                }
            }
        }
    }

    tooltip-layer := Rectangle {
        x: root.content-x;
        y: 0px;
        width: root.width - root.content-x;
        height: root.inspector-height;

        if root.tooltip-visible: InspectorTooltipBubble {
            x: root.tooltip-position.x;
            y: root.tooltip-position.y;
            label: root.tooltip-label;
        }
    }

    Rectangle {
        x: root.content-x;
        y: root.inspector-height;
        width: root.width - root.content-x;
        height: root.split-height;
        background: InspectorTokens.divider;
    }

    OutlinePane {
        x: root.content-x;
        y: root.inspector-height + root.split-height;
        width: root.width - root.content-x;
        height: root.height - self.y;
        element-selected => { root.element-selected(); }
    }
}
