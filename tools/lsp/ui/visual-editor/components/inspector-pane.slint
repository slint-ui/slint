import { Api, EditorSurfaceMode, ElementInformation, SelectionRectangle } from "../../api.slint";
import { Icons } from "../../components/styling.slint";
import { CanvasSelectionKind, EdgeDivider, EditorMetrics, StudioTheme } from "common.slint";
import { OutlinePane } from "outline-pane.slint";

global InspectorTokens {
    out property <color> panel-bg: StudioTheme.panel-bg;
    out property <color> divider: StudioTheme.dark ? #414141 : #e5e5e5;
    out property <color> field-bg: StudioTheme.dark ? #383838 : #f5f5f5;
    out property <color> field-bg-hover: StudioTheme.dark ? #414141 : #eeeeee;
    out property <color> field-border: StudioTheme.dark ? #4b4b4b : #d9d9d9;
    out property <color> text: StudioTheme.dark ? #f4f4f4 : #1e1e1e;
    out property <color> muted: StudioTheme.dark ? #9a9a9a : #8c8c8c;
    out property <color> accent: #0d99ff;
    out property <length> side-padding: 15px;
    out property <length> section-title-size: 12px;
    out property <length> field-height: 24px;
    out property <length> field-radius: 4px;
    out property <length> column-width: 88px;
    out property <length> column-gap: 8px;
    out property <length> wide-width: 184px;
}

struct InspectorComboOption {
    value: string,
    label: string,
    enabled: bool,
}

component InspectorIconButton inherits Rectangle {
    in property <string> kind;
    in property <bool> selected: false;
    callback clicked;

    width: 18px;
    height: 18px;
    border-radius: 3.5px;
    background: selected ? InspectorTokens.accent.with-alpha(0.12) : touch.has-hover ? InspectorTokens.field-bg : transparent;

    if root.kind == "eye": Rectangle {
        x: 3.5px;
        y: 5.5px;
        width: 11px;
        height: 7px;
        border-width: 1px;
        border-color: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        border-radius: 5.5px;

        Rectangle {
            width: 3px;
            height: 3px;
            border-radius: 1.5px;
            background: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        }
    }

    if root.kind == "drop": Rectangle {
        x: 6.5px;
        y: 3px;
        width: 6px;
        height: 11px;
        border-width: 1px;
        border-color: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        border-radius: 4px;
        transform-rotation: 28deg;
    }

    if root.kind == "type-grid": Rectangle {
        for row in 2: Rectangle {
            for col in 2: Rectangle {
                x: 4px + col * 6px;
                y: 4px + row * 6px;
                width: 3px;
                height: 3px;
                border-radius: 1.5px;
                border-width: 1px;
                border-color: InspectorTokens.text;
            }
        }
    }

    if root.kind == "sliders": Rectangle {
        for col in 3: Rectangle {
            x: 4px + col * 4.5px;
            y: 4px;
            width: 1px;
            height: 10px;
            background: InspectorTokens.text;
            border-radius: 1px;
        }
        Rectangle { x: 2.5px; y: 6.5px; width: 4px; height: 1px; background: InspectorTokens.text; }
        Rectangle { x: 7px; y: 10.5px; width: 4px; height: 1px; background: InspectorTokens.text; }
        Rectangle { x: 11.5px; y: 5px; width: 4px; height: 1px; background: InspectorTokens.text; }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component InspectorSegmentIcon inherits Rectangle {
    in property <string> kind;
    in property <int> index;
    in property <bool> selected;

    if root.kind == "horizontal": Rectangle {
        for line in 3: Rectangle {
            x: root.index == 0 ? 4.5px : root.index == 1 ? 3.5px + line * 1px : 2.5px + line * 2px;
            y: 5.5px + line * 3.5px;
            width: line == 1 ? 9.5px : 7px;
            height: 1px;
            background: root.selected ? InspectorTokens.text : InspectorTokens.muted;
            border-radius: 1px;
        }
    }

    if root.kind == "vertical": Rectangle {
        Rectangle {
            x: 8.5px;
            y: root.index == 0 ? 3.5px : root.index == 1 ? 6px : 9px;
            width: 1px;
            height: 9px;
            background: root.selected ? InspectorTokens.text : InspectorTokens.muted;
            border-radius: 1px;
        }
        Rectangle {
            x: 5px;
            y: root.index == 0 ? 4px : root.index == 1 ? 7.5px : 12.5px;
            width: 8px;
            height: 1px;
            background: root.selected ? InspectorTokens.text : InspectorTokens.muted;
            border-radius: 1px;
        }
        Rectangle {
            x: 7px;
            y: root.index == 0 ? 2.5px : root.index == 1 ? 9.5px : 11px;
            width: 4px;
            height: 1px;
            background: root.selected ? InspectorTokens.text : InspectorTokens.muted;
            border-radius: 1px;
        }
    }
}

component InspectorSegment inherits Rectangle {
    in property <string> kind;
    in property <int> index;
    in property <bool> selected;
    callback clicked;

    height: InspectorTokens.field-height;
    horizontal-stretch: 1;
    background: selected ? InspectorTokens.panel-bg : touch.has-hover ? InspectorTokens.field-bg-hover : transparent;
    border-radius: selected ? InspectorTokens.field-radius : 0px;
    border-width: selected ? 1px : 0px;
    border-color: InspectorTokens.divider;

    InspectorSegmentIcon {
        kind: root.kind;
        index: root.index;
        selected: root.selected;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component InspectorSegmentedIconControl inherits Rectangle {
    in property <string> kind;
    in property <int> selected-index;
    callback selected(int) -> bool;

    width: InspectorTokens.column-width;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: InspectorTokens.field-bg;
    clip: true;

    HorizontalLayout {
        spacing: 0px;

        InspectorSegment {
            kind: root.kind;
            index: 0;
            selected: root.selected-index == 0;
            clicked => { root.selected(0); }
        }

        Rectangle { width: 1px; background: InspectorTokens.panel-bg; }

        InspectorSegment {
            kind: root.kind;
            index: 1;
            selected: root.selected-index == 1;
            clicked => { root.selected(1); }
        }

        Rectangle { width: 1px; background: InspectorTokens.panel-bg; }

        InspectorSegment {
            kind: root.kind;
            index: 2;
            selected: root.selected-index == 2;
            clicked => { root.selected(2); }
        }
    }
}

component InspectorTooltipBubble inherits Rectangle {
    in property <string> label;
    private property <color> tip-bg: #1e1e1e;

    width: 71px;
    height: 31px;
    background: transparent;

    arrow := Path {
        x: (bubble.width - self.width) / 2;
        y: 0px;
        width: 12px;
        height: 7px;
        viewbox-width: 12;
        viewbox-height: 7;
        fill: root.tip-bg;

        MoveTo {
            x: 6;
            y: 0;
        }

        LineTo {
            x: 12;
            y: 7;
        }

        LineTo {
            x: 0;
            y: 7;
        }

        Close { }
    }

    bubble := Rectangle {
        y: arrow.height;
        width: root.width;
        height: root.height - arrow.height;
        border-radius: 4px;
        background: root.tip-bg;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 6px;
        drop-shadow-color: #00000028;

        tip-text := Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.label;
            color: white;
            font-size: 12px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component InspectorInfoIcon inherits Rectangle {
    callback activated;

    width: 14px;
    height: 14px;
    border-radius: 7px;
    border-width: 1px;
    border-color: touch.has-hover ? InspectorTokens.accent : InspectorTokens.muted.with-alpha(0.72);
    background: touch.has-hover ? InspectorTokens.accent.with-alpha(0.10) : transparent;

    Text {
        x: 0px;
        y: -0.5px;
        width: parent.width;
        height: parent.height;
        text: "i";
        color: touch.has-hover ? InspectorTokens.accent : InspectorTokens.muted;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;

        clicked => {
            root.activated();
        }
    }
}

component InspectorValueField inherits Rectangle {
    in property <string> prefix;
    in property <string> value;
    in property <bool> enabled: true;
    in property <string> tooltip-label: "";
    in property <string> tooltip-key: tooltip-label;
    callback tooltip-hovered(string, string, Point);
    callback tooltip-hidden(string);
    callback accepted(string) -> bool;

    width: InspectorTokens.column-width;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: !enabled ? InspectorTokens.field-bg.with-alpha(0.65) : input.has-focus ? InspectorTokens.panel-bg : touch.has-hover ? InspectorTokens.field-bg-hover : InspectorTokens.field-bg;
    border-width: input.has-focus ? 1px : 0px;
    border-color: InspectorTokens.accent;

    changed value => {
        if !input.has-focus {
            input.text = root.value;
        }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 7px;
        spacing: 5px;
        cross-axis-alignment: center;

        Text {
            text: root.prefix;
            color: root.enabled ? InspectorTokens.text : InspectorTokens.muted;
            font-size: 11px;
            font-weight: 400;
            vertical-alignment: center;
        }

        input := TextInput {
            horizontal-stretch: 1;
            text: root.value;
            enabled: root.enabled;
            single-line: true;
            wrap: no-wrap;
            color: root.enabled ? InspectorTokens.text : InspectorTokens.muted;
            font-size: 12px;
            font-weight: 400;
            vertical-alignment: center;
            horizontal-alignment: left;
            selection-background-color: InspectorTokens.accent.with-alpha(0.28);
            text-cursor-width: 1px;

            accepted => {
                if !root.accepted(self.text) {
                    self.text = root.value;
                }
            }

            changed has-focus => {
                if !self.has-focus && self.text != root.value {
                    if !root.accepted(self.text) {
                        self.text = root.value;
                    }
                }
            }
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: text;
        clicked => { input.focus(); }

        changed has-hover => {
            if self.has-hover && root.tooltip-label != "" {
                root.tooltip-hovered(root.tooltip-key, root.tooltip-label, root.absolute-position);
            } else if root.tooltip-label != "" {
                root.tooltip-hidden(root.tooltip-key);
            }
        }
    }
}

component InspectorSelectField inherits Rectangle {
    in property <string> prefix: "";
    in property <string> value;
    in property <bool> wide: false;
    callback accepted(string) -> bool;
    callback menu-clicked;

    width: wide ? InspectorTokens.wide-width : InspectorTokens.column-width;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: input.has-focus ? InspectorTokens.panel-bg : touch.has-hover ? InspectorTokens.field-bg-hover : InspectorTokens.field-bg;
    border-width: input.has-focus ? 1px : 0px;
    border-color: InspectorTokens.accent;

    changed value => {
        if !input.has-focus {
            input.text = root.value;
        }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 5px;
        spacing: 4px;
        cross-axis-alignment: center;

        if root.prefix != "": Text {
            text: root.prefix;
            color: InspectorTokens.text;
            font-size: 11px;
            font-weight: 400;
            vertical-alignment: center;
        }

        input := TextInput {
            horizontal-stretch: 1;
            text: root.value;
            single-line: true;
            wrap: no-wrap;
            color: InspectorTokens.text;
            font-size: 12px;
            font-weight: 400;
            vertical-alignment: center;
            selection-background-color: InspectorTokens.accent.with-alpha(0.28);
            text-cursor-width: 1px;

            accepted => {
                if !root.accepted(self.text) {
                    self.text = root.value;
                }
            }

            changed has-focus => {
                if !self.has-focus && self.text != root.value {
                    if !root.accepted(self.text) {
                        self.text = root.value;
                    }
                }
            }
        }

        Rectangle {
            width: 16px;
            height: 16px;

            Image {
                width: parent.width;
                height: parent.height;
                source: Icons.select-chevron;
                colorize: InspectorTokens.muted;
            }

            menu-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.menu-clicked(); }
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: text;
        clicked => { input.focus(); }
    }
}

component InspectorComboBox inherits Rectangle {
    in property <string> prefix: "";
    in property <string> value;
    in property <int> selected-index: -1;
    in property <[InspectorComboOption]> options;
    in property <bool> wide: false;
    in property <string> placeholder: "";
    callback accepted(string) -> bool;

    width: wide ? InspectorTokens.wide-width : InspectorTokens.column-width;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: fallback-popup.is-open ? InspectorTokens.panel-bg : native-menu-touch.has-hover ? InspectorTokens.field-bg-hover : InspectorTokens.field-bg;
    border-width: fallback-popup.is-open ? 1px : 0px;
    border-color: InspectorTokens.accent;
    accessible-role: AccessibleRole.combobox;
    accessible-value: root.value;
    accessible-expanded: fallback-popup.is-open;
    accessible-action-expand => {
        root.show-popup();
    }

    private property <length> row-height: 26px;
    private property <length> popup-padding: 4px;
    private property <bool> can-open: root.options.length > 0;
    private property <bool> use-native-menu:
        Platform.os == OperatingSystemType.macos || Platform.os == OperatingSystemType.windows;

    function fallback-popup-y() -> length {
        if Platform.os == OperatingSystemType.macos && root.selected-index >= 0 {
            return root.height / 2
                - root.popup-padding
                - root.selected-index * root.row-height
                - root.row-height / 2;
        }
        return root.height + 2px;
    }

    function native-menu-y() -> length {
        if Platform.os == OperatingSystemType.macos && root.selected-index >= 0 {
            return root.height / 2 - root.selected-index * root.row-height - root.row-height / 2;
        }
        return root.height;
    }

    function show-popup() {
        if !root.can-open {
            return;
        }
        if root.use-native-menu {
            native-menu.show({ x: 0px, y: root.native-menu-y() });
        } else {
            fallback-popup.show();
        }
    }

    native-menu := ContextMenuArea {
        Menu {
            for option[index] in root.options: MenuItem {
                title: option.label;
                enabled: option.enabled;
                checkable: true;
                checked: index == root.selected-index;
                activated => {
                    root.accepted(option.value);
                }
            }
        }

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 5px;
            spacing: 4px;
            cross-axis-alignment: center;

            if root.prefix != "": Text {
                text: root.prefix;
                color: InspectorTokens.text;
                font-size: 11px;
                font-weight: 400;
                vertical-alignment: center;
            }

            Text {
                horizontal-stretch: 1;
                text: root.value != "" ? root.value : root.placeholder;
                color: root.value != "" ? InspectorTokens.text : InspectorTokens.muted;
                font-size: 12px;
                font-weight: 400;
                vertical-alignment: center;
                overflow: elide;
                wrap: no-wrap;
            }

            Rectangle {
                width: 16px;
                height: 16px;

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: Icons.select-chevron;
                    colorize: InspectorTokens.muted;
                }
            }
        }

        native-menu-touch := TouchArea {
            mouse-cursor: root.can-open ? pointer : default;
            clicked => {
                root.show-popup();
            }
        }
    }

    fallback-popup := PopupWindow {
        x: 0px;
        y: root.fallback-popup-y();
        width: root.width;
        height: root.options.length * root.row-height + 2 * root.popup-padding;
        close-policy: close-on-click-outside;
        forward-focus: popup-focus;

        Rectangle {
            background: InspectorTokens.panel-bg;
            border-width: 1px;
            border-color: InspectorTokens.divider;
            border-radius: InspectorTokens.field-radius;
            drop-shadow-color: StudioTheme.dark ? #00000066 : #64748b30;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 4px;
        }

        popup-focus := FocusScope {
            key-pressed(event) => {
                if event.text == Key.Escape {
                    fallback-popup.close();
                    return accept;
                }
                return reject;
            }

            VerticalLayout {
                padding: root.popup-padding;
                alignment: start;

                for option[index] in root.options: Rectangle {
                    height: root.row-height;
                    border-radius: InspectorTokens.field-radius;
                    background: index == root.selected-index
                        ? InspectorTokens.accent.with-alpha(0.16)
                        : row-touch.has-hover && option.enabled
                        ? InspectorTokens.field-bg-hover
                        : transparent;

                    Text {
                        x: 7px;
                        width: 14px;
                        text: index == root.selected-index ? "✓" : "";
                        color: option.enabled ? InspectorTokens.accent : InspectorTokens.muted;
                        font-size: 12px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 25px;
                        width: parent.width - self.x - 8px;
                        text: option.label;
                        color: option.enabled ? InspectorTokens.text : InspectorTokens.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                        wrap: no-wrap;
                    }

                    row-touch := TouchArea {
                        enabled: option.enabled;
                        mouse-cursor: option.enabled ? pointer : default;
                        clicked => {
                            if root.accepted(option.value) {
                                fallback-popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

component InspectorColorField inherits Rectangle {
    in property <string> value;
    in property <color> swatch;
    in property <bool> wide: false;
    callback accepted(string) -> bool;

    width: wide ? InspectorTokens.wide-width : InspectorTokens.column-width;
    height: InspectorTokens.field-height;
    border-radius: InspectorTokens.field-radius;
    background: input.has-focus ? InspectorTokens.panel-bg : touch.has-hover ? InspectorTokens.field-bg-hover : InspectorTokens.field-bg;
    border-width: input.has-focus ? 1px : 0px;
    border-color: InspectorTokens.accent;

    changed value => {
        if !input.has-focus {
            input.text = root.value;
        }
    }

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        spacing: 6px;
        cross-axis-alignment: center;

        Rectangle {
            width: 11px;
            height: 11px;
            border-radius: 2.5px;
            border-width: 1px;
            border-color: InspectorTokens.muted;
            background: root.swatch;

            for row in 3: Rectangle {
                x: 2.5px + row * 2.5px;
                y: 2.5px;
                width: 1px;
                height: 6px;
                background: InspectorTokens.muted.with-alpha(0.35);
            }
            for col in 3: Rectangle {
                x: 2.5px;
                y: 2.5px + col * 2.5px;
                width: 6px;
                height: 1px;
                background: InspectorTokens.muted.with-alpha(0.35);
            }
        }

        input := TextInput {
            horizontal-stretch: 1;
            text: root.value;
            single-line: true;
            wrap: no-wrap;
            color: InspectorTokens.text;
            font-size: 12px;
            font-weight: 400;
            vertical-alignment: center;
            selection-background-color: InspectorTokens.accent.with-alpha(0.28);
            text-cursor-width: 1px;

            accepted => {
                if !root.accepted(self.text) {
                    self.text = root.value;
                }
            }

            changed has-focus => {
                if !self.has-focus && self.text != root.value {
                    if !root.accepted(self.text) {
                        self.text = root.value;
                    }
                }
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: text;
        clicked => { input.focus(); }
    }
}

