import { Palette } from "std-widgets.slint";

export global EditorTreeTokens {
    property <ColorScheme> color-scheme: Palette.color-scheme;

    out property <color> row-bg-hover: color-scheme == ColorScheme.dark ? rgba(177, 186, 196, 0.05) : rgba(208, 215, 222, 0.15);
    out property <color> row-bg-current: color-scheme == ColorScheme.dark ? rgba(110, 118, 129, 0.16) : rgba(234, 238, 242, 0.8);
    out property <color> text: color-scheme == ColorScheme.dark ? #e6edf3 : #1f2328;
    out property <color> muted-text: color-scheme == ColorScheme.dark ? #848d97 : #656d76;
    out property <color> accent: color-scheme == ColorScheme.dark ? #2f81f7 : #0969da;
    out property <color> guide: color-scheme == ColorScheme.dark ? #21262d : #d8dee4;
    out property <color> directory-icon: color-scheme == ColorScheme.dark ? #848d97 : #0969da;

    out property <length> row-height: 32px;
    out property <length> row-radius: 6px;
    out property <length> row-padding-inline: 8px;
    out property <length> content-gap: 8px;
    out property <length> toggle-width: 16px;
    out property <length> icon-size: 16px;
    out property <length> current-indicator-width: 4px;
    out property <length> current-indicator-height: 24px;
    out property <length> guide-width: 1px;
    out property <length> focus-ring-width: 2px;
}
