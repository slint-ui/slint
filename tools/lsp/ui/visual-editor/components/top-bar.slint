import { StudioTheme } from "common.slint";

export component EditorTopBar inherits Rectangle {
    height: 54px;
    background: StudioTheme.panel-bg;

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: StudioTheme.border;
    }

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 16px;
        cross-axis-alignment: center;

        HorizontalLayout {
            spacing: 10px;
            horizontal-stretch: 1;
            cross-axis-alignment: center;

            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 7px;
                background: StudioTheme.accent;

                Text {
                    text: "S";
                    color: white;
                    font-size: 15px;
                    font-weight: 900;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "Slinterface Pro";
                color: StudioTheme.text;
                font-size: 15px;
                font-weight: 800;
                vertical-alignment: center;
            }

            Rectangle {
                width: 1px;
                height: 24px;
                background: StudioTheme.soft-border;
            }

            Text {
                text: "Mobile / main.slint";
                color: StudioTheme.muted;
                font-size: 13px;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 82px;
            height: 34px;
            border-radius: 17px;
            background: StudioTheme.panel-subtle;
            border-width: 1px;
            border-color: StudioTheme.border;

            Text {
                text: "100%";
                color: StudioTheme.text;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
