import { EditorMetrics, StudioTheme } from "common.slint";

export component EditorTopBar inherits Rectangle {
    height: EditorMetrics.top-bar-height;
    background: StudioTheme.panel-bg;

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: StudioTheme.border;
    }

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 16px;
        alignment: end;
        cross-axis-alignment: center;

        Rectangle {
            width: 82px;
            height: 34px;
            border-radius: 17px;
            background: StudioTheme.panel-subtle;
            border-width: 1px;
            border-color: StudioTheme.border;

            Text {
                text: "100%";
                color: StudioTheme.text;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    HorizontalLayout {
        alignment: center;
        cross-axis-alignment: center;

        Rectangle {
            width: 1px;
            height: 24px;
            background: StudioTheme.soft-border;
        }

        Text {
            text: "Mobile / main.slint";
            color: StudioTheme.muted;
            font-size: 13px;
            vertical-alignment: center;
        }
    }
}
