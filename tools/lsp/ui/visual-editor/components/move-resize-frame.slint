import { CanvasCorner, EditorMetrics, StudioTheme } from "common.slint";

export component MoveResizeFrame inherits Rectangle {
    in property <bool> active;
    in property <bool> shift-pressed: false;
    in property <angle> rotation: 0deg;
    out property <bool> frame-hover: move-touch.has-hover;
    out property <bool> move-pressed: move-touch.pressed;
    out property <bool> move-dragging: false;
    out property <bool> rotating: false;
    out property <bool> rotation-tooltip-visible: false;
    out property <Point> rotation-tooltip-position: { x: 0px, y: 0px };
    out property <angle> rotation-tooltip-value: 0deg;
    private property <length> drag-threshold: 2px;
    private property <bool> resize-pressed: false;
    private property <bool> resize-shift-pressed: false;
    private property <CanvasCorner> resize-corner: CanvasCorner.top-left;
    private property <Size> resize-start-size: { width: 0px, height: 0px };
    private property <Point> resize-start-center: { x: 0px, y: 0px };
    private property <Point> resize-start-pointer: { x: 0px, y: 0px };
    private property <Point> resize-fixed-corner: { x: 0px, y: 0px };
    private property <Point> free-resize-position: { x: 0px, y: 0px };
    private property <Size> free-resize-size: { width: 0px, height: 0px };
    callback selected();
    callback interaction-started();
    callback moved-to(Point);
    callback resized-to(CanvasCorner, Point, Size);
    callback rotated-to(angle);

    public pure function corner-on-left(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-left || corner == CanvasCorner.bottom-left;
    }

    public pure function corner-on-top(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-left || corner == CanvasCorner.top-right;
    }

    pure function corner-resize-cursor-is-forward-diagonal(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-left || corner == CanvasCorner.bottom-right;
    }

    pure function rotation-cursor-is-forward-diagonal(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-right || corner == CanvasCorner.bottom-left;
    }

    pure function resize-handle-x(corner: CanvasCorner) -> length {
        return root.corner-on-left(corner)
            ? -EditorMetrics.selection-handle-size / 2
            : root.width - EditorMetrics.selection-handle-size / 2;
    }

    pure function resize-handle-y(corner: CanvasCorner) -> length {
        return root.corner-on-top(corner)
            ? -EditorMetrics.selection-handle-size / 2
            : root.height - EditorMetrics.selection-handle-size / 2;
    }

    pure function rotation-zone-x(corner: CanvasCorner) -> length {
        return root.corner-on-left(corner)
            ? -EditorMetrics.selection-handle-size / 2 - EditorMetrics.rotation-zone-gap - EditorMetrics.rotation-zone-size
            : root.width + EditorMetrics.selection-handle-size / 2 + EditorMetrics.rotation-zone-gap;
    }

    pure function rotation-zone-y(corner: CanvasCorner) -> length {
        return root.corner-on-top(corner)
            ? -EditorMetrics.selection-handle-size / 2 - EditorMetrics.rotation-zone-gap - EditorMetrics.rotation-zone-size
            : root.height + EditorMetrics.selection-handle-size / 2 + EditorMetrics.rotation-zone-gap;
    }

    pure function local-to-parent-x(local-x: length, local-y: length) -> length {
        let from-center-x = local-x - root.width / 2;
        let from-center-y = local-y - root.height / 2;
        return root.x + root.width / 2 + from-center-x * root.rotation.cos() - from-center-y * root.rotation.sin();
    }

    pure function local-to-parent-y(local-x: length, local-y: length) -> length {
        let from-center-x = local-x - root.width / 2;
        let from-center-y = local-y - root.height / 2;
        return root.y + root.height / 2 + from-center-x * root.rotation.sin() + from-center-y * root.rotation.cos();
    }

    pure function pointer-angle(local-x: length, local-y: length) -> angle {
        return atan2((local-y - root.height / 2) / 1px, (local-x - root.width / 2) / 1px) + root.rotation;
    }

    pure function snapped-rotation(value: angle) -> angle {
        return (value / 15deg).round() * 15deg;
    }

    pure function corner-local-x-sign(corner: CanvasCorner) -> float {
        return root.corner-on-left(corner) ? -1 : 1;
    }

    pure function corner-local-y-sign(corner: CanvasCorner) -> float {
        return root.corner-on-top(corner) ? -1 : 1;
    }

    pure function opposite-corner-local-x-sign(corner: CanvasCorner) -> float {
        return -root.corner-local-x-sign(corner);
    }

    pure function opposite-corner-local-y-sign(corner: CanvasCorner) -> float {
        return -root.corner-local-y-sign(corner);
    }

    pure function proportional-resizing() -> bool {
        return root.resize-pressed && root.resize-shift-pressed;
    }

    function store-free-resize-target(pointer: Point) {
        let screen-delta-x = pointer.x - root.resize-start-pointer.x;
        let screen-delta-y = pointer.y - root.resize-start-pointer.y;
        let delta-x = screen-delta-x * root.rotation.cos() + screen-delta-y * root.rotation.sin();
        let delta-y = -screen-delta-x * root.rotation.sin() + screen-delta-y * root.rotation.cos();
        let target-width = root.corner-on-left(root.resize-corner)
            ? root.resize-start-size.width - delta-x
            : root.resize-start-size.width + delta-x;
        let target-height = root.corner-on-top(root.resize-corner)
            ? root.resize-start-size.height - delta-y
            : root.resize-start-size.height + delta-y;
        root.store-free-resize-target-from-size({ width: target-width, height: target-height });
    }

    function store-free-resize-target-from-size(target-size: Size) {
        let opposite-x = root.opposite-corner-local-x-sign(root.resize-corner);
        let opposite-y = root.opposite-corner-local-y-sign(root.resize-corner);
        let target-center-x = root.resize-fixed-corner.x - opposite-x * target-size.width / 2 * root.rotation.cos()
            + opposite-y * target-size.height / 2 * root.rotation.sin();
        let target-center-y = root.resize-fixed-corner.y - opposite-x * target-size.width / 2 * root.rotation.sin()
            - opposite-y * target-size.height / 2 * root.rotation.cos();
        root.free-resize-position = {
            x: target-center-x - target-size.width / 2,
            y: target-center-y - target-size.height / 2,
        };
        root.free-resize-size = target-size;
    }

    function emit-resize-target() {
        if root.proportional-resizing() {
            let side = max(max(root.free-resize-size.width, root.free-resize-size.height), 80px);
            let opposite-x = root.opposite-corner-local-x-sign(root.resize-corner);
            let opposite-y = root.opposite-corner-local-y-sign(root.resize-corner);
            let target-center-x = root.resize-fixed-corner.x - opposite-x * side / 2 * root.rotation.cos()
                + opposite-y * side / 2 * root.rotation.sin();
            let target-center-y = root.resize-fixed-corner.y - opposite-x * side / 2 * root.rotation.sin()
                - opposite-y * side / 2 * root.rotation.cos();
            root.resized-to(
                root.resize-corner,
                { x: target-center-x - side / 2, y: target-center-y - side / 2 },
                { width: side, height: side },
            );
        } else {
            root.resized-to(root.resize-corner, root.free-resize-position, root.free-resize-size);
        }
    }

    changed shift-pressed => {
        if root.resize-pressed {
            root.resize-shift-pressed = root.shift-pressed;
            root.emit-resize-target();
        }
    }

    rotated := Rectangle {
        width: root.width;
        height: root.height;
        transform-origin: { x: root.width / 2, y: root.height / 2 };
        transform-rotation: root.rotation;

        move-touch := TouchArea {
            width: root.width;
            height: root.height;
            mouse-cursor: move;
            private property <Point> pointer-press: { x: 0px, y: 0px };
            private property <Point> start-position: { x: 0px, y: 0px };

            changed pressed => {
                if self.pressed {
                    root.move-dragging = false;
                    self.pointer-press = {
                        x: self.absolute-position.x + self.mouse-x,
                        y: self.absolute-position.y + self.mouse-y,
                    };
                    self.start-position = { x: root.x, y: root.y };
                    root.selected();
                } else {
                    root.move-dragging = false;
                }
            }

            moved => {
                let pointer = {
                    x: self.absolute-position.x + self.mouse-x,
                    y: self.absolute-position.y + self.mouse-y,
                };
                let delta-x = pointer.x - self.pointer-press.x;
                let delta-y = pointer.y - self.pointer-press.y;
                let moved-far-enough = delta-x.abs() >= root.drag-threshold
                    || delta-y.abs() >= root.drag-threshold;
                if self.pressed && moved-far-enough {
                    root.move-dragging = true;
                }
                if root.move-dragging {
                    root.moved-to({
                        x: ((self.start-position.x + delta-x) / 1px).round() * 1px,
                        y: ((self.start-position.y + delta-y) / 1px).round() * 1px,
                    });
                }
            }

            clicked => {
                root.selected();
            }
        }

        @children

        if root.active && !root.move-dragging: Rectangle {
            width: root.width;
            height: root.height;
            border-width: 1px;
            border-color: StudioTheme.accent-strong;

        if root.proportional-resizing(): Path {
            stroke: StudioTheme.accent-strong;
            stroke-width: 1phx;
            viewbox-width: root.width / 1px;
            viewbox-height: root.height / 1px;

            MoveTo {
                x: root.corner-on-left(root.resize-corner) ? 0 : parent.viewbox-width;
                y: root.corner-on-top(root.resize-corner) ? 0 : parent.viewbox-height;
            }

            LineTo {
                x: root.corner-on-left(root.resize-corner) ? parent.viewbox-width : 0;
                y: root.corner-on-top(root.resize-corner) ? parent.viewbox-height : 0;
            }
        }

        for corner in [
            CanvasCorner.top-left,
            CanvasCorner.top-right,
            CanvasCorner.bottom-right,
            CanvasCorner.bottom-left,
        ]: Rectangle {
            x: root.rotation-zone-x(corner);
            y: root.rotation-zone-y(corner);
            width: EditorMetrics.rotation-zone-size;
            height: EditorMetrics.rotation-zone-size;
            background: transparent;

            TouchArea {
                mouse-cursor: root.rotation-cursor-is-forward-diagonal(corner) ? nwse-resize : nesw-resize;
                private property <bool> event-shift-pressed: false;
                private property <angle> start-rotation;
                private property <angle> start-pointer-angle;

                pointer-event(event) => {
                    self.event-shift-pressed = event.modifiers.shift;
                }

                changed pressed => {
                    if self.pressed {
                        let local-x = parent.x + self.mouse-x;
                        let local-y = parent.y + self.mouse-y;
                        root.selected();
                        root.interaction-started();
                        root.rotating = true;
                        root.rotation-tooltip-visible = true;
                        self.start-rotation = root.rotation;
                        self.start-pointer-angle = root.pointer-angle(local-x, local-y);
                        root.rotation-tooltip-position = {
                            x: root.local-to-parent-x(local-x, local-y),
                            y: root.local-to-parent-y(local-x, local-y),
                        };
                        root.rotation-tooltip-value = root.rotation;
                    } else {
                        root.rotating = false;
                        root.rotation-tooltip-visible = false;
                    }
                }

                moved => {
                    let local-x = parent.x + self.mouse-x;
                    let local-y = parent.y + self.mouse-y;
                    let angle = self.start-rotation + root.pointer-angle(local-x, local-y) - self.start-pointer-angle;
                    let target-angle = (root.shift-pressed || self.event-shift-pressed) ? root.snapped-rotation(angle) : angle;
                    root.rotation-tooltip-visible = true;
                    root.rotation-tooltip-position = {
                        x: root.local-to-parent-x(local-x, local-y),
                        y: root.local-to-parent-y(local-x, local-y),
                    };
                    root.rotation-tooltip-value = target-angle;
                    root.rotated-to(target-angle);
                }
            }
        }

        if !root.rotating: Rectangle {
            width: root.width;
            height: root.height;
            for corner in [
                CanvasCorner.top-left,
                CanvasCorner.top-right,
                CanvasCorner.bottom-right,
                CanvasCorner.bottom-left,
            ]: Rectangle {
                x: root.resize-handle-x(corner);
                y: root.resize-handle-y(corner);
                width: EditorMetrics.selection-handle-size;
                height: EditorMetrics.selection-handle-size;
                border-radius: 2px;
                background: white;
                border-width: 2px;
                border-color: StudioTheme.accent-strong;

                TouchArea {
                    mouse-cursor: root.corner-resize-cursor-is-forward-diagonal(corner) ? nwse-resize : nesw-resize;
                    private property <bool> event-shift-pressed: false;

                    pointer-event(event) => {
                        self.event-shift-pressed = event.modifiers.shift;
                        if root.resize-pressed {
                            root.resize-shift-pressed = event.modifiers.shift;
                            root.emit-resize-target();
                        }
                    }

                    changed pressed => {
                        if self.pressed {
                            let pointer = {
                                x: self.absolute-position.x + self.mouse-x,
                                y: self.absolute-position.y + self.mouse-y,
                            };
                            let opposite-x = root.opposite-corner-local-x-sign(corner);
                            let opposite-y = root.opposite-corner-local-y-sign(corner);
                            let local-opposite-x = opposite-x * root.width / 2;
                            let local-opposite-y = opposite-y * root.height / 2;

                            root.selected();
                            root.interaction-started();
                            root.resize-corner = corner;
                            root.resize-pressed = true;
                            root.resize-shift-pressed = root.shift-pressed || self.event-shift-pressed;
                            root.resize-start-size = { width: root.width, height: root.height };
                            root.resize-start-center = { x: root.x + root.width / 2, y: root.y + root.height / 2 };
                            root.resize-start-pointer = pointer;
                            root.resize-fixed-corner = {
                                x: root.resize-start-center.x + local-opposite-x * root.rotation.cos() - local-opposite-y * root.rotation.sin(),
                                y: root.resize-start-center.y + local-opposite-x * root.rotation.sin() + local-opposite-y * root.rotation.cos(),
                            };
                            root.store-free-resize-target(pointer);
                            root.emit-resize-target();
                        } else {
                            root.resize-pressed = false;
                            root.resize-shift-pressed = false;
                        }
                    }

                    moved => {
                        root.store-free-resize-target({
                            x: self.absolute-position.x + self.mouse-x,
                            y: self.absolute-position.y + self.mouse-y,
                        });
                        root.emit-resize-target();
                    }
                }
            }
        }
    }
    }
}
