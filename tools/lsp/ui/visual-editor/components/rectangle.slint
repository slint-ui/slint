import { CanvasCorner, EditorMetrics, StudioTheme } from "common.slint";
import { MoveResizeFrame } from "move-resize-frame.slint";

export component RectangleOnCanvas inherits MoveResizeFrame {
    in property <length> top-left-radius;
    in property <length> top-right-radius;
    in property <length> bottom-right-radius;
    in property <length> bottom-left-radius;
    callback radius-changed(CanvasCorner, length, bool);

    width: 240px;
    height: 96px;

    function radius-from-handle(corner: CanvasCorner, pointer-x: length, pointer-y: length) -> length {
        let from-left = root.corner-on-left(corner) ? pointer-x : root.width - pointer-x;
        let from-top = root.corner-on-top(corner) ? pointer-y : root.height - pointer-y;
        return (min(from-left, from-top) - EditorMetrics.radius-handle-inset).clamp(0px, root.max-corner-radius());
    }

    function max-corner-radius() -> length {
        return min(root.width, root.height) / 2;
    }

    function corner-radius(corner: CanvasCorner) -> length {
        if corner == CanvasCorner.top-left {
            return root.top-left-radius;
        }
        if corner == CanvasCorner.top-right {
            return root.top-right-radius;
        }
        if corner == CanvasCorner.bottom-right {
            return root.bottom-right-radius;
        }
        return root.bottom-left-radius;
    }

    Rectangle {
        border-top-left-radius: root.top-left-radius;
        border-top-right-radius: root.top-right-radius;
        border-bottom-right-radius: root.bottom-right-radius;
        border-bottom-left-radius: root.bottom-left-radius;
        background: StudioTheme.object-bg;
        border-width: root.active ? 2px : 1px;
        border-color: root.active ? StudioTheme.accent-strong : StudioTheme.object-border;
    }

    for corner in [
        CanvasCorner.top-left,
        CanvasCorner.top-right,
        CanvasCorner.bottom-right,
        CanvasCorner.bottom-left,
    ]: Rectangle {
        property <length> radius: root.corner-radius(corner);
        property <length> handle-center-x: root.corner-on-left(corner)
            ? EditorMetrics.radius-handle-inset + radius
            : root.width - EditorMetrics.radius-handle-inset - radius;
        property <length> handle-center-y: root.corner-on-top(corner)
            ? EditorMetrics.radius-handle-inset + radius
            : root.height - EditorMetrics.radius-handle-inset - radius;

        visible: root.active;
        x: handle-center-x - EditorMetrics.radius-handle-size / 2;
        y: handle-center-y - EditorMetrics.radius-handle-size / 2;
        width: EditorMetrics.radius-handle-size;
        height: EditorMetrics.radius-handle-size;
        border-radius: EditorMetrics.radius-handle-size / 2;
        background: #00000000;
        border-width: 1px;
        border-color: StudioTheme.accent-strong;

        TouchArea {
            mouse-cursor: pointer;
            private property <bool> shift-mode: false;

            pointer-event(event) => {
                self.shift-mode = event.modifiers.shift;
            }

            changed pressed => {
                if self.pressed {
                    root.selected();
                }
            }

            moved => {
                let pointer-x = parent.x + self.mouse-x;
                let pointer-y = parent.y + self.mouse-y;
                root.radius-changed(corner, root.radius-from-handle(corner, pointer-x, pointer-y), self.shift-mode);
            }
        }
    }
}
