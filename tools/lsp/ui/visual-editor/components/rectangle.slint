import { StudioTheme } from "common.slint";
import { MoveResizeFrame } from "move-resize-frame.slint";

export component RectangleOnCanvas inherits Rectangle {
    in property <bool> active;
    in property <length> top-left-radius;
    in property <length> top-right-radius;
    in property <length> bottom-right-radius;
    in property <length> bottom-left-radius;
    callback selected();
    callback moved-to(length, length);
    callback resized-to(int, length, length, length, length);
    callback radius-changed(int, length, bool);

    width: 240px;
    height: 96px;

    function radius-from-handle(corner: int, pointer-x: length, pointer-y: length) -> length {
        let from-left = corner == 0 || corner == 3 ? pointer-x : root.width - pointer-x;
        let from-top = corner == 0 || corner == 1 ? pointer-y : root.height - pointer-y;
        return (min(from-left, from-top) - 10px).clamp(0px, root.max-corner-radius());
    }

    function max-corner-radius() -> length {
        return min(root.width, root.height) / 2;
    }

    function corner-radius(corner: int) -> length {
        if corner == 0 {
            return root.top-left-radius;
        }
        if corner == 1 {
            return root.top-right-radius;
        }
        if corner == 2 {
            return root.bottom-right-radius;
        }
        return root.bottom-left-radius;
    }

    MoveResizeFrame {
        width: root.width;
        height: root.height;
        active: root.active;
        selected => { root.selected(); }
        moved-to(x, y) => { root.moved-to(root.x + x, root.y + y); }
        resized-to(corner, x, y, width, height) => { root.resized-to(corner, root.x + x, root.y + y, width, height); }

        Rectangle {
            border-top-left-radius: root.top-left-radius;
            border-top-right-radius: root.top-right-radius;
            border-bottom-right-radius: root.bottom-right-radius;
            border-bottom-left-radius: root.bottom-left-radius;
            background: #fde68a;
            border-width: root.active ? 2px : 1px;
            border-color: root.active ? StudioTheme.accent-strong : #f59e0b;
        }

        for corner in 4: Rectangle {
            property <bool> on-left: corner == 0 || corner == 3;
            property <bool> on-top: corner == 0 || corner == 1;
            property <length> radius: root.corner-radius(corner);
            property <length> handle-center-x: on-left ? 10px + radius : root.width - 10px - radius;
            property <length> handle-center-y: on-top ? 10px + radius : root.height - 10px - radius;

            visible: root.active;
            x: handle-center-x - 5px;
            y: handle-center-y - 5px;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: #00000000;
            border-width: 1px;
            border-color: StudioTheme.accent-strong;

            TouchArea {
                mouse-cursor: pointer;
                private property <bool> shift-mode: false;

                pointer-event(event) => {
                    self.shift-mode = event.modifiers.shift;
                }

                changed pressed => {
                    if self.pressed {
                        root.selected();
                    }
                }

                moved => {
                    let pointer-x = parent.x + self.mouse-x;
                    let pointer-y = parent.y + self.mouse-y;
                    root.radius-changed(corner, root.radius-from-handle(corner, pointer-x, pointer-y), self.shift-mode);
                }
            }
        }
    }
}
