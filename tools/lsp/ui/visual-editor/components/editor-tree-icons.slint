export global EditorTreeIcons {
    out property <image> chevron-down: @image-url("../../assets/octicons/chevron-down.svg");
    out property <image> chevron-right: @image-url("../../assets/octicons/chevron-right.svg");
    out property <image> default-item: @image-url("../../assets/octicons/screen-normal.svg");
    out property <image> image: @image-url("../../assets/octicons/image.svg");
    out property <image> rectangle: @image-url("../../assets/octicons/screen-full.svg");
    out property <image> text: @image-url("../../assets/octicons/typography.svg");
}
