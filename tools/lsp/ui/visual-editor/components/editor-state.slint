import {
    AppState, CanvasCorner, CanvasOrientation, CanvasSelectionKind, EditorMetrics, LeftPaneMode,
    PrototypeComponentKind,
} from "common.slint";

export component EditorState inherits Rectangle {
    in property <length> window-width;
    in property <length> window-height;

    in-out property <CanvasOrientation> canvas-orientation: CanvasOrientation.portrait;
    in-out property <LeftPaneMode> left-mode: LeftPaneMode.files;
    in-out property <CanvasSelectionKind> selection: CanvasSelectionKind.artboard;
    in-out property <PrototypeComponentKind> placed-kind: PrototypeComponentKind.none;
    out property <bool> canvas-drop-hover: false;
    in-out property <string> search-text: "";

    out property <length> canvas-drop-x: 0px;
    out property <length> canvas-drop-y: 0px;
    out property <length> placed-x: 54px;
    out property <length> placed-y: 196px;
    out property <length> rectangle-width: 240px;
    out property <length> rectangle-height: 96px;
    out property <length> rectangle-top-left-radius: 12px;
    out property <length> rectangle-top-right-radius: 12px;
    out property <length> rectangle-bottom-right-radius: 12px;
    out property <length> rectangle-bottom-left-radius: 12px;
    out property <length> text-width: 280px;
    out property <length> text-height: 32px;
    out property <length> image-width: 282px;
    out property <length> image-height: 168px;

    width: 0px;
    height: 0px;

    public function open-project() {
        root.left-mode = LeftPaneMode.library;
        root.selection = CanvasSelectionKind.artboard;
    }

    function place-component(kind: PrototypeComponentKind) {
        root.placed-kind = kind;
        if kind == PrototypeComponentKind.rectangle {
            root.selection = CanvasSelectionKind.rectangle;
            root.rectangle-width = root.default-component-width(kind);
            root.rectangle-height = root.default-component-height(kind);
            root.set-all-rectangle-radii(12px);
        } else if kind == PrototypeComponentKind.text {
            root.selection = CanvasSelectionKind.text;
            root.text-width = root.default-component-width(kind);
            root.text-height = root.default-component-height(kind);
        } else if kind == PrototypeComponentKind.image {
            root.selection = CanvasSelectionKind.image;
            root.image-width = root.default-component-width(kind);
            root.image-height = root.default-component-height(kind);
        }
    }

    function place-component-at(kind: PrototypeComponentKind, drop-x: length, drop-y: length) {
        root.place-component(kind);
        if kind == PrototypeComponentKind.rectangle {
            root.placed-x = drop-x.clamp(0px, root.phone-width() - root.rectangle-width);
            root.placed-y = drop-y.clamp(0px, root.phone-height() - root.rectangle-height);
        } else if kind == PrototypeComponentKind.text {
            root.placed-x = drop-x.clamp(0px, root.phone-width() - root.text-width);
            root.placed-y = drop-y.clamp(0px, root.phone-height() - root.text-height);
        } else if kind == PrototypeComponentKind.image {
            root.placed-x = drop-x.clamp(0px, root.phone-width() - root.image-width);
            root.placed-y = drop-y.clamp(0px, root.phone-height() - root.image-height);
        }
    }

    function clamp-elements-to-phone() {
        if root.placed-kind == PrototypeComponentKind.rectangle {
            root.rectangle-width = root.rectangle-width.clamp(80px, root.phone-width());
            root.rectangle-height = root.rectangle-height.clamp(44px, root.phone-height());
            root.placed-x = root.placed-x.clamp(0px, root.phone-width() - root.rectangle-width);
            root.placed-y = root.placed-y.clamp(0px, root.phone-height() - root.rectangle-height);
            root.clamp-rectangle-radii();
        } else if root.placed-kind == PrototypeComponentKind.text {
            root.text-width = root.text-width.clamp(80px, root.phone-width());
            root.text-height = root.text-height.clamp(32px, root.phone-height());
            root.placed-x = root.placed-x.clamp(0px, root.phone-width() - root.text-width);
            root.placed-y = root.placed-y.clamp(0px, root.phone-height() - root.text-height);
        } else if root.placed-kind == PrototypeComponentKind.image {
            root.image-width = root.image-width.clamp(80px, root.phone-width());
            root.image-height = root.image-height.clamp(44px, root.phone-height());
            root.placed-x = root.placed-x.clamp(0px, root.phone-width() - root.image-width);
            root.placed-y = root.placed-y.clamp(0px, root.phone-height() - root.image-height);
        }
    }

    public function set-canvas-orientation(orientation: CanvasOrientation) {
        root.canvas-orientation = orientation;
        root.clamp-elements-to-phone();
    }

    function canvas-width() -> length {
        return root.window-width - EditorMetrics.left-pane-width - EditorMetrics.inspector-pane-width;
    }

    function canvas-height() -> length {
        return root.window-height - EditorMetrics.top-bar-height - EditorMetrics.canvas-toolbar-height;
    }

    public pure function phone-width() -> length {
        return root.canvas-orientation == CanvasOrientation.portrait
            ? EditorMetrics.phone-portrait-width
            : EditorMetrics.phone-landscape-width;
    }

    public pure function phone-height() -> length {
        return root.canvas-orientation == CanvasOrientation.portrait
            ? EditorMetrics.phone-portrait-height
            : EditorMetrics.phone-landscape-height;
    }

    function phone-canvas-top() -> length {
        return max(40px, (root.canvas-height() - root.phone-height()) / 2);
    }

    function phone-left() -> length {
        return EditorMetrics.left-pane-width + (root.canvas-width() - root.phone-width()) / 2;
    }

    function phone-top() -> length {
        return EditorMetrics.top-bar-height + EditorMetrics.canvas-toolbar-height + root.phone-canvas-top();
    }

    function pointer-inside-phone(window-x: length, window-y: length) -> bool {
        return window-x >= root.phone-left()
            && window-x <= root.phone-left() + root.phone-width()
            && window-y >= root.phone-top()
            && window-y <= root.phone-top() + root.phone-height();
    }

    pure function default-component-width(kind: PrototypeComponentKind) -> length {
        if kind == PrototypeComponentKind.rectangle {
            return 160px;
        }
        if kind == PrototypeComponentKind.image {
            return 160px;
        }
        if kind == PrototypeComponentKind.text {
            return 220px;
        }
        return 96px;
    }

    pure function default-component-height(kind: PrototypeComponentKind) -> length {
        if kind == PrototypeComponentKind.rectangle {
            return 64px;
        }
        if kind == PrototypeComponentKind.image {
            return 96px;
        }
        if kind == PrototypeComponentKind.text {
            return 40px;
        }
        return 48px;
    }

    pure function drag-preview-pointer-gap() -> length {
        return 12px;
    }

    pure function drag-preview-y-offset(kind: PrototypeComponentKind) -> length {
        if kind == PrototypeComponentKind.text {
            return 120px;
        }
        if kind == PrototypeComponentKind.rectangle {
            return 96px;
        }
        return root.default-component-height(kind) + root.drag-preview-pointer-gap();
    }

    pure function corner-on-left(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-left || corner == CanvasCorner.bottom-left;
    }

    pure function corner-on-top(corner: CanvasCorner) -> bool {
        return corner == CanvasCorner.top-left || corner == CanvasCorner.top-right;
    }

    public function update-visual-drag(kind: PrototypeComponentKind, window-x: length, window-y: length) {
        AppState.dragging-kind = kind;
        AppState.drag-x = window-x;
        AppState.drag-y = window-y;
        AppState.drag-preview-width = root.default-component-width(kind);
        AppState.drag-preview-height = root.default-component-height(kind);
        AppState.drag-preview-x = window-x - AppState.drag-preview-width - root.drag-preview-pointer-gap();
        AppState.drag-preview-y = window-y - root.drag-preview-y-offset(kind);
        root.canvas-drop-x = AppState.drag-preview-x - root.phone-left();
        root.canvas-drop-y = AppState.drag-preview-y - root.phone-top();
        root.canvas-drop-hover = root.pointer-inside-phone(window-x, window-y);
    }

    public function finish-visual-drag(kind: PrototypeComponentKind, window-x: length, window-y: length) {
        root.update-visual-drag(kind, window-x, window-y);
        if root.canvas-drop-hover {
            root.place-component-at(kind, root.canvas-drop-x, root.canvas-drop-y);
        }
        AppState.dragging-kind = PrototypeComponentKind.none;
        root.canvas-drop-hover = false;
    }

    public pure function rectangle-radius-label() -> string {
        if root.rectangle-top-left-radius == root.rectangle-top-right-radius
            && root.rectangle-top-left-radius == root.rectangle-bottom-right-radius
            && root.rectangle-top-left-radius == root.rectangle-bottom-left-radius {
            return "\{root.rectangle-top-left-radius / 1px}";
        }
        return "Mixed";
    }

    public function move-rectangle-to(x: length, y: length) {
        root.selection = CanvasSelectionKind.rectangle;
        root.placed-x = x.clamp(0px, root.phone-width() - root.rectangle-width);
        root.placed-y = y.clamp(0px, root.phone-height() - root.rectangle-height);
    }

    public function resize-rectangle-to(corner: CanvasCorner, x: length, y: length, width: length, height: length) {
        root.selection = CanvasSelectionKind.rectangle;
        if root.corner-on-left(corner) {
            root.rectangle-width = width.clamp(80px, x + width);
            root.placed-x = (x + width - root.rectangle-width).clamp(0px, root.phone-width() - root.rectangle-width);
        } else {
            root.placed-x = x.clamp(0px, root.phone-width() - 80px);
            root.rectangle-width = width.clamp(80px, root.phone-width() - root.placed-x);
        }
        if root.corner-on-top(corner) {
            root.rectangle-height = height.clamp(44px, y + height);
            root.placed-y = (y + height - root.rectangle-height).clamp(0px, root.phone-height() - root.rectangle-height);
        } else {
            root.placed-y = y.clamp(0px, root.phone-height() - 44px);
            root.rectangle-height = height.clamp(44px, root.phone-height() - root.placed-y);
        }
        root.clamp-rectangle-radii();
    }

    public function update-rectangle-radius(corner: CanvasCorner, radius: length, single-corner: bool) {
        root.selection = CanvasSelectionKind.rectangle;
        if single-corner {
            root.set-rectangle-corner-radius(corner, radius);
        } else {
            root.set-all-rectangle-radii(radius);
        }
    }

    function rectangle-max-radius() -> length {
        return min(root.rectangle-width, root.rectangle-height) / 2;
    }

    function set-rectangle-corner-radius(corner: CanvasCorner, value: length) {
        let radius = value.clamp(0px, root.rectangle-max-radius());
        if corner == CanvasCorner.top-left {
            root.rectangle-top-left-radius = radius;
        } else if corner == CanvasCorner.top-right {
            root.rectangle-top-right-radius = radius;
        } else if corner == CanvasCorner.bottom-right {
            root.rectangle-bottom-right-radius = radius;
        } else {
            root.rectangle-bottom-left-radius = radius;
        }
    }

    function set-all-rectangle-radii(value: length) {
        let radius = value.clamp(0px, root.rectangle-max-radius());
        root.rectangle-top-left-radius = radius;
        root.rectangle-top-right-radius = radius;
        root.rectangle-bottom-right-radius = radius;
        root.rectangle-bottom-left-radius = radius;
    }

    function clamp-rectangle-radii() {
        root.rectangle-top-left-radius = root.rectangle-top-left-radius.clamp(0px, root.rectangle-max-radius());
        root.rectangle-top-right-radius = root.rectangle-top-right-radius.clamp(0px, root.rectangle-max-radius());
        root.rectangle-bottom-right-radius = root.rectangle-bottom-right-radius.clamp(0px, root.rectangle-max-radius());
        root.rectangle-bottom-left-radius = root.rectangle-bottom-left-radius.clamp(0px, root.rectangle-max-radius());
    }

    public function move-text-to(x: length, y: length) {
        root.selection = CanvasSelectionKind.text;
        root.placed-x = x.clamp(0px, root.phone-width() - root.text-width);
        root.placed-y = y.clamp(0px, root.phone-height() - root.text-height);
    }

    public function resize-text-to(corner: CanvasCorner, x: length, y: length, width: length, height: length) {
        root.selection = CanvasSelectionKind.text;
        if root.corner-on-left(corner) {
            root.text-width = width.clamp(80px, x + width);
            root.placed-x = (x + width - root.text-width).clamp(0px, root.phone-width() - root.text-width);
        } else {
            root.placed-x = x.clamp(0px, root.phone-width() - 80px);
            root.text-width = width.clamp(80px, root.phone-width() - root.placed-x);
        }
        if root.corner-on-top(corner) {
            root.text-height = height.clamp(32px, y + height);
            root.placed-y = (y + height - root.text-height).clamp(0px, root.phone-height() - root.text-height);
        } else {
            root.placed-y = y.clamp(0px, root.phone-height() - 32px);
            root.text-height = height.clamp(32px, root.phone-height() - root.placed-y);
        }
    }

    public function move-image-to(x: length, y: length) {
        root.selection = CanvasSelectionKind.image;
        root.placed-x = x.clamp(0px, root.phone-width() - root.image-width);
        root.placed-y = y.clamp(0px, root.phone-height() - root.image-height);
    }

    public function resize-image-to(corner: CanvasCorner, x: length, y: length, width: length, height: length) {
        root.selection = CanvasSelectionKind.image;
        if root.corner-on-left(corner) {
            root.image-width = width.clamp(80px, x + width);
            root.placed-x = (x + width - root.image-width).clamp(0px, root.phone-width() - root.image-width);
        } else {
            root.placed-x = x.clamp(0px, root.phone-width() - 80px);
            root.image-width = width.clamp(80px, root.phone-width() - root.placed-x);
        }
        if root.corner-on-top(corner) {
            root.image-height = height.clamp(44px, y + height);
            root.placed-y = (y + height - root.image-height).clamp(0px, root.phone-height() - root.image-height);
        } else {
            root.placed-y = y.clamp(0px, root.phone-height() - 44px);
            root.image-height = height.clamp(44px, root.phone-height() - root.placed-y);
        }
    }
}
