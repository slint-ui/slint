import { Palette } from "std-widgets.slint";

export enum LeftPaneMode {
    files,
    library,
}

export enum CanvasOrientation {
    portrait,
    landscape,
}

export enum PrototypeComponentKind {
    none,
    rectangle,
    text,
    image,
}

export enum CanvasSelectionKind {
    none,
    artboard,
    rectangle,
    text,
    image,
}

export enum CanvasCorner {
    top-left,
    top-right,
    bottom-right,
    bottom-left,
}

export global StudioTheme {
    out property <bool> dark: Palette.color-scheme == ColorScheme.dark;
    out property <color> app-bg: dark ? #2c2c2c : #f6f8fa;
    out property <color> panel-bg: dark ? #2c2c2c : #ffffff;
    out property <color> panel-subtle: dark ? #383838 : #f6f8fa;
    out property <color> text: dark ? #f1f1f1 : #1f2328;
    out property <color> muted: dark ? #b7b7b7 : #6e7781;
    out property <color> border: dark ? #494949 : #d0d7de;
    out property <color> soft-border: dark ? #3f3f3f : #eaeef2;
    out property <color> accent: #0d99ff;
    out property <color> accent-strong: #52aeff;
    out property <color> canvas: dark ? #1f1f1f : #eef2f7;
    out property <color> phone-bg: dark ? #f7f8fb : #ffffff;
    out property <color> phone-text: #20252d;
    out property <color> object-bg: #ffffff;
    out property <color> object-subtle: #f6f8fa;
    out property <color> object-border: #d0d7de;
    out property <color> object-muted: #6e7781;
}

export global EditorMetrics {
    out property <length> left-pane-width: 286px;
    out property <length> inspector-pane-width: 306px;
    out property <length> top-bar-height: 54px;
    out property <length> canvas-toolbar-height: 42px;
    out property <length> phone-portrait-width: 390px;
    out property <length> phone-portrait-height: 720px;
    out property <length> phone-landscape-width: 720px;
    out property <length> phone-landscape-height: 390px;
    out property <length> phone-frame-radius: 34px;
    out property <length> phone-status-bar-size: 42px;
    out property <length> phone-outer-padding: 1px;
    out property <length> selection-handle-size: 12px;
    out property <length> radius-handle-size: 10px;
    out property <length> radius-handle-inset: 10px;
}

export component EdgeDivider inherits Rectangle {
    width: 1px;
    background: StudioTheme.border;
}

export component ImagePlaceholder inherits Rectangle {
    in property <bool> active: false;

    border-radius: 16px;
    background: StudioTheme.object-subtle;
    border-width: root.active ? 2px : 1px;
    border-color: root.active ? StudioTheme.accent-strong : StudioTheme.object-border;

    Rectangle {
        width: 48px;
        height: 36px;
        border-radius: 6px;
        border-width: 2px;
        border-color: StudioTheme.object-muted.with-alpha(0.65);

        Rectangle {
            x: 30px;
            y: 8px;
            width: 7px;
            height: 7px;
            border-radius: 3.5px;
            background: StudioTheme.object-muted.with-alpha(0.7);
        }

        Rectangle {
            x: 9px;
            y: 22px;
            width: 30px;
            height: 5px;
            border-radius: 2.5px;
            background: StudioTheme.object-muted.with-alpha(0.55);
        }
    }
}

export component BodyLabel inherits Text {
    color: StudioTheme.text;
    font-size: 13px;
    font-weight: 500;
    overflow: elide;
}

export component MutedLabel inherits Text {
    color: StudioTheme.muted;
    font-size: 12px;
    overflow: elide;
}

export component SectionTitle inherits Text {
    in property <string> label;
    text: label;
    color: StudioTheme.muted;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0px;
}

export component PrimerTextInput inherits Rectangle {
    in-out property <string> text <=> editor.text;
    in property <string> placeholder: "";
    in property <string> leading-text: "";

    height: 34px;
    border-radius: 6px;
    border-width: 1px;
    border-color: editor.has-focus ? StudioTheme.accent-strong : StudioTheme.border;
    background: StudioTheme.panel-bg;
    animate border-color { duration: 120ms; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;

        if root.leading-text != "": Text {
            text: root.leading-text;
            color: StudioTheme.muted;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;

            editor := TextInput {
                width: parent.width;
                height: parent.height;
                text: "";
                color: StudioTheme.text;
                font-size: 13px;
                single-line: true;
                wrap: no-wrap;
                vertical-alignment: center;
                selection-background-color: StudioTheme.accent.with-alpha(0.28);
            }

            if editor.text == "": Text {
                x: editor.x;
                y: editor.y;
                width: editor.width;
                height: editor.height;
                text: root.placeholder;
                color: StudioTheme.muted;
                font-size: 13px;
                vertical-alignment: center;
            }
        }
    }
}

export component PrimerSegmentedTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked;

    height: 30px;
    horizontal-stretch: 1;
    border-radius: 6px;
    background: selected ? StudioTheme.panel-bg : touch.has-hover ? StudioTheme.panel-subtle : transparent;
    border-width: selected ? 1px : 0px;
    border-color: StudioTheme.border;
    animate background { duration: 120ms; }

    Text {
        text: root.label;
        color: root.selected ? StudioTheme.text : StudioTheme.muted;
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component OrientationIconButton inherits Rectangle {
    in property <bool> landscape: false;
    in property <bool> selected: false;
    callback clicked;

    width: 34px;
    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: selected ? StudioTheme.accent-strong : StudioTheme.border;
    background: selected ? StudioTheme.accent.with-alpha(0.14) : touch.has-hover ? StudioTheme.panel-subtle : StudioTheme.panel-bg;
    animate background, border-color { duration: 120ms; }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.landscape ? 18px : 12px;
        height: root.landscape ? 12px : 18px;
        border-radius: 3px;
        border-width: 2px;
        border-color: root.selected ? StudioTheme.accent-strong : StudioTheme.muted;
        background: transparent;

        Rectangle {
            x: root.landscape ? parent.width - 5px : (parent.width - 4px) / 2;
            y: root.landscape ? (parent.height - 4px) / 2 : parent.height - 5px;
            width: root.landscape ? 2px : 4px;
            height: root.landscape ? 4px : 2px;
            border-radius: 1px;
            background: root.selected ? StudioTheme.accent-strong : StudioTheme.muted;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component PrimerNavRow inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected: false;
    in property <length> indent: 0px;

    height: 30px;
    border-radius: 6px;
    background: selected ? StudioTheme.accent.with-alpha(0.13) : touch.has-hover ? StudioTheme.panel-subtle : transparent;

    HorizontalLayout {
        padding-left: 8px + root.indent;
        padding-right: 8px;
        spacing: 8px;

        Text {
            text: root.glyph;
            color: root.selected ? StudioTheme.accent-strong : StudioTheme.muted;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: root.selected ? StudioTheme.text : StudioTheme.muted;
            font-size: 13px;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
    }
}

export component PrimerActionListRow inherits Rectangle {
    in property <PrototypeComponentKind> kind;
    in property <string> label;
    in property <string> detail;
    in property <string> glyph;
    callback drag-started(PrototypeComponentKind, length, length);
    callback drag-moved(PrototypeComponentKind, length, length);
    callback drag-ended(PrototypeComponentKind, length, length);

    private property <length> drag-threshold: 2px;
    property <bool> dragging: AppState.dragging-kind == root.kind;
    property <bool> active: root.dragging || touch.pressed;

    height: 70px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.active ? StudioTheme.accent-strong : StudioTheme.border;
    background: root.active ? StudioTheme.accent.with-alpha(0.08) : StudioTheme.panel-bg;
    opacity: root.active ? 0.45 : 1;

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        Rectangle {
            width: 42px;
            height: 42px;
            border-radius: 7px;
            background: root.kind == PrototypeComponentKind.rectangle ? #fde68a : root.kind == PrototypeComponentKind.text ? #fef3c7 : #dcfce7;
            border-width: 1px;
            border-color: root.kind == PrototypeComponentKind.rectangle ? #f59e0b : root.kind == PrototypeComponentKind.text ? #fbbf24 : #86efac;

            Text {
                text: root.glyph;
                color: root.kind == PrototypeComponentKind.rectangle ? #78350f : root.kind == PrototypeComponentKind.text ? #92400e : #166534;
                font-size: 13px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            spacing: 3px;
            alignment: center;

            BodyLabel {
                text: root.label;
            }

            MutedLabel {
                text: root.detail;
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        private property <bool> drag-active: false;
        private property <length> press-x: 0px;
        private property <length> press-y: 0px;

        changed pressed => {
            if self.pressed {
                self.drag-active = false;
                self.press-x = self.mouse-x;
                self.press-y = self.mouse-y;
            } else if self.drag-active {
                root.drag-ended(root.kind, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                self.drag-active = false;
            }
        }

        moved => {
            let window-x = self.absolute-position.x + self.mouse-x;
            let window-y = self.absolute-position.y + self.mouse-y;
            let moved-far-enough = (self.mouse-x - self.press-x).abs() >= root.drag-threshold
                || (self.mouse-y - self.press-y).abs() >= root.drag-threshold;
            if self.pressed && !self.drag-active && moved-far-enough {
                self.drag-active = true;
                AppState.dragging-kind = root.kind;
                root.drag-started(root.kind, window-x, window-y);
            }
            if self.drag-active {
                AppState.dragging-kind = root.kind;
                root.drag-moved(root.kind, window-x, window-y);
            }
        }
    }
}

export global AppState {
    in-out property <PrototypeComponentKind> dragging-kind: PrototypeComponentKind.none;
    in-out property <length> drag-x: 0px;
    in-out property <length> drag-y: 0px;
    in-out property <length> drag-preview-x: 0px;
    in-out property <length> drag-preview-y: 0px;
    in-out property <length> drag-preview-width: 96px;
    in-out property <length> drag-preview-height: 48px;
}

export component PropertyField inherits Rectangle {
    in property <string> name;
    in property <string> value;

    height: 34px;

    HorizontalLayout {
        spacing: 10px;

        Text {
            width: 80px;
            text: root.name;
            color: StudioTheme.muted;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            border-radius: 6px;
            border-width: 1px;
            border-color: StudioTheme.border;
            background: StudioTheme.panel-subtle;

            Text {
                x: 10px;
                width: parent.width - 20px;
                text: root.value;
                color: StudioTheme.text;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }
}

export component ColorPropertyField inherits Rectangle {
    in property <string> name;
    in property <color> color-value;
    in property <string> value;

    height: 34px;

    HorizontalLayout {
        spacing: 10px;

        Text {
            width: 80px;
            text: root.name;
            color: StudioTheme.muted;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 32px;
            border-radius: 6px;
            border-width: 1px;
            border-color: StudioTheme.border;
            background: StudioTheme.panel-subtle;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 10px;
                spacing: 8px;
                cross-axis-alignment: center;

                Rectangle {
                    width: 16px;
                    height: 16px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: StudioTheme.border;
                    background: root.color-value;
                }

                Text {
                    horizontal-stretch: 1;
                    text: root.value;
                    color: StudioTheme.text;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

export component InspectorSection inherits VerticalLayout {
    in property <string> title;
    spacing: 10px;

    SectionTitle {
        label: root.title;
    }

    @children
}
