import { BodyLabel, MutedLabel, StudioTheme } from "common.slint";

export component LibraryComponentRow inherits Rectangle {
    in property <string> label;
    in property <string> detail;

    height: 70px;
    border-radius: 8px;
    border-width: 1px;
    border-color: StudioTheme.border;
    background: StudioTheme.panel-bg;

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        Rectangle {
            width: 42px;
            height: 42px;
            border-radius: 7px;
            background: #e0e7ff;
            border-width: 1px;
            border-color: #a5b4fc;

            Text {
                text: "C";
                color: #3730a3;
                font-size: 13px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            spacing: 3px;
            alignment: center;

            BodyLabel { text: root.label; }
            MutedLabel { text: root.detail; }
        }
    }

    @children
}
