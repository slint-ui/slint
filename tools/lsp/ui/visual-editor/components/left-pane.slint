import { ScrollView } from "std-widgets.slint";
import {
    EdgeDivider, EditorMetrics, LeftPaneMode, PrimerActionListRow, PrimerSegmentedTab, PrimerTextInput,
    SectionTitle, StudioTheme,
} from "common.slint";
import { Api, PrototypeComponentKind } from "../../api.slint";
import { FileTreeView } from "file-tree-view.slint";
import { LibraryComponentRow } from "library-component-row.slint";

export component LeftPane inherits Rectangle {
    in-out property <LeftPaneMode> mode;
    in-out property <string> search-text;
    callback drag-started(PrototypeComponentKind, Point);
    callback drag-moved(PrototypeComponentKind, Point);
    callback drag-ended(PrototypeComponentKind, Point);

    width: EditorMetrics.left-pane-width;
    background: StudioTheme.panel-bg;

    EdgeDivider {
        x: parent.width - self.width;
    }

    VerticalLayout {
        padding: 14px;
        spacing: 14px;

        Rectangle {
            height: 38px;
            border-radius: 8px;
            background: StudioTheme.panel-subtle;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;

                PrimerSegmentedTab {
                    label: "Files";
                    selected: root.mode == LeftPaneMode.files;
                    clicked => {
                        root.mode = LeftPaneMode.files;
                    }
                }

                PrimerSegmentedTab {
                    label: "Library";
                    selected: root.mode == LeftPaneMode.library;
                    clicked => {
                        root.mode = LeftPaneMode.library;
                    }
                }
            }
        }

        PrimerTextInput {
            text <=> root.search-text;
            placeholder: "Search";
            leading-text: "/";
        }

        if root.mode == LeftPaneMode.files: ScrollView {
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: file-list.preferred-height;
            vertical-scrollbar-policy: always-off;

            file-list := FileTreeView {
                width: parent.width;
            }
        }

        if root.mode == LeftPaneMode.library: ScrollView {
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: library-list.preferred-height;
            vertical-scrollbar-policy: always-off;

            library-list := VerticalLayout {
                width: parent.width;
                spacing: 10px;

                SectionTitle { label: "BASIC"; }

                PrimerActionListRow {
                    kind: PrototypeComponentKind.rectangle;
                    label: "Rectangle";
                    detail: "Prototype shape";
                    glyph: "R";
                    drag-started(kind, position) => { root.drag-started(kind, position); }
                    drag-moved(kind, position) => { root.drag-moved(kind, position); }
                    drag-ended(kind, position) => { root.drag-ended(kind, position); }
                }

                PrimerActionListRow {
                    kind: PrototypeComponentKind.text;
                    label: "Text";
                    detail: "Prototype label";
                    glyph: "T";
                    drag-started(kind, position) => { root.drag-started(kind, position); }
                    drag-moved(kind, position) => { root.drag-moved(kind, position); }
                    drag-ended(kind, position) => { root.drag-ended(kind, position); }
                }

                PrimerActionListRow {
                    kind: PrototypeComponentKind.image;
                    label: "Image";
                    detail: "Prototype media";
                    glyph: "I";
                    drag-started(kind, position) => { root.drag-started(kind, position); }
                    drag-moved(kind, position) => { root.drag-moved(kind, position); }
                    drag-ended(kind, position) => { root.drag-ended(kind, position); }
                }

                Rectangle { height: 6px; }

                for category in Api.known-components: VerticalLayout {
                    width: parent.width;
                    spacing: 10px;

                    SectionTitle { label: category.category; }

                    VerticalLayout {
                        width: parent.width;
                        spacing: 10px;

                        for component in category.components: LibraryComponentRow {
                            label: component.name;
                            detail: component.pretty-location;

                            DragArea {
                                data: Api.new-component-data(component.index);
                                allow-copy: true;
                            }
                        }
                    }
                }
            }
        }
    }
}
