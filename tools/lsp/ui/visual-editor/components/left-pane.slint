import {
    BodyLabel, EdgeDivider, EditorMetrics, MutedLabel, PrimerActionListRow, SectionTitle, SidebarToggleButton,
    StudioTheme,
} from "common.slint";
import { Api, EditorSurfaceMode, PrototypeComponentKind } from "../../api.slint";
import { FileTreeView } from "file-tree-view.slint";

component ElementsUnavailableNotice inherits Rectangle {
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: StudioTheme.soft-border;
    background: StudioTheme.panel-subtle.with-alpha(0.72);

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        cross-axis-alignment: center;

        Rectangle {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border-width: 1px;
            border-color: StudioTheme.border.with-alpha(0.82);
            background: StudioTheme.panel-bg.with-alpha(0.72);

            Rectangle {
                x: 9px;
                y: 9px;
                width: 16px;
                height: 16px;
                border-radius: 5px;
                border-width: 2px;
                border-color: StudioTheme.muted.with-alpha(0.72);
                background: transparent;
            }

            Rectangle {
                x: 7px;
                y: 16px;
                width: 20px;
                height: 2px;
                border-radius: 1px;
                background: StudioTheme.muted.with-alpha(0.82);
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;

            BodyLabel {
                text: "Unavailable for images";
            }

            MutedLabel {
                text: "Open a component to drag elements.";
                wrap: word-wrap;
            }
        }
    }
}

component FilesUnavailableNotice inherits Rectangle {
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: StudioTheme.soft-border;
    background: StudioTheme.panel-subtle.with-alpha(0.72);

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        cross-axis-alignment: center;

        Rectangle {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border-width: 1px;
            border-color: StudioTheme.border.with-alpha(0.82);
            background: StudioTheme.panel-bg.with-alpha(0.72);

            Rectangle {
                x: 8px;
                y: 10px;
                width: 18px;
                height: 14px;
                border-radius: 4px;
                border-width: 2px;
                border-color: StudioTheme.muted.with-alpha(0.72);
                background: transparent;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;

            BodyLabel {
                text: "No files available";
            }

            MutedLabel {
                text: "Open a project file to browse siblings.";
                wrap: word-wrap;
            }
        }
    }
}

component ElementPaletteRows inherits VerticalLayout {
    in property <bool> enabled: true;
    callback drag-started(PrototypeComponentKind, Point);
    callback drag-moved(PrototypeComponentKind, Point);
    callback drag-ended(PrototypeComponentKind, Point);

    spacing: 8px;

    PrimerActionListRow {
        enabled: root.enabled;
        kind: PrototypeComponentKind.rectangle;
        label: "Rectangle";
        detail: "Shape layer";
        drag-started(kind, position) => { root.drag-started(kind, position); }
        drag-moved(kind, position) => { root.drag-moved(kind, position); }
        drag-ended(kind, position) => { root.drag-ended(kind, position); }
    }

    PrimerActionListRow {
        enabled: root.enabled;
        kind: PrototypeComponentKind.text;
        label: "Text";
        detail: "Text layer";
        drag-started(kind, position) => { root.drag-started(kind, position); }
        drag-moved(kind, position) => { root.drag-moved(kind, position); }
        drag-ended(kind, position) => { root.drag-ended(kind, position); }
    }

    PrimerActionListRow {
        enabled: root.enabled;
        kind: PrototypeComponentKind.image;
        label: "Image";
        detail: "Image layer";
        drag-started(kind, position) => { root.drag-started(kind, position); }
        drag-moved(kind, position) => { root.drag-moved(kind, position); }
        drag-ended(kind, position) => { root.drag-ended(kind, position); }
    }
}

export component LeftPane inherits Rectangle {
    in property <bool> can-collapse: false;
    callback drag-started(PrototypeComponentKind, Point);
    callback drag-moved(PrototypeComponentKind, Point);
    callback drag-ended(PrototypeComponentKind, Point);
    callback panes-collapsed();

    private property <bool> image-mode: Api.editor-surface-mode == EditorSurfaceMode.image;

    width: EditorMetrics.left-pane-width;
    background: StudioTheme.panel-bg;

    EdgeDivider {
        x: parent.width - self.width;
    }

    VerticalLayout {
        padding: 14px;
        spacing: 12px;

        HorizontalLayout {
            height: 34px;
            spacing: 10px;
            cross-axis-alignment: center;

            if root.can-collapse: SidebarToggleButton {
                clicked => {
                    root.panes-collapsed();
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                alignment: center;

                BodyLabel {
                    text: "Project";
                    font-size: 14px;
                }

                MutedLabel {
                    text: "Files and elements";
                }
            }
        }

        SectionTitle { label: "FILES"; }

        if Api.file-tree.length == 0: FilesUnavailableNotice { }

        if Api.file-tree.length > 0: FileTreeView {
            vertical-stretch: 1;
        }

        VerticalLayout {
            spacing: 8px;

            SectionTitle { label: "ELEMENTS"; }

            if root.image-mode: ElementsUnavailableNotice { }

            ElementPaletteRows {
                enabled: !root.image-mode;
                drag-started(kind, position) => { root.drag-started(kind, position); }
                drag-moved(kind, position) => { root.drag-moved(kind, position); }
                drag-ended(kind, position) => { root.drag-ended(kind, position); }
            }
        }
    }
}
