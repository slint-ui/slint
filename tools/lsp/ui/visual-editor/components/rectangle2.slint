import { StudioTheme } from "common.slint";
import { MoveResizeFrame } from "move-resize-frame.slint";

export component Rectangle2OnCanvas inherits Rectangle {
    in property <bool> active;
    callback selected();
    callback moved-to(length, length);
    callback resized-to(int, length, length, length, length);

    width: 240px;
    height: 96px;

    MoveResizeFrame {
        width: root.width;
        height: root.height;
        active: root.active;
        selected => { root.selected(); }
        moved-to(x, y) => { root.moved-to(x, y); }
        resized-to(corner, x, y, width, height) => { root.resized-to(corner, x, y, width, height); }

        Rectangle {
            border-radius: 12px;
            background: #fde68a;
            border-width: root.active ? 2px : 1px;
            border-color: root.active ? StudioTheme.accent-strong : #f59e0b;

            Text {
                text: "Rectangle 2";
                color: #78350f;
                font-size: 14px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
