import { InspectorTokens } from "tokens.slint";

export component InspectorIconButton inherits Rectangle {
    in property <string> kind;
    in property <string> label: root.kind;
    in property <bool> selected: false;
    callback clicked;

    width: 18px;
    height: 18px;
    border-radius: 3.5px;
    background: selected ? InspectorTokens.accent.with-alpha(0.12) : touch.has-hover || button-focus.has-focus ? InspectorTokens.field-bg : transparent;
    border-width: button-focus.has-focus ? 1px : 0px;
    border-color: InspectorTokens.accent;
    accessible-role: button;
    accessible-label: root.label;
    accessible-checked: root.selected;
    accessible-action-default => {
        root.clicked();
    }

    button-focus := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Return || event.text == Key.Space {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    if root.kind == "eye": Rectangle {
        x: 3.5px;
        y: 5.5px;
        width: 11px;
        height: 7px;
        border-width: 1px;
        border-color: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        border-radius: 5.5px;

        Rectangle {
            width: 3px;
            height: 3px;
            border-radius: 1.5px;
            background: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        }
    }

    if root.kind == "drop": Rectangle {
        x: 6.5px;
        y: 3px;
        width: 6px;
        height: 11px;
        border-width: 1px;
        border-color: root.selected ? InspectorTokens.accent : InspectorTokens.text;
        border-radius: 4px;
        transform-rotation: 28deg;
    }

    if root.kind == "type-grid": Rectangle {
        for row in 2: Rectangle {
            for col in 2: Rectangle {
                x: 4px + col * 6px;
                y: 4px + row * 6px;
                width: 3px;
                height: 3px;
                border-radius: 1.5px;
                border-width: 1px;
                border-color: InspectorTokens.text;
            }
        }
    }

    if root.kind == "sliders": Rectangle {
        for col in 3: Rectangle {
            x: 4px + col * 4.5px;
            y: 4px;
            width: 1px;
            height: 10px;
            background: InspectorTokens.text;
            border-radius: 1px;
        }
        Rectangle { x: 2.5px; y: 6.5px; width: 4px; height: 1px; background: InspectorTokens.text; }
        Rectangle { x: 7px; y: 10.5px; width: 4px; height: 1px; background: InspectorTokens.text; }
        Rectangle { x: 11.5px; y: 5px; width: 4px; height: 1px; background: InspectorTokens.text; }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            button-focus.focus();
            root.clicked();
        }
    }
}
