export component SimplePreview inherits Window {
    width: 323px;
    height: 398px;
    title: "Simple Preview";

    Rectangle {
        background: #f6f8fa;

    }
    Rectangle {
        width: 243px;
        height: 120px;
        border-radius: 12px;
        background: #ffffff;
        border-width: 1px;
        border-color: #d0d7de;
    
        Text {
            text: "Hello visual editor";
            color: #1f2328;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }
}
