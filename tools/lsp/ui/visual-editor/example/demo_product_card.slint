export component DemoProductCard inherits Window {
    preferred-width: 390px;
    preferred-height: 720px;
    title: "Product Card";
    private property <bool> landscape: root.width > root.height;

    Rectangle {
        width: root.width;
        height: root.height;
        background: #f7f7f5;
    }

    Text {
        x: root.landscape ? 32px : 30px;
        y: root.landscape ? 30px : 34px;
        width: 176px;
        height: 30px;
        text: "Studio Dock";
        color: #111827;
        font-size: 25px;
        font-weight: 800;
    }

    Text {
        x: root.landscape ? 32px : 30px;
        y: root.landscape ? 66px : 70px;
        width: 190px;
        height: 18px;
        text: "Quiet power station";
        color: #6b7280;
        font-size: 13px;
