        width: 132px;
        height: 18px;
        text: "Ships today";
        color: #15803d;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: right;
    }

    Rectangle {
        x: root.landscape ? 382px : 30px;
        y: root.landscape ? 204px : 578px;
        width: 54px;
        height: 32px;
        border-radius: 16px;
        background: #111827;
    }

    Rectangle {
        x: root.landscape ? 450px : 98px;
        y: root.landscape ? 204px : 578px;
        width: 54px;
        height: 32px;
        border-radius: 16px;
        background: #dbeafe;
    }

    Rectangle {
        x: root.landscape ? 518px : 166px;
        y: root.landscape ? 204px : 578px;
        width: 54px;
        height: 32px;
        border-radius: 16px;
