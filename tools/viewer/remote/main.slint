import { Palette } from "std-widgets.slint";

export component EmptyWindow inherits Window {
    // Friendly device name (e.g. "Simon's iPhone") this viewer advertises to editors.
    in property <string> name;
    in property <string> address;
    in property <string> message;

    property <bool> showing-name: true;
    property <bool> dark-color-scheme: Palette.color-scheme == ColorScheme.dark;

    Rectangle {
        background: root.dark-color-scheme ? @linear-gradient(180deg, #1C1C1C, black) : @linear-gradient(180deg, #D7D9DD, white);
    }

    Image {
        y: root.height - self.height;
        width: 100%;
        source: root.dark-color-scheme ? @image-url("assets/bg-frame.svg") : @image-url("assets/bg-frame-light.svg");
    }

    TouchArea {
        clicked => {
            root.showing-name = !root.showing-name;
        }
    }

    VerticalLayout {
        alignment: space-between;
        padding-left: 24px;
        padding-top: root.safe-area-insets.top + 46px;
        padding-bottom: root.safe-area-insets.bottom;
        VerticalLayout {
            alignment: start;
            spacing: 8px;

            HorizontalLayout {
                alignment: start;
                spacing: 2px;
                align-items: end;
                Text {
                    text: "Connect to";
                    font-size: 26px;
                    font-weight: 100;
                }

                Image {
                    width: 30px;
                    source: @image-url("assets/slint-logo-small-light.svg");
                }
            }

            Text {
                text: root.showing-name ? name : address;
                font-size: 24px;
                font-weight: 400;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 8px;
            opacity: 0.5;
            Text {
                text: "Slint 1.17.0";
                font-size: 14px;
                font-weight: 400;
            }

            Text {
                text: "Viewer v0.0.3";
                font-size: 12px;
                font-weight: 400;
            }
        }
        // HorizontalLayout {
        //     alignment: center;
        //     VerticalLayout {
        //         alignment: center;
        //         spacing: 8px;

        //         Text {
        //             text: "Connect to";
        //             horizontal-alignment: center;
        //             font-size: 20px;
        //             font-weight: 400;
        //         }
        //         Text {
        //             text: root.showing-name ? name : address;
        //             horizontal-alignment: center;
        //             font-size: 20px;
        //             font-weight: 700;
        //         }
        //         Text {
        //             text: "on your PC";
        //             horizontal-alignment: center;
        //             font-size: 20px;
        //             font-weight: 400;
        //         }
        //     }
        // }
    }
}
