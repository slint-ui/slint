export component EmptyWindow inherits Window {
    in property <string> address;
    in property <string> message;

    HorizontalLayout {
        alignment: center;
        VerticalLayout {
            alignment: center;

            if message == "": Text {
                text: address;
            }
            if message != "": Text {
                text: message;
            }
        }
    }
}
