import { Palette } from "std-widgets-impl.slint";

export component ToolTip inherits Rectangle {
    in property <string> text;

    background: Palette.alternate-background;
    border-radius: 4px;
    border-width: 1px;
    border-color: Palette.border;

    VerticalLayout {
        padding: 6px;
        Text {
            text: root.text;
            color: Palette.foreground;
        }
    }
}
