export interface SpinBox {
    in property <bool> enabled: true;
    out property <bool> has-focus: false;
    in-out property <int> value: minimum;
    in property <int> minimum: 0;
    in property <int> maximum: 100;
    in property <bool> read-only: false;
    in property <int> step-size: 1;
    in property <TextHorizontalAlignment> horizontal-alignment: left;

    callback edited(value: int);
}
