import { Palette } from "std-widgets-impl.slint";

export component ToolTipImpl inherits Rectangle {
    in property <string> text;
    in property <bool> no-background: false;

    background: no-background ? transparent : Palette.alternate-background;
    border-radius: 4px;
    border-width: no-background ? 0px : 1px;
    border-color: Palette.border;

    VerticalLayout {
        padding-left: no-background ? 0px : 9px;
        padding-right: no-background ? 0px : 9px;
        padding-top: no-background ? 0px : 6px;
        padding-bottom: no-background ? 0px : 6px;

        if root.text != "": Text {
            text: root.text;
            color: Palette.foreground;
        }

        @children
    }
}
