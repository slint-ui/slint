// Test error cases for optional types

export component TestCase {
    // Error: Cannot assign optional to non-optional without unwrap/coalesce
    property <string> text: none;
//                          >   <error{Cannot convert <error>? to string}

    property <string?> opt_text: none;
    property <string> text2: opt_text;
//                           >       <error{Cannot convert string? to string}

    // Error: Unwrap on non-optional type
    property <string> regular_text: "hello";
    property <string> unwrapped: regular_text!;
//                               >          <error{Cannot unwrap non-optional type 'string'}

    // Error: Null-coalesce on non-optional
    property <int> regular_num: 42;
    property <int> coalesced: regular_num ?? 0;
//                            >              <error{The '??' operator requires an optional left-hand side}

    // Error: Type mismatch in null-coalesce fallback
    property <string?> opt_str: none;
    property <string> wrong_fallback: opt_str ?? 123;
}
