// Parser-level syntax errors for the `implement` statement.

interface Base {
    out property <bool> test;
}

// `implement` requires `<=>` and a target.
export component NoArrow {
    implement Base;
//                ^error{Syntax error: expected '<=>'}
//                ^^error{Syntax error: expected Identifier}
}

// `implement` requires a target identifier after `<=>`.
export component NoTarget {
    implement Base <=> ;
//                     ^error{Syntax error: expected Identifier}
}
