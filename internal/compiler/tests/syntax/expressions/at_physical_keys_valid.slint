export component SuperSimple {
    property <[keys]> shortcuts: [
        @physical-keys(A),
        @physical-keys(Control + Shift + Digit1),
        @physical-keys(Meta + LeftArrow),
        @physical-keys(Alt? + BackQuote),
        @physical-keys(Control + PageDown),
    ];
}
