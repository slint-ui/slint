//config:generate_all_exported_windows

export component A inherits SystemTrayIcon {
    if false : Menu {}
//             >   <error{SystemTrayIcon's Menu cannot be in a conditional or repeated element}
}

export component B inherits SystemTrayIcon {
    for _ in [1,2,3] : Menu {}
//                     >   <error{SystemTrayIcon's Menu cannot be in a conditional or repeated element}
}

export component C inherits SystemTrayIcon {
    Menu {
//  >   <note{First Menu defined here}
        MenuItem { title: "ok"; }
    }
    Menu {
//  >   <error{Only one Menu is allowed in a SystemTrayIcon}
        MenuItem { title: "another"; }
    }
}
