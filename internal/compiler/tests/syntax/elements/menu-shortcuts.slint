export component Test inherits Window {
    MenuBar {
        Menu {
            MenuItem {
                shortcut: @keys(Control + N);
            }
        }
    }

    in-out property <bool> conditional;
    in-out property <[keys]> dynamic;

    ContextMenuArea {
        Menu {
            MenuItem {
                shortcut: @keys(Control + X);
//                        >                 <error{MenuItem shortcuts are currently only supported in the MenuBar}
            }

            if conditional: MenuItem {
                shortcut: @keys(Control + Y);
//                        >                 <error{MenuItem shortcuts are currently only supported in the MenuBar}
            }

            for key in dynamic: MenuItem {
                shortcut: key;
//                        >  <error{MenuItem shortcuts are currently only supported in the MenuBar}
            }
        }
    }
}
