export component Hello {
    Rectangle {
        absolute-position: {x: 45px, y: 78px};
//      >               <error{Cannot assign to out property 'absolute-position'}

    }

    Rectangle {
        init => {
            self.absolute-position.x += 45px;
//          >                              <error{Self assignment on an out property}
        }
    }
}
