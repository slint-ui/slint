export global A {
    callback compute(int) -> int;
}

export global B {
    callback compute <=> A.compute;
    compute(x) => { return x * 2; }
//  >     <error{Callback 'compute' is implemented in more than one global}
}

export global C {
    callback compute <=> A.compute;
    compute(x) => { return x * 3; }
//  >     <error{Callback 'compute' is implemented in more than one global}
}
