export component Foo {
    in-out property <bool> foo;
    @children
    match foo {
        true: Rectangle { background: blue; }
        false: Rectangle { background: blue; }
    }
}

export component Bar {
    in-out property <bool> foo;
    match foo {
        true: Rectangle { background: blue; }
        false: Rectangle { background: blue; }
    }
    @children
}

export component Baz {
    in-out property <bool> foo;
    match foo {
        true: Rectangle {
            @children
//          >       <error{The @children placeholder cannot appear in a match element}
        }
    }
}

