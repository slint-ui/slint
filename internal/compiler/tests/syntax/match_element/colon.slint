export component Foo {
    in-out property <bool> foo: false;
    match foo {
        true Rectangle { }
//           >       <error{Expected ':' after match case expression}
    }
}

export component Bar {
    in-out property <bool> foo: false;
    match foo {
        true: Rectangle { }
        false Rectangle { }
//            >       <error{Expected ':' after match case expression}
    }
}

export component Baz {
    in-out property <int> foo: 0;
    match foo {
        0: Rectangle { }
        1: Rectangle { }
        * Rectangle { }
//        >       <error{Expected ':' after '*'}
    }
}


export component Qux {
    in-out property<int> foo: 1;

    match foo {
        1 => Rectangle { }
//        ><error{Expected ':' after match case expression}
    }
}

export component FooBar {
    in-out property<int> foo: 1;
    match foo {
        1: Rectangle { }
        * => Rectangle { }
//        ><error{Expected ':' after '*'}
    }
}
