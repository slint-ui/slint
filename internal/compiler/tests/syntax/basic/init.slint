export component CallInit {
    Rectangle {
        init => {
            self.x = 0;
            self.init();
//          >         <warning{Calling 'init' explicitly does nothing and is deprecated}
        }
    }
    init => {
        self.init();
//      >         <warning{Calling 'init' explicitly does nothing and is deprecated}
    }
}

export component CallInitFromOutside {
    r := Rectangle {
        init => {
            self.x = 0;
        }
    }
    init => {
        r.init();
//      >      <warning{Calling 'init' explicitly does nothing and is deprecated}
    }
}
