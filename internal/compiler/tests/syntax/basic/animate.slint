export SuperSimple := Rectangle {
//                 ><warning{':=' to declare a component is deprecated. The new syntax declare components with 'component MyComponent {'. Read the documentation for more info}

    animate x {
        duration: 1000ms;
        easing: linear;
    }

    animate x {
//          ><error{Duplicated animation}
        duration: 1000ms;
    }

    animate y {
        nonexistent: 42;
//      >         <error{Unknown property nonexistent in PropertyAnimation}
    }

    animate text {
//          >   <error{'text' is not a property that can be animated}
    }

    animate * { duration: 100ms; }
//          ^error{catch-all property is only allowed within transitions}

    animate background, foo { duration: 100ms; }
//                      >  <error{'foo' is not a property that can be animated}

    text := Text{ animate x { duration: 1000ms; } }
    animate text.x { duration: 100ms; }
//          >     <error{Can only refer to property in the current element}

    animate width { easing: spring; bounce: 0.0; }
//                          >     <error{A spring easing must have a duration}
    Rectangle {
        animate x { easing: linear; bounce: 0.0; }
//                                          >  <error{Cannot have 'bounce' with a non Spring easing curve}
        animate y { easing: linear; mass: 0.0; }
//                                        >  <error{Cannot have 'mass' with a non Spring easing curve}
        animate width { easing: linear; stiffness: 0.0; }
//                                                 >  <error{Cannot have 'stiffness' with a non Spring easing curve}
        animate height { easing: linear; damping: 0.0; }
//                                                >  <error{Cannot have 'damping' with a non Spring easing curve}
    }
    Rectangle {
        animate x { easing: spring; bounce: 0.0; duration: 100ms; mass: 0.0; }
//                          >     <error{Cannot mix 'bounce'/'duration' with 'mass'/'stiffness'/'damping' in a spring animation}
        animate y { easing: spring; mass: 0.0; }
//                          >     <error{'mass', 'stiffness' and 'damping' must all be set together in a spring animation}
    }
}
