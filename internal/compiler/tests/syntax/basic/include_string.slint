export component TestCase {
    property <string> empty: @include_string("");
//                           >                 <error{File cannot be empty}
    property <string> missing_file: @include_string("missing_file.txt");
//                                  >                                 <error{File '📂/tests/syntax/basic/missing_file.txt' does not exist}
    property <string> valid_file: @include_string("include_string_file.txt");
}
