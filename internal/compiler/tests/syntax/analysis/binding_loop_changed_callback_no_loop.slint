// Negative test: a changed callback on a property that does NOT depend on layout
// should not trigger any binding loop warning.

component RepeatedItem {
    in property <int> counter;

    changed counter => {
        debug(self.counter);
    }

    Rectangle {
        height: 20px;
    }
}

export component TestNoLoop inherits Window {
    property <[int]> model: [1, 2, 3];

    HorizontalLayout {
        for item in model: RepeatedItem {
            counter: 42;
        }
    }
}
