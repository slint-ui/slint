// Test that binding loop detection works for nested repeaters.
// An init callback in a component used inside a nested repeater inside a layout
// should still be detected.

component Inner {
    in property <length> item-width;

    init => {
        debug(self.item-width);
    }

    Rectangle {
        width: item-width;
        height: 20px;
    }
}

component Outer {
//              >warning{The binding for the property 'layoutinfo-h' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
    in property <length> outer-width;

    HorizontalLayout {
//  >               <warning{The binding for the property 'layoutinfo-h' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
        for j in [1, 2]: Inner {
            item-width: outer-width;
//                      >          <warning{The binding for the property 'item-width' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
        }
    }
}
//<<<warning{The binding for the property 'layoutinfo-h' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}

export component TestNestedRepeaterLoop inherits Window {
//                                               >     <warning{The binding for the property 'layoutinfo-h' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
    HorizontalLayout {
//  >               <warning{The binding for the property 'width' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
//  >               <^warning{The binding for the property 'layoutinfo-h' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
        for i in [1, 2, 3]: Outer {
            outer-width: parent.width / 3;
//                       >               <warning{The binding for the property 'outer-width' is part of a binding loop (width -> outer-width -> item-width -> layoutinfo-h -> layoutinfo-h -> layoutinfo-h -> root.layoutinfo-h).↵This was allowed in previous version of Slint, but is deprecated and may cause panic at runtime}
        }
    }
}
