export component Test {
    VerticalLayout {
//  >             <error{The binding for the property 'layout-cache-ortho' is part of a binding loop (cross-axis-alignment -> layout-cache-ortho -> r.x -> cross-axis-alignment)}
//  >             <^error{The binding for the property 'x' is part of a binding loop (cross-axis-alignment -> layout-cache-ortho -> r.x -> cross-axis-alignment)}
        cross-axis-alignment: r.x > 10px ? start : end;
//                            >                       <error{The binding for the property 'cross-axis-alignment' is part of a binding loop (cross-axis-alignment -> layout-cache-ortho -> r.x -> cross-axis-alignment)}
        r := Rectangle {
            preferred-width: 50px;
        }
    }
}
