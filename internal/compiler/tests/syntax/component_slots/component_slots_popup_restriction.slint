export component PopupSlotHost inherits Rectangle {
    slot header;

    PopupWindow {
        header {}
//      >       <error{The slot 'header' cannot appear in a PopupWindow}
    }
}

export component FailSlotInPopup inherits Rectangle {
    PopupSlotHost {
        header << Rectangle { }
    }
}
