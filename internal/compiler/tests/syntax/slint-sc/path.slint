        width: 100px;
//      >   <error{Bindings are not supported in Slint SC}
//             >   <^error{Number literals are not supported in Slint SC}
        height: 100px;
//      >    <error{Bindings are not supported in Slint SC}
//              >   <^error{Number literals are not supported in Slint SC}
    }
}
