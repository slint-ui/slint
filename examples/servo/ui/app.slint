import {
    VerticalBox,
    HorizontalBox,
    Button,
    LineEdit,
} from "std-widgets.slint";

import { Webview } from "../src/webview/webview.slint";

export { WebviewLogic } from "../src/webview/webview.slint";

export component MyApp inherits Window {
    preferred-width: 1224px;
    preferred-height: 768px;

    property <length> toolbar-height: 50px;
    property <length> toolbar-padding: 8px;
    property <length> toolbar-spacing: 8px;

    // On mobile (e.g. iOS/Android) safe-area-insets.top is non-zero.
    property <bool> is-mobile: root.safe-area-insets.top > 0px;

    contextMenuArea := ContextMenuArea {
        Menu {
            MenuItem {
                title: "Back";
                activated => webview.back();
            }

            MenuItem {
                title: "Forward";
                activated => webview.forward();
            }

            MenuItem {
                title: "Reload";
                activated => webview.reload();
            }

            MenuItem {
                title: "Go";
                activated => webview.loadUrl(lineEdit.text);
            }
        }
    }

    VerticalBox {
        padding-left: root.safe-area-insets.left;
        padding-top: root.safe-area-insets.top;
        padding-right: root.safe-area-insets.right;
        padding-bottom: root.safe-area-insets.bottom;

        HorizontalBox {
            height: root.toolbar-height;
            padding: root.toolbar-padding;
            spacing: root.toolbar-spacing;

            if !root.is-mobile: Button {
                text: "Back";
                clicked => webview.back();
            }

            if !root.is-mobile: Button {
                text: "Forward";
                clicked => webview.forward();
            }

            if !root.is-mobile: Button {
                text: "Reload";
                clicked => webview.reload();
            }

            lineEdit := LineEdit {
                text: webview.current_url;
                horizontal-stretch: 1;
                accepted(url) => webview.loadUrl(lineEdit.text);
            }

            if !root.is-mobile: Button {
                text: "Go";
                clicked => webview.loadUrl(lineEdit.text);
            }

            if root.is-mobile: Button {
                text: "...";
                clicked => contextMenuArea.show({ x: self.absolute-position.x, y: self.absolute-position.y + self.height });
            }
        }

        Rectangle {
            webview := Webview {
                width: 100%;
                height: 100%;
                changed current_url => {
                    lineEdit.text = self.current_url;
                }
            }
        }
    }
}
