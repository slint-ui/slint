export component HelloWorld inherits Window {
    in-out property <int> counter: 0;
    callback button-clicked;

    VerticalLayout {
        alignment: center;

        Text {
            text: "Hello, Swift! Count: " + counter;
            horizontal-alignment: center;
            font-size: 24px;
        }

        Button {
            text: "Click me";
            clicked => {
                root.counter += 1;
                root.button-clicked();
            }
        }
    }
}
