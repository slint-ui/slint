export component MainWindow inherits Window {
    width: 320px;
    height: 240px;

    background: #ff000047;

    in property <color> color-0: Colors.green;
    in property <color> color-1: Colors.orange;
    in property <color> color-2: Colors.red;

    first := Rectangle {
        x: 0px;
        y: 0px;
        width: 40px;
        height: self.width;
        background: color-0;
    }

    second := Rectangle {
        x: 50px;
        y: 0px;
        width: 40px;
        height: self.width;
        background: color-1;
    }

    third := Rectangle {
        x: 100px;
        y: 0px;
        width: 40px;
        height: self.width;
        background: color-2;
    }

    Image {
        x: 160px;
        y: 0px;
        width: 64px;
        height: 64px;
        source: @image-url("../../../logo/slint-logo-square-light-128x128.png");
    }
}
