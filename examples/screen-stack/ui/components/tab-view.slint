import { ScreenWithHeader } from "screen-with-header.slint";

// Reusable tab view component with horizontal tabs
// Usage:
//   TabView {
//       tabs: ["Tab 1", "Tab 2", "Tab 3"];
//       // Content for each tab using current-tab index
//   }
export component TabView inherits ScreenWithHeader {
    in property <[string]> tabs;
    in-out property <int> current-tab: 0;
    callback tab-changed(int);

    // Fill parent completely
    Rectangle {
        width: 100%;
        height: 100%;

        VerticalLayout {
        // Tab bar
        Rectangle {
            height: 48px;
            background: white;

            HorizontalLayout {
                for tab[index] in root.tabs: Rectangle {
                    horizontal-stretch: 1;
                    background: touch.pressed ? #f0f0f0 : transparent;

                    VerticalLayout {
                        alignment: center;

                        Text {
                            text: tab;
                            font-size: 14px;
                            font-weight: index == root.current-tab ? 600 : 400;
                            horizontal-alignment: center;
                            color: index == root.current-tab ? #2196F3 : #757575;
                        }
                    }

                    // Active indicator
                    Rectangle {
                        y: parent.height - 3px;
                        height: 3px;
                        background: index == root.current-tab ? #2196F3 : transparent;
                    }

                    touch := TouchArea {
                        clicked => {
                            root.current-tab = index;
                            root.tab-changed(index);
                        }
                    }
                }
            }

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: #e0e0e0;
            }
        }

        // Content area - use @children
        Rectangle {
            vertical-stretch: 1;
            background: #f5f5f5;
            clip: true;

            @children
        }
        }
    }
}
